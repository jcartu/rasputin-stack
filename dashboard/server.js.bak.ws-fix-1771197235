// ─── Trace Hierarchy Builder ──────────────────────────────────────────────────
function buildEventHierarchy(events) {
  // Build hierarchical structure based on event sequence and timing
  // This is a heuristic approach until OpenClaw provides parent_id natively
  
  const hierarchy = [];
  const stack = [];
  
  events.forEach((event, index) => {
    // Calculate depth based on context
    let depth = 0;
    
    // User messages and agent responses are root level
    if (event.type === 'user-message' || event.type === 'agent-response') {
      depth = 0;
      stack.length = 0; // Clear stack
    }
    // Tool calls and thinking are nested under agent responses
    else if (event.type === 'tool-call' || event.type === 'thinking') {
      // Find the last agent-response or user-message in stack
      if (stack.length > 0 && (stack[stack.length - 1].type === 'agent-response' || stack[stack.length - 1].type === 'user-message')) {
        depth = 1;
      } else {
        depth = Math.min(stack.length, 2); // Max depth of 3
      }
    }
    // Errors can be nested under tool calls
    else if (event.type === 'error') {
      depth = Math.min(stack.length, 2);
    }
    
    event.depth = depth;
    
    // Add to hierarchy or parent's children
    if (depth === 0) {
      hierarchy.push(event);
      stack.push(event);
    } else if (stack.length > 0) {
      const parent = stack[stack.length - 1];
      if (!parent.children) parent.children = [];
      parent.children.push(event);
      
      // Push tool calls onto stack so their children can nest
      if (event.type === 'tool-call') {
        stack.push(event);
      }
    } else {
      // Fallback: add to root if no parent found
      hierarchy.push(event);
    }
    
    // Pop stack if we're moving back to root level on next iteration
    if (index < events.length - 1) {
      const nextEvent = events[index + 1];
      if (nextEvent.type === 'user-message' || nextEvent.type === 'agent-response') {
        stack.length = 0;
      }
    }
  });
  
  return hierarchy;
}

