// ─── Gateway WebSocket Client ─────────────────────────────────────────────────
class GatewayWSClient {
  constructor(url, token, password) {
    this.url = url;
    this.token = token;
    this.password = password;
    this.ws = null;
    this.reconnectDelay = 800;
    this.maxReconnectDelay = 15000;
    this.reconnectFactor = 1.7;
    this.reconnectTimer = null;
    this.pendingRPC = new Map(); // requestId → { resolve, reject, timeout }
    this.nextRequestId = 1;
    this.connected = false;
    this.authenticated = false;
  }

  connect() {
    if (this.ws) return;
    
    console.log('[Gateway] Connecting to', this.url);
    
    try {
      // Node v25 has native WebSocket
      this.ws = new WebSocket(this.url);
      
      this.ws.onopen = () => {
        console.log('[Gateway] WebSocket connected');
        this.connected = true;
        this.reconnectDelay = 800; // Reset backoff on successful connection
      };
      
      this.ws.onmessage = (event) => {
        try {
          const msg = JSON.parse(event.data);
          this.handleMessage(msg);
        } catch (e) {
          console.error('[Gateway] Failed to parse message:', e.message);
        }
      };
      
      this.ws.onclose = () => {
        console.log('[Gateway] WebSocket closed');
        this.connected = false;
        this.authenticated = false;
        this.ws = null;
        this.scheduleReconnect();
      };
      
      this.ws.onerror = (err) => {
        const msg = err.message || '';
        if (msg && msg !== 'Unknown error') {
          console.error('[Gateway] WebSocket error:', msg);
        }
      };
    } catch (e) {
      console.error('[Gateway] Failed to create WebSocket:', e.message);
      this.scheduleReconnect();
    }
  }

  scheduleReconnect() {
    if (this.reconnectTimer) return;
    
    console.log(`[Gateway] Reconnecting in ${this.reconnectDelay}ms`);
    this.reconnectTimer = setTimeout(() => {
      this.reconnectTimer = null;
      this.reconnectDelay = Math.min(this.reconnectDelay * this.reconnectFactor, this.maxReconnectDelay);
      this.connect();
    }, this.reconnectDelay);
  }

  handleMessage(msg) {
    // Handle RPC responses (protocol: type="res", ok=true/false)
    if (msg.type === 'res' && msg.id && this.pendingRPC.has(msg.id)) {
      const pending = this.pendingRPC.get(msg.id);
      clearTimeout(pending.timeout);
      this.pendingRPC.delete(msg.id);
      
      if (!msg.ok) {
        pending.reject(new Error(msg.error?.message || 'RPC error'));
      } else {
        // Connect response has payload.type === 'hello-ok'
        if (msg.payload?.type === 'hello-ok') {
          console.log('[Gateway] Authenticated successfully');
          this.authenticated = true;
        }
        pending.resolve(msg.payload);
      }
      return;
    }

    // Handle broadcast events (protocol: type="event")
    if (msg.type === 'event' && msg.event === 'connect.challenge') {
      console.log('[Gateway] Received challenge, authenticating with token:', !!this.token, 'password:', !!this.password);
      const reqId = String(this.nextRequestId++);
      const connectReq = {
        type: 'req',
        id: reqId,
        method: 'connect',
        params: {
          minProtocol: 3,
          maxProtocol: 3,
          client: {
            id: 'cli',
            version: '2.0.0',
            platform: 'linux',
            mode: 'cli'
          },
          role: 'operator',
          scopes: ['operator.read', 'operator.write', 'operator.admin', 'operator.approvals'],
          caps: [],
          auth: { token: this.token, password: this.password },
          userAgent: 'nexus-dashboard/2.0.0'
        }
      };
      // Register pending RPC for the connect response
      this.pendingRPC.set(reqId, {
        resolve: () => {},
        reject: (err) => console.error('[Gateway] Connect failed:', err.message),
        timeout: setTimeout(() => {
          this.pendingRPC.delete(reqId);
          console.error('[Gateway] Connect request timed out');
        }, 10000)
      });
      this.send(connectReq);
      return;
    }

    // Handle broadcast events (skip connect.challenge — already handled above)
    if (msg.type === 'event' && msg.event && msg.event !== 'connect.challenge') {
      this.handleBroadcast(msg);
    }
  }

  handleBroadcast(msg) {
    const eventMap = {
      'chat': 'gateway_chat',
      'agent': 'gateway_agent',
      'presence': 'gateway_presence',
      'cron': 'gateway_cron',
      'heartbeat': 'gateway_heartbeat',
      'exec.approval.requested': 'gateway_exec_approval',
      'exec.approval.resolved': 'gateway_exec_resolved'
    };

    const dashboardType = eventMap[msg.event];
    if (dashboardType) {
      // Forward to dashboard clients immediately (real-time, no file polling delay)
      broadcast({
        type: dashboardType,
        payload: msg.payload || msg,
        timestamp: Date.now()
      });
    }

    // Immediately trigger session file poll on agent/chat events (don't wait for interval)
    if (msg.event === 'agent' || msg.event === 'chat') {
      for (const [filePath] of tailedSessions) {
        pollSessionFile(filePath);
      }
    }
  }

  send(msg) {
    if (!this.ws || this.ws.readyState !== WebSocket.OPEN) {
      throw new Error('WebSocket not connected');
    }
    this.ws.send(JSON.stringify(msg));
  }

  async rpc(method, params = {}, timeoutMs = 30000) {
    if (!this.authenticated) {
      throw new Error('Not authenticated to gateway');
    }

    const id = String(this.nextRequestId++);
    
    return new Promise((resolve, reject) => {
      const timeout = setTimeout(() => {
        this.pendingRPC.delete(id);
        reject(new Error('RPC timeout'));
      }, timeoutMs);

      this.pendingRPC.set(id, { resolve, reject, timeout });

      this.send({
        type: 'req',
        id,
        method,
        params
      });
    });
  }

  disconnect() {
    if (this.reconnectTimer) {
      clearTimeout(this.reconnectTimer);
      this.reconnectTimer = null;
    }
    if (this.ws) {
      this.ws.close();
      this.ws = null;
    }
    this.connected = false;
    this.authenticated = false;
  }
}

