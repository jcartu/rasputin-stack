// Graceful shutdown
function shutdown(signal) {
  saveCosts();
  logInfo('Shutdown initiated', { signal });
  clearInterval(pingInterval);
  if (pollTimer) clearInterval(pollTimer);
  if (dirWatcher) dirWatcher.close();
  
  // Disconnect gateway client
  if (gatewayClient) {
    gatewayClient.disconnect();
    logInfo('Gateway client disconnected');
  }
  
  // Close all session watchers
  for (const [, entry] of tailedSessions) {
    if (entry.watcher) {
      try { entry.watcher.close(); } catch (_) {}
    }
  }
  
  for (const socket of clients) {
    wsClose(socket, 1001, 'server shutting down');
  }
  server.close(() => {
    logInfo('Server closed');
    process.exit(0);
  });
  setTimeout(() => process.exit(1), 5000);
}
process.on('SIGTERM', () => shutdown('SIGTERM'));
process.on('SIGINT', () => shutdown('SIGINT'));
