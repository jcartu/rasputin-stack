function checkAuthRate(ip) {
  const now = Date.now();
  let entry = authAttempts.get(ip);
  if (!entry || now > entry.resetAt) {
    entry = { attempts: 0, resetAt: now + 60000 };
    authAttempts.set(ip, entry);
