function handleTokenStream(msg) {
  if (!state.streamingMsg) {
    state.streamingMsg = addStreamMessage('ai', '', msg.ts);
  }

  const textEl = state.streamingMsg.querySelector('.stream-text');
  const text = msg.text || '';
  textEl.textContent = text;
  scrollToBottom();
