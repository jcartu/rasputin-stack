  if (widget && !widget.classList.contains('collapsed')) {
    widget.classList.add('collapsed');
  }
}, 10000);

// ═══════════════════════════════════════════════════════════════════
// PREDICTIVE LATENCY MONITORING SYSTEM
// Chaos Monkey UI Evolution - Warns before gateway starvation
// ═══════════════════════════════════════════════════════════════════

const PredictiveLatency = {
  history: [],
  maxHistory: 60, // 60 seconds of data
  wsErrors: [],
  wsErrorWindow: 60000, // 1 minute
  chart: null,
  lastUpdate: Date.now(),
  
  // Risk thresholds
  thresholds: {
    latencyHigh: 3000,      // 3s
    latencyCritical: 5000,  // 5s
    trendWarning: 1.5,      // 50% increase
    wsErrorRate: 5,         // 5 errors/min
  },
  
  // Initialize the system
  init() {
    this.setupChart();
    this.startMonitoring();
    console.log('[PredictiveLatency] Initialized');
  },
  
  // Setup trend chart
  setupChart() {
    const canvas = document.getElementById('prediction-trend-chart');
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    this.chart = { canvas, ctx };
  },
  
  // Start monitoring loop
  startMonitoring() {
    setInterval(() => this.update(), 1000);
  },
  
  // Record latency sample
  recordLatency(ms, metadata = {}) {
    const sample = {
      timestamp: Date.now(),
      latency: ms,
      ...metadata
    };
    
    this.history.push(sample);
    
    // Keep only recent history
    if (this.history.length > this.maxHistory) {
      this.history.shift();
    }
  },
  
  // Record WebSocket error
  recordWSError(error) {
    this.wsErrors.push({
      timestamp: Date.now(),
      error: error
    });
    
    // Clean old errors
    const cutoff = Date.now() - this.wsErrorWindow;
    this.wsErrors = this.wsErrors.filter(e => e.timestamp > cutoff);
  },
  
  // Calculate trend (linear regression slope)
  calculateTrend() {
    if (this.history.length < 10) return { slope: 0, direction: 'stable' };
    
    const recent = this.history.slice(-30); // Last 30 samples
    const n = recent.length;
    
    let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
    
    recent.forEach((sample, i) => {
      sumX += i;
      sumY += sample.latency;
      sumXY += i * sample.latency;
      sumX2 += i * i;
    });
    
    const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
    
    let direction = 'stable';
    if (slope > 20) direction = 'rising';
    else if (slope > 50) direction = 'critical';
    else if (slope < -20) direction = 'falling';
    
    return { slope: slope.toFixed(2), direction };
  },
  
  // Calculate risk score (0-100)
  calculateRisk() {
    if (this.history.length < 5) return 0;
    
    let risk = 0;
    
    // Recent latency average
    const recent = this.history.slice(-10);
    const avgLatency = recent.reduce((sum, s) => sum + s.latency, 0) / recent.length;
    
    if (avgLatency > this.thresholds.latencyHigh) risk += 30;
    if (avgLatency > this.thresholds.latencyCritical) risk += 40;
    
    // Trend
    const trend = this.calculateTrend();
    if (trend.direction === 'rising') risk += 20;
    if (trend.direction === 'critical') risk += 30;
    
    // WebSocket errors
    const wsErrorRate = this.wsErrors.length;
    if (wsErrorRate >= this.thresholds.wsErrorRate) risk += 30;
    
    // Recent spikes
    const maxRecent = Math.max(...recent.map(s => s.latency));
    if (maxRecent > this.thresholds.latencyCritical * 1.5) risk += 20;
    
    return Math.min(100, risk);
  },
  
  // Predict time to issue (in seconds, or null if none predicted)
  predictTimeToIssue() {
    const trend = this.calculateTrend();
    const risk = this.calculateRisk();
    
    if (risk < 50) return null;
    if (trend.direction === 'critical') return 30; // 30 seconds
    if (trend.direction === 'rising') return 120; // 2 minutes
    if (risk > 70) return 60; // 1 minute
    
    return null;
  },
  
  // Generate insights
  generateInsights() {
    const insights = [];
    const trend = this.calculateTrend();
    const risk = this.calculateRisk();
    const wsErrorRate = this.wsErrors.length;
    
    if (this.history.length < 5) {
      return ['📊 Collecting baseline data...'];
    }
    
    const recent = this.history.slice(-10);
    const avgLatency = recent.reduce((sum, s) => sum + s.latency, 0) / recent.length;
    
    if (trend.direction === 'rising' || trend.direction === 'critical') {
      insights.push(`📈 Latency trending upward (+${trend.slope}ms/s)`);
    }
    
    if (avgLatency > this.thresholds.latencyHigh) {
      insights.push(`⚠️ Average latency elevated: ${avgLatency.toFixed(0)}ms`);
    }
    
    if (wsErrorRate >= this.thresholds.wsErrorRate) {
      insights.push(`🔌 WebSocket instability: ${wsErrorRate} errors/min`);
    }
    
    if (risk > 70) {
      insights.push(`🚨 High risk of gateway starvation detected`);
    } else if (risk > 40) {
      insights.push(`⚡ Moderate performance degradation observed`);
    }
    
    const timeToIssue = this.predictTimeToIssue();
    if (timeToIssue !== null) {
      insights.push(`⏱️ Potential issue in ~${timeToIssue}s if trend continues`);
    }
    
    if (insights.length === 0) {
      insights.push('✅ All systems nominal');
    }
    
    return insights;
  },
  
  // Update UI
  update() {
    const now = Date.now();
    
    // Update from state.latency if available (from main dashboard)
    if (window.state && window.state.latency && window.state.latency.length > 0) {
      const latestLatency = window.state.latency[window.state.latency.length - 1];
      if (latestLatency && (now - this.lastUpdate) >= 1000) {
        this.recordLatency(latestLatency.duration || latestLatency.latency || 0);
        this.lastUpdate = now;
      }
    }
    
    // Calculate metrics
    const trend = this.calculateTrend();
    const risk = this.calculateRisk();
    const timeToIssue = this.predictTimeToIssue();
    const insights = this.generateInsights();
    
    // Update trend
    const trendEl = document.getElementById('latency-trend');
    const trendIndEl = document.getElementById('trend-indicator');
    if (trendEl && trendIndEl) {
      let trendColor = 'var(--cyan)';
      let trendText = 'STABLE';
      let trendDesc = 'No significant change';
      
      if (trend.direction === 'rising') {
        trendColor = 'var(--amber)';
        trendText = 'RISING';
        trendDesc = `+${trend.slope}ms/s`;
      } else if (trend.direction === 'critical') {
        trendColor = 'var(--red)';
        trendText = 'CRITICAL';
        trendDesc = `+${trend.slope}ms/s ⚠️`;
      } else if (trend.direction === 'falling') {
        trendColor = 'var(--green)';
        trendText = 'IMPROVING';
        trendDesc = `${trend.slope}ms/s`;
      }
      
      trendEl.textContent = trendText;
      trendEl.style.color = trendColor;
      trendIndEl.textContent = trendDesc;
    }
    
    // Update risk score
    const riskEl = document.getElementById('risk-score');
    const riskLevelEl = document.getElementById('risk-level');
    if (riskEl && riskLevelEl) {
      let riskColor = 'var(--green)';
      let riskLevel = 'Low';
      
      if (risk >= 70) {
        riskColor = 'var(--red)';
        riskLevel = 'Critical';
      } else if (risk >= 40) {
        riskColor = 'var(--amber)';
        riskLevel = 'Moderate';
      }
      
      riskEl.textContent = `${risk}%`;
      riskEl.style.color = riskColor;
      riskLevelEl.textContent = riskLevel;
    }
    
    // Update WS health
    const wsHealthEl = document.getElementById('ws-health');
    const wsErrorsEl = document.getElementById('ws-errors');
    if (wsHealthEl && wsErrorsEl) {
      const wsErrorRate = this.wsErrors.length;
      let wsColor = 'var(--green)';
      let wsStatus = 'GOOD';
      
      if (wsErrorRate >= this.thresholds.wsErrorRate) {
        wsColor = 'var(--red)';
        wsStatus = 'DEGRADED';
      } else if (wsErrorRate >= 2) {
        wsColor = 'var(--amber)';
        wsStatus = 'FAIR';
      }
      
      wsHealthEl.textContent = wsStatus;
      wsHealthEl.style.color = wsColor;
      wsErrorsEl.textContent = `${wsErrorRate} errors/min`;
    }
    
    // Update time to issue
    const timeToIssueEl = document.getElementById('time-to-issue');
    if (timeToIssueEl) {
      if (timeToIssue === null) {
        timeToIssueEl.textContent = '∞';
        timeToIssueEl.style.color = 'var(--blue)';
      } else {
        timeToIssueEl.textContent = `${timeToIssue}s`;
        timeToIssueEl.style.color = timeToIssue < 60 ? 'var(--red)' : 'var(--amber)';
      }
    }
    
    // Update status badge
    const statusEl = document.getElementById('prediction-status');
    if (statusEl) {
      if (risk >= 70) {
        statusEl.textContent = 'CRITICAL';
        statusEl.style.background = 'var(--red-glow)';
        statusEl.style.color = 'var(--red)';
      } else if (risk >= 40) {
        statusEl.textContent = 'WARNING';
        statusEl.style.background = 'var(--amber-glow)';
        statusEl.style.color = 'var(--amber)';
      } else {
        statusEl.textContent = 'HEALTHY';
        statusEl.style.background = 'var(--green-glow)';
        statusEl.style.color = 'var(--green)';
      }
    }
    
    // Update warning banner
    const warningEl = document.getElementById('starvation-warning');
    const warningMsgEl = document.getElementById('warning-message');
    if (warningEl && warningMsgEl) {
      if (risk >= 70) {
        warningEl.style.display = 'block';
        warningMsgEl.textContent = `Risk score: ${risk}%. ${insights.join(' • ')}`;
      } else {
        warningEl.style.display = 'none';
      }
    }
    
    // Update insights list
    const insightsListEl = document.getElementById('insights-list');
    if (insightsListEl) {
      insightsListEl.innerHTML = insights
        .slice(-5) // Last 5 insights
        .map(i => `<div style="margin-bottom:4px;">• ${i}</div>`)
        .join('');
    }
    
    // Update chart
    this.drawChart();
  },
  
  // Draw trend chart
  drawChart() {
    if (!this.chart || !this.chart.ctx || this.history.length < 2) return;
    
    const { canvas, ctx } = this.chart;
    const width = canvas.width = canvas.offsetWidth * window.devicePixelRatio;
    const height = canvas.height = canvas.offsetHeight * window.devicePixelRatio;
    
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    const displayWidth = canvas.offsetWidth;
    const displayHeight = canvas.offsetHeight;
    
    // Clear
    ctx.clearRect(0, 0, displayWidth, displayHeight);
    
    // Get data
    const data = this.history.slice(-60); // Last 60 seconds
    if (data.length < 2) return;
    
    const maxLatency = Math.max(...data.map(s => s.latency), this.thresholds.latencyHigh);
    const minLatency = Math.min(...data.map(s => s.latency), 0);
    const range = maxLatency - minLatency || 1;
    
    // Draw threshold lines
    const criticalY = displayHeight - ((this.thresholds.latencyCritical - minLatency) / range * displayHeight);
    const highY = displayHeight - ((this.thresholds.latencyHigh - minLatency) / range * displayHeight);
    
    ctx.strokeStyle = 'rgba(255, 0, 100, 0.2)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(0, criticalY);
    ctx.lineTo(displayWidth, criticalY);
    ctx.stroke();
    
    ctx.strokeStyle = 'rgba(255, 180, 0, 0.2)';
    ctx.beginPath();
    ctx.moveTo(0, highY);
    ctx.lineTo(displayWidth, highY);
    ctx.stroke();
    ctx.setLineDash([]);
    
    // Draw latency line
    ctx.strokeStyle = 'rgba(0, 212, 255, 0.8)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    
    data.forEach((sample, i) => {
      const x = (i / (data.length - 1)) * displayWidth;
      const y = displayHeight - ((sample.latency - minLatency) / range * displayHeight);
      
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    
    ctx.stroke();
    
    // Draw gradient fill
    const gradient = ctx.createLinearGradient(0, 0, 0, displayHeight);
    gradient.addColorStop(0, 'rgba(0, 212, 255, 0.3)');
    gradient.addColorStop(1, 'rgba(0, 212, 255, 0)');
    
    ctx.fillStyle = gradient;
    ctx.beginPath();
    data.forEach((sample, i) => {
      const x = (i / (data.length - 1)) * displayWidth;
      const y = displayHeight - ((sample.latency - minLatency) / range * displayHeight);
      
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.lineTo(displayWidth, displayHeight);
    ctx.lineTo(0, displayHeight);
    ctx.closePath();
    ctx.fill();
  }
};

// Initialize on load
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => PredictiveLatency.init());
} else {
  setTimeout(() => PredictiveLatency.init(), 100);
}

// Export to window for access from main app
window.PredictiveLatency = PredictiveLatency;

console.log('[PredictiveLatency] Module loaded');
</script>

