const cmdRecentKey = 'alfie-cmdk-recent';
let cmdSelectedIdx = 0;

function getCmdRecent() {
  try { return JSON.parse(localStorage.getItem(cmdRecentKey) || '[]'); } catch { return []; }
}
function addCmdRecent(id) {
  let recent = getCmdRecent().filter(r => r !== id);
  recent.unshift(id);
  if (recent.length > 5) recent = recent.slice(0, 5);
  localStorage.setItem(cmdRecentKey, JSON.stringify(recent));
}

function cmdSearchMemory() {
  const q = $('#cmd-input').value.trim();
  if (!q) { toast('🔍 Type a query first', 'info'); return; }
  fetch('/api/knowledge?q=' + encodeURIComponent(q))
    .then(r => r.json())
    .then(d => { toast(`🔍 Found ${d.results?.length || 0} memories`, 'success'); })
    .catch(() => toast('❌ Memory search failed', 'error'));
}

function fuzzyMatch(query, text) {
  const q = query.toLowerCase();
  const t = text.toLowerCase();
  if (!q) return { match: true, score: 0, highlighted: text };
  if (t.includes(q)) return { match: true, score: 100 - t.indexOf(q), highlighted: text.replace(new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi'), '<mark>$1</mark>') };
  let qi = 0, score = 0;
  for (let i = 0; i < t.length && qi < q.length; i++) {
    if (t[i] === q[qi]) { qi++; score += (i === 0 || t[i-1] === ' ') ? 10 : 1; }
  }
  return qi === q.length ? { match: true, score, highlighted: text } : { match: false, score: 0, highlighted: text };
}

function openCommandPalette() {
  const overlay = $('#cmd-overlay');
  overlay.classList.add('visible');
  const input = $('#cmd-input');
  input.value = '';
  input.focus();
  cmdSelectedIdx = 0;
  renderCommandResults('');
}

function closeCommandPalette() {
  $('#cmd-overlay').classList.remove('visible');
}

function renderCommandResults(query) {
  const container = $('#cmd-results');
  container.innerHTML = '';

  let items;
  if (!query) {
    // Show recent, then all
    const recent = getCmdRecent();
    const recentCmds = recent.map(id => commands.find(c => c.id === id)).filter(Boolean);
    if (recentCmds.length) {
      const label = document.createElement('div');
      label.className = 'cmd-section-label';
      label.textContent = 'Recent';
      container.appendChild(label);
      recentCmds.forEach(cmd => container.appendChild(makeCmdItem(cmd, false)));
      const label2 = document.createElement('div');
      label2.className = 'cmd-section-label';
      label2.textContent = 'All Commands';
      container.appendChild(label2);
    }
    items = commands;
  } else {
    items = commands
      .map(cmd => ({ cmd, ...fuzzyMatch(query, cmd.name + ' ' + cmd.desc) }))
      .filter(r => r.match)
      .sort((a, b) => b.score - a.score)
      .map(r => ({ ...r.cmd, _highlighted: fuzzyMatch(query, r.cmd.name).highlighted }));
  }

  if (items.length === 0) {
    container.innerHTML = '<div class="cmd-empty">No matching commands</div>';
    return;
  }

  items.forEach(cmd => container.appendChild(makeCmdItem(cmd, !!query)));

  // Select first actionable item
  const allItems = container.querySelectorAll('.cmd-item');
  cmdSelectedIdx = 0;
  if (allItems[0]) allItems[0].classList.add('selected');
}

function makeCmdItem(cmd, useHighlight) {
  const el = document.createElement('div');
  el.className = 'cmd-item';
  el.dataset.cmdId = cmd.id;
  const catClass = cmd.cat || 'nav';
  el.innerHTML = `
    <div class="cmd-icon ${catClass}">${cmd.icon}</div>
    <div class="cmd-text">
      <div class="cmd-name">${useHighlight && cmd._highlighted ? cmd._highlighted : cmd.name}</div>
      <div class="cmd-desc">${cmd.desc}</div>
    </div>
    ${cmd.key ? `<kbd class="cmd-key">${cmd.key}</kbd>` : ''}
  `;
  el.addEventListener('click', () => executeCmd(cmd));
  el.addEventListener('mouseenter', () => {
    const all = el.parentElement.querySelectorAll('.cmd-item');
    all.forEach((item, i) => { item.classList.remove('selected'); if (item === el) cmdSelectedIdx = i; });
    el.classList.add('selected');
  });
  return el;
}

function executeCmd(cmd) {
  addCmdRecent(cmd.id);
  closeCommandPalette();
  cmd.action();
}

$('#cmd-input').addEventListener('input', (e) => {
  cmdSelectedIdx = 0;
  renderCommandResults(e.target.value.trim());
});

$('#cmd-input').addEventListener('keydown', (e) => {
  const items = $('#cmd-results').querySelectorAll('.cmd-item');
  if (e.key === 'Escape') {
    e.preventDefault();
    closeCommandPalette();
  } else if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (items.length) {
      items[cmdSelectedIdx]?.classList.remove('selected');
      cmdSelectedIdx = (cmdSelectedIdx + 1) % items.length;
      items[cmdSelectedIdx]?.classList.add('selected');
      items[cmdSelectedIdx]?.scrollIntoView({ block: 'nearest' });
    }
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (items.length) {
      items[cmdSelectedIdx]?.classList.remove('selected');
      cmdSelectedIdx = (cmdSelectedIdx - 1 + items.length) % items.length;
      items[cmdSelectedIdx]?.classList.add('selected');
      items[cmdSelectedIdx]?.scrollIntoView({ block: 'nearest' });
    }
  } else if (e.key === 'Enter') {
    e.preventDefault();
    const selected = items[cmdSelectedIdx];
    if (selected) selected.click();
  }
});

// ─── Voice Chat ───
const voiceState = {
  recognition: null,
  isRecording: false,
};

function initVoiceChat() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    toast('⚠️ Speech recognition not supported', 'error');
    $('#mic-btn').disabled = true;
    return;
  }

  voiceState.recognition = new SpeechRecognition();
  voiceState.recognition.continuous = false;
  voiceState.recognition.interimResults = false;
  voiceState.recognition.lang = 'en-US';

  voiceState.recognition.onstart = () => {
    voiceState.isRecording = true;
    $('#mic-btn').classList.add('recording');
    $('#voice-status').textContent = '🎤 Listening...';
    $('#voice-status').classList.add('listening');
  };

  voiceState.recognition.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    $('#chat-input').value = transcript;
    sendMessage(transcript);
  };

  voiceState.recognition.onerror = (event) => {
    console.error('Speech recognition error:', event.error);
    stopRecording();
    if (event.error !== 'no-speech') {
      toast('❌ Speech error: ' + event.error, 'error');
    }
  };

  voiceState.recognition.onend = () => {
    stopRecording();
  };
}

function startRecording() {
  if (!voiceState.recognition) return;
  try {
    voiceState.recognition.start();
  } catch (e) {
    console.error('Failed to start recording:', e);
  }
}

function stopRecording() {
  voiceState.isRecording = false;
  $('#mic-btn').classList.remove('recording');
  $('#voice-status').textContent = '';
  $('#voice-status').classList.remove('listening');
}

function sendMessage(text) {
  if (!text || !text.trim()) return;
  
  if (state.ws && state.ws.readyState === WebSocket.OPEN) {
    state.ws.send(JSON.stringify({
      type: 'voice_message',
      text: text.trim(),
      from: 'user',
    }));
  }

  $('#chat-input').value = '';
  addStreamMessage('user', text, Date.now());
}

// ─── TTS System ───
function queueTTS(text, messageElement) {
  if (!text || text.trim().length < 10) return;
  
  state.ttsQueue.push({
    text: text.trim(),
    messageElement,
    voiceId: $('#voice-selector').value,
  });
  
  if (!state.ttsPlaying) {
    playNextTTS();
  }
}

async function playNextTTS() {
  if (state.ttsQueue.length === 0) {
    state.ttsPlaying = false;
    state.currentTTS = null;
    $('#tts-stop').style.display = 'none';
    $('#voice-status').textContent = '';
    $('#voice-status').classList.remove('speaking');
    $$('.stream-msg.tts-active').forEach(el => el.classList.remove('tts-active'));
    $$('.msg-tts-btn.playing').forEach(btn => btn.classList.remove('playing'));
    return;
  }
  
  const item = state.ttsQueue.shift();
  state.ttsPlaying = true;
  state.currentTTS = item;
  
  $('#tts-stop').style.display = 'flex';
  
  if (item.messageElement) {
    item.messageElement.classList.add('tts-active');
    const btn = item.messageElement.querySelector('.msg-tts-btn');
    if (btn) btn.classList.add('playing');
  }
  
  try {
    $('#voice-status').textContent = '🔊 Speaking...';
    $('#voice-status').classList.add('speaking');

    const response = await fetch('/api/tts', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: item.text, voiceId: item.voiceId }),
    });

    if (!response.ok) throw new Error('TTS request failed');

    const contentType = response.headers.get('content-type');
    
    if (contentType && contentType.includes('application/json')) {
      const data = await response.json();
      if (data.fallback) {
        const utterance = new SpeechSynthesisUtterance(item.text);
        utterance.onend = () => {
          if (item.messageElement) {
            item.messageElement.classList.remove('tts-active');
            const btn = item.messageElement.querySelector('.msg-tts-btn');
            if (btn) btn.classList.remove('playing');
          }
          playNextTTS();
        };
        window.speechSynthesis.speak(utterance);
        return;
      }
    }

    const audioBlob = await response.blob();
    const audioUrl = URL.createObjectURL(audioBlob);
    const audio = new Audio(audioUrl);
    
    state.currentTTSAudio = audio;
    
    audio.onended = () => {
      URL.revokeObjectURL(audioUrl);
      if (item.messageElement) {
        item.messageElement.classList.remove('tts-active');
        const btn = item.messageElement.querySelector('.msg-tts-btn');
        if (btn) btn.classList.remove('playing');
      }
      playNextTTS();
    };

    audio.onerror = () => {
      URL.revokeObjectURL(audioUrl);
      if (item.messageElement) {
        item.messageElement.classList.remove('tts-active');
        const btn = item.messageElement.querySelector('.msg-tts-btn');
        if (btn) btn.classList.remove('playing');
      }
      toast('❌ Audio playback failed', 'error');
      playNextTTS();
    };

    audio.volume = 1.0;
    const playPromise = audio.play();
    if (playPromise) {
      playPromise.catch(err => {
        console.error('Audio play blocked:', err);
        const utterance = new SpeechSynthesisUtterance(item.text);
        utterance.onend = () => playNextTTS();
        window.speechSynthesis.speak(utterance);
        URL.revokeObjectURL(audioUrl);
      });
    }
  } catch (e) {
    console.error('TTS error:', e);
    if (item.messageElement) {
      item.messageElement.classList.remove('tts-active');
      const btn = item.messageElement.querySelector('.msg-tts-btn');
      if (btn) btn.classList.remove('playing');
    }
    toast('❌ TTS failed', 'error');
    playNextTTS();
  }
}

function stopTTS() {
  if (state.currentTTSAudio) {
    state.currentTTSAudio.pause();
    state.currentTTSAudio.currentTime = 0;
    state.currentTTSAudio = null;
  }
  
  if (window.speechSynthesis) {
    window.speechSynthesis.cancel();
  }
  
  state.ttsQueue = [];
  state.ttsPlaying = false;
  state.currentTTS = null;
  
  $('#tts-stop').style.display = 'none';
  $('#voice-status').textContent = '';
  $('#voice-status').classList.remove('speaking');
  
  $$('.stream-msg.tts-active').forEach(el => el.classList.remove('tts-active'));
  $$('.msg-tts-btn.playing').forEach(btn => btn.classList.remove('playing'));
  
  toast('⏹️ TTS stopped', 'info', 2000);
}

