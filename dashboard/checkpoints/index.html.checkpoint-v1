// ─── System Vitals (Sparklines + Network/Disk/CPU/RAM) ───
const _vitalsHistory = { cpu: [], ram: [], netRx: [], netTx: [], diskR: [], diskW: [] };
const SPARKLINE_MAX = 60; // 60 data points (~2 min at 2s interval)

function drawSparkline(svgId, data, color, maxVal) {
  const svg = document.getElementById(svgId);
  if (!svg || data.length < 2) return;
  const w = svg.getBoundingClientRect().width || 100;
  const h = 20;
  const max = maxVal || Math.max(...data, 1);
  const step = w / (SPARKLINE_MAX - 1);
  const points = data.map((v, i) => `${i * step},${h - (v / max) * (h - 2) - 1}`).join(' ');
  const fillPoints = `0,${h} ${points} ${(data.length - 1) * step},${h}`;
  svg.innerHTML = `
    <defs><linearGradient id="g-${svgId}" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="${color}" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="${color}" stop-opacity="0.02"/>
    </linearGradient></defs>
    <polygon points="${fillPoints}" fill="url(#g-${svgId})"/>
    <polyline points="${points}" fill="none" stroke="${color}" stroke-width="1.2" stroke-linejoin="round"/>
  `;
}

function updateSystemVitals(sys) {
  // Network
  const netRx = sys.netRx || 0, netTx = sys.netTx || 0;
  _vitalsHistory.netRx.push(netRx); _vitalsHistory.netTx.push(netTx);
  if (_vitalsHistory.netRx.length > SPARKLINE_MAX) { _vitalsHistory.netRx.shift(); _vitalsHistory.netTx.shift(); }
  const nrEl = document.getElementById('net-rx'); if (nrEl) nrEl.textContent = netRx > 1024 ? (netRx/1024).toFixed(1) + ' MB' : netRx.toFixed(0);
  const ntEl = document.getElementById('net-tx'); if (ntEl) ntEl.textContent = netTx > 1024 ? (netTx/1024).toFixed(1) + ' MB' : netTx.toFixed(0);
  // Combine rx+tx for sparkline
  const netCombined = _vitalsHistory.netRx.map((r, i) => r + (_vitalsHistory.netTx[i] || 0));
  drawSparkline('net-sparkline', netCombined, '#22d3ee');

  // Disk I/O
  const diskR = sys.diskReadMBs || 0, diskW = sys.diskWriteMBs || 0;
  _vitalsHistory.diskR.push(diskR); _vitalsHistory.diskW.push(diskW);
  if (_vitalsHistory.diskR.length > SPARKLINE_MAX) { _vitalsHistory.diskR.shift(); _vitalsHistory.diskW.shift(); }
  const drEl = document.getElementById('disk-read'); if (drEl) drEl.textContent = diskR.toFixed(1);
  const dwEl = document.getElementById('disk-write'); if (dwEl) dwEl.textContent = diskW.toFixed(1);
  const diskCombined = _vitalsHistory.diskR.map((r, i) => r + (_vitalsHistory.diskW[i] || 0));
  drawSparkline('disk-sparkline', diskCombined, '#f59e0b');

  // CPU
  const cpuPct = sys.cpu || 0;
  _vitalsHistory.cpu.push(cpuPct);
  if (_vitalsHistory.cpu.length > SPARKLINE_MAX) _vitalsHistory.cpu.shift();
  const cfEl = document.getElementById('cpu-freq'); if (cfEl && sys.cpuFreqAvg) cfEl.textContent = sys.cpuFreqAvg;
  const ccEl = document.getElementById('cpu-cores'); if (ccEl && sys.cpuCores) ccEl.textContent = sys.cpuCores + 'c';
  drawSparkline('cpu-sparkline', _vitalsHistory.cpu, '#f97316', 100);

  // RAM
  const ramPct = sys.ram || 0;
  _vitalsHistory.ram.push(ramPct);
  if (_vitalsHistory.ram.length > SPARKLINE_MAX) _vitalsHistory.ram.shift();
  const rdEl = document.getElementById('ram-detail');
  if (rdEl && sys.memUsed && sys.memTotal) {
    const used = (sys.memUsed / 1073741824).toFixed(1);
    const total = (sys.memTotal / 1073741824).toFixed(0);
    rdEl.textContent = `${used}/${total}`;
  }
  drawSparkline('ram-sparkline', _vitalsHistory.ram, '#22d3ee', 100);

  // Disk capacity bar
  const diskBar = document.getElementById('disk-bar');
  const diskDetail = document.getElementById('disk-detail');
  if (diskBar && sys.disk) diskBar.style.width = sys.disk + '%';
  if (diskBar && sys.disk > 80) diskBar.style.background = 'var(--red)';
  else if (diskBar && sys.disk > 60) diskBar.style.background = 'var(--amber)';
  if (diskDetail && sys.diskTotal && sys.diskUsed) {
    const used = (sys.diskUsed / 1099511627776).toFixed(2);
    const total = (sys.diskTotal / 1099511627776).toFixed(2);
    diskDetail.textContent = `${used}/${total} TB (${sys.disk}%)`;
  }
}

