  border-radius: 4px;
  margin-bottom: 3px;
  transition: all 0.2s;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 0.6rem;
}
.top-process-row:hover {
  background: oklch(0.12 0.015 270 / 0.4);
  transform: translateX(2px);
}
.top-process-pid {
  color: var(--text-3);
}
.top-process-user {
