// ─── Initialize ───
function initApp() {
  const hash = window.location.hash.slice(1);
  state.secret = hash || 'rasputin-neural-2026';
  $('#auth-screen').classList.add('hidden');
  $('#app').classList.add('visible');
  connect();

  initDemoMode();
  initVoiceChat();
  initChat();
  startDataRefresh();
  
  setTimeout(() => {
    if (state.authenticated) {
      fetchAgents();
    }
  }, 1000);

  // ─── Keyboard Shortcuts Handler ───
  document.addEventListener('keyboard-shortcut', (e) => {
    const { action } = e.detail;
    
    switch(action) {
      case 'sendMessage':
        const chatInput = $('#chat-input');
        if (chatInput && chatInput.value.trim()) {
          handleSendChat();
        }
        break;
        
      case 'toggleVoice':
        if (typeof toggleVoiceInput === 'function') {
          toggleVoiceInput();
        }
        break;
        
      case 'newConversation':
        if (confirm('Start new conversation? Current chat will be cleared.')) {
          state.messages = [];
          renderMessages();
        }
        break;
        
      case 'clearChat':
        if (confirm('Clear all messages?')) {
          state.messages = [];
          renderMessages();
        }
        break;
    }
  });
  
  console.log('⌨️ Chat page keyboard shortcuts registered');
}
// Run immediately if DOM ready, otherwise wait
if (document.readyState === 'complete' || document.readyState === 'interactive') {
  initApp();
} else {
  window.addEventListener('load', initApp);
}

