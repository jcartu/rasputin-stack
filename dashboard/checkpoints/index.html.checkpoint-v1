<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>🧠 Rasputin Neural Dashboard v4</title>

<!-- PWA Meta Tags -->
<meta name="theme-color" content="#0a0a0f">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
<link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png">
<link rel="apple-touch-icon" href="/icon-192.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/d3@7.8.5/dist/d3.min.js"></script>
<style>
/* ════════════════════════════════════════════════════════════════════════
   RASPUTIN NEURAL DASHBOARD V4 — 2026 VISUAL OVERHAUL
   Bloomberg Terminal aesthetic • WebGL particles • Glassmorphism 2.0
   Dense information display • oklch colors • Glow effects • Micro-animations
   ════════════════════════════════════════════════════════════════════════ */

* { margin:0; padding:0; box-sizing:border-box; }

:root {
  color-scheme: dark;
  
  /* OKLCH Colors - Perceptually uniform, vibrant */
  --void: oklch(0.06 0.01 270);
  --base: oklch(0.08 0.015 265);
  --surface: oklch(0.11 0.02 270);
  --elevated: oklch(0.15 0.025 270);
  --raised: oklch(0.19 0.025 265);
  
  --text-1: oklch(0.98 0.005 270);
  --text-2: oklch(0.72 0.012 270);
  --text-3: oklch(0.48 0.018 270);
  --text-ghost: oklch(0.30 0.015 270);
  
  --purple: oklch(0.68 0.30 290);
  --purple-glow: oklch(0.68 0.30 290 / 0.5);
  --cyan: oklch(0.78 0.22 195);
  --cyan-glow: oklch(0.78 0.22 195 / 0.5);
  --green: oklch(0.75 0.24 145);
  --green-glow: oklch(0.75 0.24 145 / 0.5);
  --amber: oklch(0.85 0.20 85);
  --amber-glow: oklch(0.85 0.20 85 / 0.5);
  --red: oklch(0.65 0.29 25);
  --red-glow: oklch(0.65 0.29 25 / 0.5);
  --pink: oklch(0.72 0.26 340);
  --orange: oklch(0.77 0.21 50);
  --blue: oklch(0.72 0.20 240);
  
  --glass: oklch(0.10 0.015 270 / 0.25);
  --glass-border: oklch(0.38 0.04 270 / 0.15);
  --glass-strong: oklch(0.14 0.02 270 / 0.35);
  
  --font-display: 'Space Grotesk', system-ui, -apple-system, sans-serif;
  --font-body: 'Geist', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  
  --radius: 14px;
  --radius-sm: 8px;
  --radius-lg: 18px;
  
  --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --spring-smooth: cubic-bezier(0.22, 1, 0.36, 1);
  --snap: cubic-bezier(0.16, 1, 0.3, 1);
}

html { font-size: 15px; }
body {
  font-family: var(--font-body);
  background: var(--void);
  color: var(--text-1);
  overflow: hidden;
  height: 100dvh;
  width: 100vw;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

::selection {
  background: var(--purple-glow);
  color: var(--text-1);
}

::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: oklch(0.28 0.02 270); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: oklch(0.38 0.03 270); }

button {
  cursor: pointer;
  border: none;
  background: none;
  font: inherit;
  color: inherit;
}

/* ═══ PARTICLE CANVAS — MAKE IT VISIBLE ═══ */
#particle-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  opacity: 0.85;
  pointer-events: none;
}

/* ═══ AURORA BACKGROUND ═══ */
.aurora-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  background: 
    radial-gradient(ellipse 80% 50% at 15% 20%, oklch(0.50 0.28 290 / 0.12) 0%, transparent 50%),
    radial-gradient(ellipse 70% 60% at 85% 25%, oklch(0.55 0.26 320 / 0.10) 0%, transparent 50%),
    radial-gradient(ellipse 90% 50% at 50% 90%, oklch(0.60 0.20 195 / 0.08) 0%, transparent 50%),
    var(--void);
  animation: aurora-shift 25s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes aurora-shift {
  0% { filter: hue-rotate(0deg) brightness(1); }
  50% { filter: hue-rotate(15deg) brightness(1.05); }
  100% { filter: hue-rotate(-10deg) brightness(0.98); }
}

/* ═══ AUTH SCREEN ═══ */
#auth-screen {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--void);
  transition: opacity 0.6s var(--snap), visibility 0.6s;
}
#auth-screen.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.auth-box {
  text-align: center;
  z-index: 1;
  animation: auth-float 3s ease-in-out infinite;
}
@keyframes auth-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.auth-logo {
  font-size: 5rem;
  margin-bottom: 1.5rem;
  filter: drop-shadow(0 0 30px var(--purple-glow));
}

.auth-title {
  font-family: var(--font-display);
  font-size: 3.5rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--purple), var(--cyan), var(--pink));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 3rem;
  letter-spacing: -2px;
}

.auth-subtitle {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  color: var(--text-3);
  margin-bottom: 2rem;
  letter-spacing: 2px;
}

.auth-input-wrap {
  position: relative;
  width: 380px;
  margin: 0 auto 2rem;
}
.auth-input-wrap input {
  width: 100%;
  padding: 18px 24px;
  background: var(--glass-strong);
  backdrop-filter: blur(8px) saturate(150%);
  border: 1.5px solid var(--glass-border);
  border-radius: var(--radius);
  font-family: var(--font-mono);
  font-size: 1.1rem;
  letter-spacing: 3px;
  color: var(--text-1);
  transition: all 0.3s var(--spring-smooth);
}
.auth-input-wrap input:focus {
  outline: none;
  border-color: var(--purple);
  box-shadow: 0 0 40px var(--purple-glow), inset 0 1px 0 oklch(1 0 0 / 0.1);
  transform: translateY(-2px);
}
.auth-input-wrap input::placeholder {
  color: var(--text-ghost);
  letter-spacing: 1px;
}

.auth-btn {
  padding: 16px 48px;
  background: linear-gradient(135deg, var(--purple), oklch(0.55 0.32 285));
  border-radius: var(--radius);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: all 0.2s var(--spring);
  box-shadow: 0 8px 32px var(--purple-glow);
}
.auth-btn:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 12px 48px var(--purple-glow);
}
.auth-btn:active {
  transform: translateY(-1px) scale(0.98);
  transition-duration: 80ms;
}

.auth-error {
  color: var(--red);
  font-size: 0.95rem;
  margin-top: 1.5rem;
  min-height: 1.5em;
  font-family: var(--font-mono);
}

.auth-footer {
  margin-top: 4rem;
  font-size: 0.75rem;
  color: var(--text-ghost);
  font-family: var(--font-mono);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.encrypt-icon {
  font-size: 1rem;
  color: var(--green);
  animation: lock-pulse 2s ease-in-out infinite;
}
@keyframes lock-pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ═══ MAIN APP ═══ */
#app {
  display: none;
  height: 100dvh;
  width: 100vw;
  position: relative;
  z-index: 1;
}
#app.visible {
  display: flex;
  flex-direction: column;
  animation: app-fadein 0.8s var(--snap);
}
@keyframes app-fadein {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ═══ TOP BAR ═══ */
.topbar {
  height: 60px;
  background: oklch(0.08 0.01 270 / 0.2);
  backdrop-filter: blur(10px) saturate(140%);
  border-bottom: 1px solid var(--glass-border);
  padding: 0 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-shrink: 0;
  z-index: 100;
  box-shadow: 0 1px 0 oklch(1 0 0 / 0.02) inset, 0 4px 24px oklch(0 0 0 / 0.3);
}

.topbar-logo {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.3rem;
  letter-spacing: -0.5px;
  display: flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, var(--purple), var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.topbar-logo .emoji {
  font-size: 1.8rem;
  filter: drop-shadow(0 0 12px var(--purple-glow));
  animation: logo-pulse 4s ease-in-out infinite;
}
@keyframes logo-pulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 12px var(--purple-glow)); }
  50% { transform: scale(1.08); filter: drop-shadow(0 0 20px var(--purple-glow)); }
}

.topbar-divider {
  width: 1px;
  height: 28px;
  background: var(--glass-border);
}

.model-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  background: var(--glass);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: 24px;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 600;
}
.model-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--purple);
  box-shadow: 0 0 12px var(--purple-glow);
  animation: dot-pulse 2s ease-in-out infinite;
}
@keyframes dot-pulse {
  0%, 100% { box-shadow: 0 0 8px var(--purple-glow); }
  50% { box-shadow: 0 0 20px var(--purple-glow); }
}

.conn-status {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8rem;
  color: var(--text-3);
  font-family: var(--font-mono);
}
.conn-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 12px var(--green-glow);
  transition: all 0.3s;
}
.conn-dot.disconnected {
  background: var(--red);
  box-shadow: 0 0 12px var(--red-glow);
}
.conn-dot.reconnecting {
  background: var(--amber);
  box-shadow: 0 0 12px var(--amber-glow);
  animation: blink 1s step-end infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.encrypt-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.75rem;
  color: var(--green);
  font-family: var(--font-mono);
  font-weight: 600;
}
.encrypt-icon-sm {
  font-size: 1rem;
  animation: lock-pulse 2s ease-in-out infinite;
}

.topbar-stats {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 0.75rem;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 6px;
}
.stat-label {
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.stat-value {
  color: var(--text-1);
  font-weight: 700;
  text-shadow: 0 0 8px currentColor;
}

.topbar-actions {
  display: flex;
  gap: 6px;
}

/* ═══ NAV PILLS ═══ */
.nav-pill {
  position: relative;
  color: oklch(0.65 0.06 280);
  font-size: 11.5px;
  font-weight: 500;
  text-decoration: none;
  padding: 5px 12px;
  border: 1px solid oklch(0.25 0.02 280 / 0.6);
  border-radius: 20px;
  white-space: nowrap;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  background: oklch(0.12 0.01 280 / 0.4);
  backdrop-filter: blur(4px);
  cursor: pointer;
  font-family: var(--font);
  letter-spacing: 0.2px;
}
.nav-pill:hover {
  color: oklch(0.90 0.15 195);
  border-color: oklch(0.60 0.15 195 / 0.6);
  background: oklch(0.18 0.04 195 / 0.3);
  box-shadow: 0 0 12px oklch(0.60 0.15 195 / 0.15), inset 0 0 8px oklch(0.60 0.15 195 / 0.05);
  transform: translateY(-1px);
}
.nav-pill:active {
  transform: translateY(0);
  box-shadow: 0 0 6px oklch(0.60 0.15 195 / 0.1);
}
.cmd-k-pill {
  color: oklch(0.70 0.12 85);
  border-color: oklch(0.30 0.06 85 / 0.5);
  background: oklch(0.14 0.03 85 / 0.3);
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
}
.cmd-k-pill:hover {
  color: oklch(0.92 0.18 85);
  border-color: oklch(0.65 0.15 85 / 0.6);
  background: oklch(0.20 0.06 85 / 0.3);
  box-shadow: 0 0 12px oklch(0.65 0.15 85 / 0.15);
}
.nav-pill[data-tooltip]:hover::after {
  content: attr(data-tooltip);
  position: absolute;
  top: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%);
  background: oklch(0.10 0.02 265 / 0.95);
  border: 1px solid oklch(0.35 0.04 270 / 0.4);
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 11px;
  font-weight: 400;
  color: oklch(0.82 0.03 270);
  white-space: normal;
  width: max-content;
  max-width: 260px;
  line-height: 1.5;
  z-index: 9999;
  pointer-events: none;
  box-shadow: 0 8px 32px oklch(0 0 0 / 0.5);
  backdrop-filter: blur(12px);
  animation: tooltip-in 0.2s ease-out;
}
.nav-pill[data-tooltip]:hover::before {
  content: '';
  position: absolute;
  top: calc(100% + 4px);
  left: 50%;
  transform: translateX(-50%);
  border: 5px solid transparent;
  border-bottom-color: oklch(0.35 0.04 270 / 0.4);
  z-index: 9999;
  pointer-events: none;
  animation: tooltip-in 0.2s ease-out;
}
@keyframes tooltip-in {
  from { opacity: 0; transform: translateX(-50%) translateY(4px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.topbar-nav-links {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding: 2px 0;
}
.topbar-nav-links::-webkit-scrollbar { display: none; }

.topbar-btn {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  transition: all 0.15s var(--spring);
}
.topbar-btn:hover {
  background: var(--glass);
  transform: scale(1.08);
}
.topbar-btn:active {
  transform: scale(0.95);
  transition-duration: 60ms;
}

/* ═══ NEW BENTO GRID LAYOUT — ONE VIEWPORT, NO SCROLLING ═══ */
.bento-container {
  flex: 1;
  overflow: hidden;
  padding: 10px;
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  grid-template-rows: repeat(8, 1fr);
  gap: 10px;
  height: calc(100vh - 60px - 70px - 28px);
}

.bento-card {
  background: oklch(0.08 0.015 270 / 0.22);
  backdrop-filter: blur(8px) saturate(150%);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  padding: 12px;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 0;
  min-width: 0;
  transition: all 0.3s var(--spring-smooth);
  box-shadow: 
    0 2px 0 oklch(1 0 0 / 0.02) inset,
    0 4px 16px oklch(0 0 0 / 0.25),
    0 0 0 1px oklch(0.38 0.04 270 / 0.2);
  animation: card-enter 0.6s var(--spring);
}
@keyframes card-enter {
  from { opacity: 0; transform: scale(0.95) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}
.bento-card:hover {
  border-color: oklch(0.42 0.06 270 / 0.5);
  box-shadow: 
    0 2px 0 oklch(1 0 0 / 0.04) inset,
    0 8px 32px oklch(0 0 0 / 0.35),
    0 0 0 1px var(--purple-glow);
  transform: translateY(-2px);
}

.card-title {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-2);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
  text-shadow: 0 0 8px var(--purple-glow);
}
.card-icon {
  font-size: 1.1rem;
  filter: drop-shadow(0 0 10px currentColor);
}

/* ═══ NEURAL STREAM — LEFT, TALL ═══ */
#stream-card {
  grid-column: 1 / 5;
  grid-row: 1 / 5;
  display: flex;
  flex-direction: column;
}
.stream-scroll {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-right: 4px;
}

.stream-msg {
  position: relative;
  padding: 8px 12px 22px 12px;
  border-radius: var(--radius-sm);
  border-left: 3px solid transparent;
  font-size: 0.85rem;
  line-height: 1.5;
  transition: all 0.2s;
  animation: msg-slide 0.4s var(--spring);
  background: oklch(0.08 0.015 270 / 0.2);
}
@keyframes msg-slide {
  from { opacity: 0; transform: translateX(20px); }
  to { opacity: 1; transform: translateX(0); }
}
.stream-msg:hover {
  background: oklch(0.13 0.02 270 / 0.25);
}

.stream-msg.role-ai {
  border-left-color: var(--purple);
  background: oklch(0.68 0.30 290 / 0.05);
}
.stream-msg.role-user {
  border-left-color: var(--amber);
  background: oklch(0.85 0.20 85 / 0.05);
}
.stream-msg.role-tool {
  border-left-color: var(--cyan);
  background: oklch(0.78 0.22 195 / 0.05);
}

.stream-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
  font-size: 0.65rem;
}
.stream-time {
  position: absolute;
  bottom: 4px;
  right: 8px;
  color: var(--text-3);
  font-family: var(--font-mono);
  font-size: 0.6rem;
  opacity: 0;
  transition: opacity 0.2s;
}
.stream-msg:hover .stream-time {
  opacity: 1;
}
.stream-role {
  padding: 2px 6px;
  border-radius: 4px;
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}
.role-ai .stream-role {
  background: oklch(0.68 0.30 290 / 0.2);
  color: var(--purple);
  text-shadow: 0 0 8px var(--purple-glow);
}
.role-user .stream-role {
  background: oklch(0.85 0.20 85 / 0.2);
  color: var(--amber);
  text-shadow: 0 0 8px var(--amber-glow);
}
.role-tool .stream-role {
  background: oklch(0.78 0.22 195 / 0.2);
  color: var(--cyan);
  text-shadow: 0 0 8px var(--cyan-glow);
}

.stream-text {
  color: var(--text-1);
  white-space: pre-wrap;
  word-break: break-word;
}

.stream-cursor {
  display: inline-block;
  width: 2px;
  height: 1em;
  background: var(--purple);
  margin-left: 2px;
  vertical-align: text-bottom;
  animation: blink 1s step-end infinite;
  box-shadow: 0 0 8px var(--purple-glow);
}

/* ═══ TOOL CALL CARD ═══ */
.tool-call-card {
  position: relative;
  margin: 4px 0;
  border-radius: var(--radius-sm);
  border: 1px solid oklch(0.78 0.22 195 / 0.2);
  border-left: 3px solid var(--cyan);
  background: oklch(0.78 0.22 195 / 0.05);
  overflow: hidden;
  animation: tool-expand 0.3s ease-out;
}
.tool-call-card:empty,
.tool-call-card:not(:has(.tool-name:not(:empty))) {
  display: none;
}
@keyframes tool-expand {
  from { max-height: 0; opacity: 0; transform: scaleY(0.8); }
  to { max-height: 300px; opacity: 1; transform: scaleY(1); }
}

.tool-header {
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 0.75rem;
}
.tool-spinner {
  width: 14px;
  height: 14px;
  border: 2px solid oklch(0.78 0.22 195 / 0.2);
  border-top-color: var(--cyan);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.tool-check {
  display: none;
  width: 14px;
  height: 14px;
}
.tool-check svg {
  width: 14px;
  height: 14px;
}
.tool-check svg path {
  stroke: var(--green);
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
  fill: none;
  stroke-dasharray: 24;
  stroke-dashoffset: 24;
  animation: check-draw 0.6s ease forwards;
}
@keyframes check-draw {
  to { stroke-dashoffset: 0; }
}
.tool-call-card.complete .tool-spinner { display: none; }
.tool-call-card.complete .tool-check { display: block; }

.tool-name {
  color: var(--cyan);
  font-weight: 700;
  text-shadow: 0 0 8px var(--cyan-glow);
}
.tool-time {
  position: absolute;
  bottom: 4px;
  right: 8px;
  color: var(--text-3);
  font-size: 0.6rem;
  opacity: 0;
  transition: opacity 0.2s;
}
.tool-call-card:hover .tool-time {
  opacity: 1;
}

.tool-input {
  padding: 0 12px 6px;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-2);
  max-height: 100px;
  overflow-y: auto;
  white-space: pre-wrap;
  word-break: break-all;
}

.tool-result {
  display: none;
  padding: 6px 12px;
  border-top: 1px solid oklch(0.78 0.22 195 / 0.15);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-2);
  max-height: 80px;
  overflow-y: auto;
  animation: result-slide 0.3s ease;
}
@keyframes result-slide {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}
.tool-call-card.complete .tool-result {
  display: block;
}

/* ═══ GPU STATUS — PREMIUM REDESIGN ═══ */
#gpu-card {
  grid-column: 5 / 9;
  grid-row: 1 / 3;
}
/* ─── Thinking Stream ─── */
.thinking-card {
  background: linear-gradient(135deg, oklch(0.12 0.03 280 / 0.4), oklch(0.08 0.02 300 / 0.3));
  border: 1px solid oklch(0.6 0.15 280 / 0.3);
  border-left: 3px solid oklch(0.7 0.2 280);
  border-radius: var(--radius-sm);
  padding: 10px 12px;
  margin-bottom: 8px;
  font-size: 12px;
  line-height: 1.5;
  position: relative;
  overflow: hidden;
  animation: thinking-fade-in 0.3s ease;
}
@keyframes thinking-fade-in {
  from { opacity: 0; transform: translateY(-4px); }
  to { opacity: 1; transform: translateY(0); }
}
.thinking-card .thinking-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: oklch(0.75 0.15 280);
}
.thinking-card .thinking-icon {
  width: 14px;
  height: 14px;
  animation: thinking-pulse 1.5s ease-in-out infinite;
}
@keyframes thinking-pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
.thinking-card .thinking-text {
  color: oklch(0.7 0.05 280);
  font-family: var(--font-mono);
  font-size: 11px;
  line-height: 1.6;
  max-height: 120px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: oklch(0.4 0.1 280) transparent;
}
.thinking-card .thinking-text::-webkit-scrollbar { width: 4px; }
.thinking-card .thinking-text::-webkit-scrollbar-thumb { background: oklch(0.4 0.1 280); border-radius: 2px; }
.thinking-card .thinking-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 6px;
  font-size: 9px;
  color: oklch(0.5 0.05 280);
  font-family: var(--font-mono);
}
.thinking-card.collapsed .thinking-text { max-height: 40px; }
.thinking-card .thinking-toggle {
  cursor: pointer;
  color: oklch(0.6 0.15 280);
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.thinking-card .thinking-toggle:hover { color: oklch(0.8 0.15 280); }

.gpu-item {
  margin-bottom: 10px;
  padding: 10px;
  background: oklch(0.08 0.015 260 / 0.2);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  border-left: 3px solid var(--purple);
  box-shadow: 0 0 12px var(--purple-glow);
  transition: all 0.2s;
}
.gpu-item:hover {
  background: oklch(0.12 0.02 260 / 0.25);
  border-left-color: var(--cyan);
  box-shadow: 0 0 16px var(--cyan-glow);
  transform: translateX(2px);
}
.gpu-name {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
  text-shadow: 0 0 8px var(--purple-glow);
}
.gpu-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 10px var(--green-glow);
}
.gpu-metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
  font-size: 0.65rem;
  font-family: var(--font-mono);
}
.gpu-metric {
  padding: 4px;
  background: oklch(0.08 0.01 270 / 0.15);
  border-radius: 4px;
}
.gpu-metric-label {
  color: var(--text-3);
  font-size: 0.55rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 2px;
}
.gpu-metric-value {
  color: var(--text-1);
  font-weight: 700;
  font-size: 0.85rem;
  text-shadow: 0 0 8px currentColor;
}
.gpu-bar {
  height: 3px;
  background: oklch(0.12 0.01 270 / 0.15);
  border-radius: 2px;
  overflow: hidden;
  margin-top: 3px;
}
.gpu-bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s var(--spring-smooth);
  box-shadow: 0 0 8px currentColor;
}

/* ═══ SUB-AGENTS — COMPACT ═══ */
#forecast-card, #latency-card {
  display: none !important;
}
#agents-card {
  grid-column: 9 / 13;
  grid-row: 5 / 7;
}
.agent-item {
  position: relative;
  padding: 6px 8px 18px 8px;
  background: oklch(0.08 0.015 270 / 0.2);
  border: 1px solid var(--glass-border);
  border-left: 3px solid var(--purple);
  border-radius: var(--radius-sm);
  margin-bottom: 6px;
  font-size: 0.7rem;
  transition: all 0.2s;
  box-shadow: 0 0 8px var(--purple-glow);
}
.agent-item:hover {
  background: oklch(0.13 0.02 270 / 0.3);
  transform: translateX(2px);
}
.agent-item.active {
  border-left-color: var(--green);
  box-shadow: 0 0 12px var(--green-glow);
}
.agent-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}
.agent-status-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 8px var(--green-glow);
}
.agent-label {
  font-weight: 700;
  color: var(--text-1);
  font-family: var(--font-mono);
  font-size: 0.65rem;
}
.agent-model {
  margin-left: auto;
  color: var(--text-3);
  font-size: 0.6rem;
}
.agent-task {
  color: var(--text-2);
  font-size: 0.65rem;
  margin-bottom: 3px;
  line-height: 1.2;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.agent-meta {
  display: flex;
  gap: 8px;
  font-size: 0.6rem;
  color: var(--text-3);
  font-family: var(--font-mono);
}
.agent-time {
  position: absolute;
  bottom: 3px;
  right: 6px;
  color: var(--text-3);
  font-size: 0.55rem;
  font-family: var(--font-mono);
  opacity: 0;
  transition: opacity 0.2s;
}
.agent-item:hover .agent-time {
  opacity: 1;
}

/* ═══ COST TRACKING — COMPACT ═══ */
/* cost-card removed — cost shown in header bar */
.cost-big {
  font-family: var(--font-mono);
  font-size: 2rem;
  font-weight: 800;
  color: var(--green);
  text-align: center;
  margin-bottom: 6px;
  text-shadow: 0 0 20px var(--green-glow);
  animation: cost-glow 3s ease-in-out infinite;
}
@keyframes cost-glow {
  0%, 100% { text-shadow: 0 0 15px var(--green-glow); }
  50% { text-shadow: 0 0 30px var(--green-glow); }
}
.cost-label {
  font-size: 0.65rem;
  color: var(--text-3);
  text-align: center;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* ═══ TOOL CALLS ═══ */
#tools-card {
  grid-column: 9 / 13;
  grid-row: 7 / 9;
}
/* ═══ MISSIONS PANEL ═══ */
#missions-card {
  grid-column: 9 / 13;
  grid-row: 1 / 5;
}
.mission-item {
  padding: 6px 8px;
  border-radius: 6px;
  background: oklch(0.12 0.02 270 / 0.15);
  margin-bottom: 6px;
  cursor: pointer;
  transition: all 0.2s;
  border-left: 3px solid transparent;
}
.mission-item:hover {
  background: oklch(0.16 0.03 270 / 0.2);
}
.mission-item.status-active { border-left-color: var(--green); }
.mission-item.status-done { border-left-color: var(--cyan); opacity: 0.6; }
.mission-item.status-paused { border-left-color: var(--amber); }
.mission-item.status-planned { border-left-color: var(--text-3); }
.mission-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
}
.mission-name {
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--text-1);
}
.mission-eta {
  font-size: 0.55rem;
  font-family: var(--font-mono);
  color: var(--text-3);
  white-space: nowrap;
}
.mission-desc {
  font-size: 0.6rem;
  color: var(--text-2);
  margin-top: 2px;
  line-height: 1.3;
}
.mission-progress {
  margin-top: 4px;
  height: 3px;
  background: oklch(0.15 0.02 270 / 0.15);
  border-radius: 2px;
  overflow: hidden;
}
.mission-progress-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.5s ease;
}
.mission-tasks {
  margin-top: 4px;
  display: none;
  padding-left: 8px;
}
.mission-item.expanded .mission-tasks {
  display: block;
}
.mission-task {
  font-size: 0.58rem;
  font-family: var(--font-mono);
  color: var(--text-2);
  padding: 1px 0;
  display: flex;
  gap: 4px;
}
.mission-task .task-icon {
  flex-shrink: 0;
}
.tool-feed-item {
  padding: 5px 8px;
  margin-bottom: 4px;
  background: oklch(0.08 0.015 270 / 0.2);
  border-left: 3px solid var(--cyan);
  border-radius: var(--radius-sm);
  font-size: 0.65rem;
  animation: slide-in 0.3s var(--spring);
  box-shadow: 0 0 8px var(--cyan-glow);
}
@keyframes slide-in {
  from { opacity: 0; transform: translateX(-10px); }
  to { opacity: 1; transform: translateX(0); }
}
.tool-feed-item.success {
  border-left-color: var(--green);
  opacity: 0.7;
}
.tool-feed-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 2px;
}
.tool-feed-desc {
  font-weight: 600;
  color: var(--text-1);
  flex: 1;
}
.tool-feed-time {
  color: var(--text-ghost);
  font-size: 0.55rem;
  font-family: var(--font-mono);
}
.tool-feed-status {
  font-size: 0.8rem;
}

/* ═══ RICH CHAT INTERFACE ═══ */
#chat-card {
  grid-column: 1 / 5;
  grid-row: 5 / 9;
}
#chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 8px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 0;
}
.chat-bubble {
  max-width: 85%;
  padding: 10px 14px;
  border-radius: 16px;
  font-size: 0.8rem;
  line-height: 1.5;
  word-wrap: break-word;
  position: relative;
  animation: bubble-in 0.3s var(--spring);
}
@keyframes bubble-in {
  from { opacity: 0; transform: translateY(8px) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
.chat-bubble.ai {
  align-self: flex-start;
  background: oklch(0.18 0.03 270 / 0.35);
  border: 1px solid oklch(0.68 0.20 290 / 0.2);
  border-bottom-left-radius: 4px;
  color: var(--text-1);
}
.chat-bubble.user {
  align-self: flex-end;
  background: oklch(0.25 0.08 270 / 0.35);
  border: 1px solid oklch(0.55 0.15 270 / 0.3);
  border-bottom-right-radius: 4px;
  color: var(--text-1);
}
.chat-bubble .chat-time {
  font-size: 0.55rem;
  color: var(--text-3);
  margin-top: 4px;
  text-align: right;
}
.chat-bubble .chat-media {
  max-width: 100%;
  border-radius: 8px;
  margin: 6px 0;
}
.chat-bubble .chat-file {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  background: oklch(0.12 0.02 270 / 0.2);
  border-radius: 8px;
  margin: 6px 0;
  font-size: 0.7rem;
  color: var(--cyan);
}
.chat-bubble.ai .typing-dots {
  display: inline-flex;
  gap: 3px;
}
.chat-bubble.ai .typing-dots span {
  width: 6px; height: 6px;
  background: var(--purple);
  border-radius: 50%;
  animation: typing-bounce 1.2s infinite;
}
.chat-bubble.ai .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
.chat-bubble.ai .typing-dots span:nth-child(3) { animation-delay: 0.3s; }
@keyframes typing-bounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-4px); opacity: 1; }
}

/* Chat input bar */
#chat-input-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px;
  border-top: 1px solid var(--glass-border);
  background: oklch(0.08 0.015 270 / 0.2);
  border-radius: 0 0 var(--radius) var(--radius);
}
#chat-input-bar input {
  flex: 1;
  background: oklch(0.12 0.02 270 / 0.2);
  border: 1px solid oklch(0.30 0.04 270 / 0.3);
  border-radius: 20px;
  padding: 8px 14px;
  color: var(--text-1);
  font-size: 0.8rem;
  font-family: var(--font-body);
  outline: none;
  transition: border-color 0.2s;
}
#chat-input-bar input:focus {
  border-color: var(--purple);
  box-shadow: 0 0 8px oklch(0.68 0.30 290 / 0.2);
}
#chat-input-bar button {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: none;
  background: oklch(0.15 0.03 270 / 0.2);
  color: var(--text-2);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  font-size: 1rem;
}
#chat-input-bar button:hover {
  background: var(--purple);
  color: white;
  box-shadow: 0 0 12px var(--purple-glow);
}
#chat-input-bar button.recording {
  background: oklch(0.55 0.25 25);
  animation: pulse-record 1s infinite;
}
@keyframes pulse-record {
  0%, 100% { box-shadow: 0 0 0 0 oklch(0.55 0.25 25 / 0.4); }
  50% { box-shadow: 0 0 0 8px oklch(0.55 0.25 25 / 0); }
}

/* ═══ NVTOP — GPU PROCESS MONITOR ═══ */
#nvtop-card {
  grid-column: 5 / 9;
  grid-row: 1 / 9;
}
.nvtop-gpu-card {
  margin-bottom: 8px;
  padding: 8px;
  background: oklch(0.08 0.015 270 / 0.2);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
}
.nvtop-gpu-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--text-1);
}
.nvtop-metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
  font-size: 0.65rem;
  font-family: var(--font-mono);
}
.nvtop-metric {
  padding: 4px;
  background: oklch(0.08 0.01 270 / 0.15);
  border-radius: 4px;
}
.nvtop-metric-label {
  color: var(--text-3);
  font-size: 0.55rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 2px;
}
.nvtop-metric-value {
  color: var(--text-1);
  font-weight: 700;
  font-size: 0.75rem;
  text-shadow: 0 0 8px currentColor;
}
.nvtop-metric-bar {
  height: 3px;
  background: oklch(0.12 0.01 270 / 0.15);
  border-radius: 2px;
  overflow: hidden;
  margin-top: 2px;
}
.nvtop-metric-bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s var(--spring-smooth);
  box-shadow: 0 0 6px currentColor;
}
.nvtop-process-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 4px 6px;
  background: oklch(0.08 0.01 270 / 0.15);
  border-left: 2px solid var(--cyan);
  border-radius: 4px;
  margin-bottom: 4px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  transition: all 0.2s;
}
.nvtop-process-row:hover {
  background: oklch(0.12 0.015 270 / 0.4);
