// ─── Cost Burn Rate ───
function handleTokenUsage(msg) {
  if (msg.totalCost !== undefined) {
    state.totalCost = msg.totalCost;
    
    // Track cost history for sparkline
    state.costHistory.push({ ts: msg.ts || Date.now(), cost: msg.totalCost });
    
    // Keep last 30 data points (~1 minute at 2s intervals)
    if (state.costHistory.length > 30) state.costHistory.shift();
    
    updateCostBurnRate();
  }
}

function updateCostBurnRate() {
  const container = $('#cost-rate-text');
  const svg = $('#cost-sparkline');
  if (!container || !svg) return;
  
  if (state.costHistory.length < 2) {
    container.textContent = 'Collecting data...';
    return;
  }
  
  // Calculate burn rate from last 10 minutes of data
  const now = Date.now();
  const tenMinAgo = now - (10 * 60 * 1000);
  const recentHistory = state.costHistory.filter(e => e.ts > tenMinAgo);
  
  if (recentHistory.length < 2) {
    container.textContent = 'Insufficient data';
    return;
  }
  
  const startCost = recentHistory[0].cost;
  const endCost = recentHistory[recentHistory.length - 1].cost;
  const deltaTime = (recentHistory[recentHistory.length - 1].ts - recentHistory[0].ts) / 1000 / 60 / 60; // hours
  
  if (deltaTime <= 0) {
    container.textContent = 'Calculating...';
    return;
  }
  
  const costDelta = endCost - startCost;
  const ratePerHour = costDelta / deltaTime;
  const projectedToday = ratePerHour * 24;
  
  // Color based on rate
  let rateColor = 'var(--green)';
  if (ratePerHour > 5) rateColor = 'var(--red)';
  else if (ratePerHour > 1) rateColor = 'var(--amber)';
  
  container.style.color = rateColor;
  container.textContent = `$${ratePerHour.toFixed(2)}/hr · $${projectedToday.toFixed(2)} projected today`;
  
  // Render sparkline
  renderCostSparkline(recentHistory);
}

function renderCostSparkline(history) {
  const svg = $('#cost-sparkline');
  if (!svg || history.length < 2) return;
  
  const width = svg.clientWidth || 300;
  const height = 30;
  
  const costs = history.map(e => e.cost);
  const minCost = Math.min(...costs);
  const maxCost = Math.max(...costs);
  const range = maxCost - minCost || 0.01;
  
  // Generate path points
  const points = history.map((e, i) => {
    const x = (i / (history.length - 1)) * width;
    const y = height - ((e.cost - minCost) / range * height);
    return `${x},${y}`;
  }).join(' ');
  
  // Calculate rate acceleration for color
  const firstHalfAvg = history.slice(0, Math.floor(history.length / 2)).reduce((sum, e) => sum + e.cost, 0) / Math.floor(history.length / 2);
  const secondHalfAvg = history.slice(Math.floor(history.length / 2)).reduce((sum, e) => sum + e.cost, 0) / Math.ceil(history.length / 2);
  const acceleration = secondHalfAvg - firstHalfAvg;
  
  let lineColor = 'var(--green)';
  if (acceleration > 0.05) lineColor = 'var(--red)';
  else if (acceleration > 0.01) lineColor = 'var(--amber)';
  
  svg.innerHTML = `
    <polyline 
      points="${points}" 
      fill="none" 
      stroke="${lineColor}" 
      stroke-width="2" 
      style="filter:drop-shadow(0 0 4px ${lineColor});"
    />
  `;
}

