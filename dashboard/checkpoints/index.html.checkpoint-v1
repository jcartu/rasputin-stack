// ─── Network Graph (D3.js) — ENHANCED FOR BIGGER DISPLAY ───
function initChat() {
  const messages = $('#chat-messages');
  const input = $('#chat-input2');
  const sendBtn = $('#chat-send-btn2');
  const attachBtn = $('#chat-attach-btn2');
  const voiceBtn = $('#chat-voice-btn2');
  const fileInput = $('#chat-file-input2');
  
  let isRecording = false;
  let mediaRecorder = null;
  let audioChunks = [];
  
  function addChatBubble(role, content, ts, media) {
    // Clean content
    content = (content || '').replace(/\[message_id:\s*\d+\]\s*/g, '').replace(/\[media attached:.*?\]\n?/gs, '').trim();
    if (!content && !media) return; // skip empty
    
    const bubble = document.createElement('div');
    bubble.className = `chat-bubble ${role}`;
    
    let html = '';
    if (media) {
      if (media.type === 'image') {
        html += `<img class="chat-media" src="${media.url}" alt="attached image">`;
      } else if (media.type === 'audio') {
        html += `<audio controls src="${media.url}" style="width:100%;max-height:36px;"></audio>`;
      } else if (media.type === 'file') {
        html += `<div class="chat-file">📄 ${media.name} (${media.size})</div>`;
      }
    }
    
    // Render markdown-lite: bold, code, links
    let text = (content || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    text = text.replace(/`([^`]+)`/g, '<code style="background:oklch(0.15 0.02 270/0.5);padding:1px 4px;border-radius:3px;font-size:0.75rem;">$1</code>');
    text = text.replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" style="color:var(--cyan);">$1</a>');
    text = text.replace(/\n/g, '<br>');
    html += `<div>${text}</div>`;
    
    if (ts) {
      const d = new Date(ts);
      const timeStr = d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
      html += `<div class="chat-time">${timeStr}</div>`;
    }
    
    bubble.innerHTML = html;
    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
    return bubble;
  }
  
  // Typing indicator
  let typingBubble = null;
  function showTyping() {
    if (typingBubble) return;
    typingBubble = document.createElement('div');
    typingBubble.className = 'chat-bubble ai';
    typingBubble.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
    messages.appendChild(typingBubble);
    messages.scrollTop = messages.scrollHeight;
  }
  function hideTyping() {
    if (typingBubble) { typingBubble.remove(); typingBubble = null; }
  }
  
  // Send message
  function sendMessage() {
    const text = input.value.trim();
    if (!text) return;
    addChatBubble('user', text, Date.now());
    input.value = '';
    
    // Send via WebSocket
    if (state.ws && state.ws.readyState === WebSocket.OPEN) {
      state.ws.send(JSON.stringify({ type: 'chat_message', text }));
    }
    showTyping();
  }
  
  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  
  // File attachment
  attachBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', (e) => {
    const files = Array.from(e.target.files);
    files.forEach(file => {
      const reader = new FileReader();
      reader.onload = () => {
        const mediaType = file.type.startsWith('image/') ? 'image' : 
                          file.type.startsWith('audio/') ? 'audio' : 'file';
        const sizeStr = file.size > 1e6 ? (file.size/1e6).toFixed(1)+'MB' : (file.size/1e3).toFixed(0)+'KB';
        addChatBubble('user', '', Date.now(), { 
          type: mediaType, 
          url: reader.result, 
          name: file.name, 
          size: sizeStr 
        });
        // Upload via WS
        if (state.ws && state.ws.readyState === WebSocket.OPEN) {
          state.ws.send(JSON.stringify({ type: 'chat_file', name: file.name, mime: file.type, data: reader.result }));
        }
      };
      reader.readAsDataURL(file);
    });
    fileInput.value = '';
  });
  
  // Voice recording
  voiceBtn.addEventListener('click', async () => {
    if (!isRecording) {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        mediaRecorder = new MediaRecorder(stream);
        audioChunks = [];
        mediaRecorder.ondataavailable = (e) => audioChunks.push(e.data);
        mediaRecorder.onstop = () => {
          const blob = new Blob(audioChunks, { type: 'audio/webm' });
          const url = URL.createObjectURL(blob);
          addChatBubble('user', '', Date.now(), { type: 'audio', url });
          stream.getTracks().forEach(t => t.stop());
          // Send audio via WS
          const reader = new FileReader();
          reader.onload = () => {
            if (state.ws && state.ws.readyState === WebSocket.OPEN) {
              state.ws.send(JSON.stringify({ type: 'chat_voice', data: reader.result }));
            }
          };
          reader.readAsDataURL(blob);
        };
        mediaRecorder.start();
        isRecording = true;
        voiceBtn.classList.add('recording');
        voiceBtn.textContent = '⏹️';
      } catch(e) { console.error('Mic access denied:', e); }
    } else {
      mediaRecorder.stop();
      isRecording = false;
      voiceBtn.classList.remove('recording');
      voiceBtn.textContent = '🎙️';
    }
  });
  
  // Streaming chat bubble
  let streamingBubble = null;
  let streamingTextEl = null;
  
  window.startChatStream = function(ts) {
    hideTyping();
    if (streamTimer) { clearInterval(streamTimer); streamTimer = null; }
    streamTarget = '';
    streamRevealed = 0;
    streamingBubble = document.createElement('div');
    streamingBubble.className = 'chat-bubble ai';
    streamingBubble.innerHTML = `<div class="chat-stream-text" style="color:var(--text-1);"></div><div class="typing-dots" style="margin-top:4px;"><span></span><span></span><span></span></div>`;
    streamingTextEl = streamingBubble.querySelector('.chat-stream-text');
    messages.appendChild(streamingBubble);
    messages.scrollTop = messages.scrollHeight;
  };
  
  let streamTarget = '';
  let streamRevealed = 0;
  let streamTimer = null;
  
  window.updateChatStream = function(text) {
    if (!streamingBubble || !streamingTextEl) return;
    const dots = streamingBubble.querySelector('.typing-dots');
    if (dots && text.length > 0) dots.remove();
    
    streamTarget = text || '';
    // Start reveal animation if not running
    if (!streamTimer) {
      streamTimer = setInterval(() => {
        if (streamRevealed >= streamTarget.length) {
          // Caught up — wait for more or stop
          return;
        }
        // Reveal 3-8 chars per tick for natural speed
        const chunkSize = Math.min(3 + Math.floor(Math.random() * 5), streamTarget.length - streamRevealed);
        streamRevealed += chunkSize;
        const visible = streamTarget.slice(0, streamRevealed);
        let rendered = visible.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        rendered = rendered.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
        rendered = rendered.replace(/`([^`]+)`/g, '<code style="background:oklch(0.15 0.02 270/0.5);padding:1px 4px;border-radius:3px;font-size:0.75rem;">$1</code>');
        rendered = rendered.replace(/\n/g, '<br>');
        streamingTextEl.innerHTML = rendered + '<span style="display:inline-block;width:2px;height:1em;background:var(--purple);animation:blink 0.8s infinite;vertical-align:text-bottom;margin-left:1px;"></span>';
        messages.scrollTop = messages.scrollHeight;
      }, 20); // 50fps reveal
    }
  };
  
  window.endChatStream = function() {
    if (streamTimer) { clearInterval(streamTimer); streamTimer = null; }
    if (streamingBubble && streamingTextEl) {
      const dots = streamingBubble.querySelector('.typing-dots');
      if (dots) dots.remove();
      // Show full final text
      let rendered = (streamTarget || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      rendered = rendered.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      rendered = rendered.replace(/`([^`]+)`/g, '<code style="background:oklch(0.15 0.02 270/0.5);padding:1px 4px;border-radius:3px;font-size:0.75rem;">$1</code>');
      rendered = rendered.replace(/\n/g, '<br>');
      streamingTextEl.innerHTML = rendered;
      // Add timestamp
      const timeEl = document.createElement('div');
      timeEl.className = 'chat-time';
      timeEl.textContent = new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
      streamingBubble.appendChild(timeEl);
      messages.scrollTop = messages.scrollHeight;
    }
    streamingBubble = null;
    streamingTextEl = null;
    streamTarget = '';
    streamRevealed = 0;
  };
  
  // Expose for message routing
  window.addChatMessage = function(role, text, ts, media) {
    hideTyping();
    addChatBubble(role, text, ts, media);
  };
  window.showChatTyping = showTyping;
  window.hideChatTyping = hideTyping;
}

