function handleStreamingEnd(msg) {
  if (state.streamingMsg) {
    const indicator = state.streamingMsg.querySelector('.streaming-indicator');
    if (indicator) indicator.remove();
    
    const text = (state.streamingMsg.querySelector('.stream-text')?.textContent || '').trim();
    const isChatResponse = text.length > 50 && state.lastUserMessageTime && 
      (Date.now() - state.lastUserMessageTime < 120000);
    
    // Finalize streaming chat bubble
    if (window.endChatStream) window.endChatStream();
    
    if (isChatResponse) {
      const msgEl = state.streamingMsg;
      const meta = state.streamingMsg.querySelector('.stream-meta');
