        <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/>
        <path d="M9 22h6"/>
        <path d="M10 22v-1"/>
        <path d="M14 22v-1"/>
      </svg>
      <span>Reasoning</span>
      <span style="margin-left:auto">${time}</span>
    </div>
    <div class="thinking-text">${isLong ? preview : text}</div>
    <div class="thinking-meta">
      <span>${wordCount} words${msg.model ? ' · ' + msg.model : ''}</span>
      ${isLong ? `<span class="thinking-toggle" onclick="toggleThinking('${id}')">expand ▾</span>` : ''}
    </div>
  `;
  el._fullText = text;
  el._preview = preview;
  
  container.appendChild(el);
  scrollToBottom();
}

function toggleThinking(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const textEl = el.querySelector('.thinking-text');
  const toggleEl = el.querySelector('.thinking-toggle');
  if (el.classList.contains('collapsed')) {
    el.classList.remove('collapsed');
    textEl.textContent = el._fullText;
    toggleEl.textContent = 'collapse ▴';
  } else {
    el.classList.add('collapsed');
    textEl.textContent = el._preview;
    toggleEl.textContent = 'expand ▾';
  }
}

