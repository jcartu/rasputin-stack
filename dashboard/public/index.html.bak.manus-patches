const streamCounts = { all: 0, thinking: 0, tool: 0, agent: 0, artifact: 0, file: 0, gateway: 0 };
let _toolGroupBuffer = [];
let _toolGroupTimer = null;
const TOOL_GROUP_WINDOW = 2000; // 2s
const TOOL_GROUP_MIN = 3;
