  // Record latency sample
  recordLatency(ms, metadata = {}) {
    const sample = {
      timestamp: Date.now(),
      latency: ms,
      ...metadata
    };
    
    this.history.push(sample);
    
    // Keep only recent history
    if (this.history.length > this.maxHistory) {
      this.history.shift();
    }
