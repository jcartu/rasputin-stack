<script>
/* ════════════════════════════════════════════════════════════════════════
   RASPUTIN 2 NEXUS V4 — JAVASCRIPT (UNCHANGED CORE LOGIC)
   ════════════════════════════════════════════════════════════════════════ */

const $ = s => document.querySelector(s);
const $$ = s => document.querySelectorAll(s);

// ─── State ───
const state = {
  ws: null,
  secret: null,
  authenticated: false,
  currentModel: 'Connecting...',
  messages: 0,
  toolCalls: 0,
  sessionCost: 0,
  totalCost: 0,
  startTime: null,
  streamingMsg: null,
  toolCards: {},
  reconnectAttempts: 0,
  maxReconnect: 50,
  ttsEnabled: false,
  ttsQueue: [],
  currentTTS: null,
  ttsPlaying: false,
  lastUserMessageTime: 0,
  timeline: [],
  costHistory: [],
  lastEventType: null, // Track last event type for thinking card grouping
  lastThinkingCard: null, // Reference to last thinking card element
};

// ─── Utility Functions ───
function formatTime(ms) {
  const s = Math.floor(ms / 1000);
  const m = Math.floor(s / 60);
  const h = Math.floor(m / 60);
  if (h > 0) return `${h}:${(m % 60).toString().padStart(2, '0')}:${(s % 60).toString().padStart(2, '0')}`;
  return `${m}:${(s % 60).toString().padStart(2, '0')}`;
}

function formatCost(cost) {
  return cost.toFixed(4);
}

function formatLatency(ms) {
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}

function toast(msg, type = 'info', duration = 4000) {
  const container = $('#toast-container');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  container.appendChild(el);
  pruneStream();
  while (container.children.length > 50) container.removeChild(container.firstChild);
  setTimeout(() => {
    el.classList.add('removing');
    setTimeout(() => el.remove(), 300);
  }, duration);
}

// ─── Three.js Particle System (UNCHANGED - ALREADY PERFECT) ───
// initParticlesLazy removed — call original directly on load
window.initParticlesOriginal = function() {
  const canvas = $('#particle-canvas');
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.z = 50;

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  const particleCount = 3000;
  const positions = new Float32Array(particleCount * 3);
  const velocities = new Float32Array(particleCount * 3);
  const baseVelocities = new Float32Array(particleCount * 3);
  const sizes = new Float32Array(particleCount);
  const colors = new Float32Array(particleCount * 3);
  const phases = new Float32Array(particleCount);

  const COLORS = {
    idle:    { r: 0.35, g: 0.25, b: 0.75 },
    gpu:     { r: 0.55, g: 0.42, b: 0.96 },
    cpu:     { r: 0.20, g: 0.74, b: 0.97 },
    memory:  { r: 0.96, g: 0.75, b: 0.14 },
    hot:     { r: 0.96, g: 0.30, b: 0.20 },
    agent:   { r: 0.20, g: 0.83, b: 0.60 },
    token:   { r: 1.00, g: 1.00, b: 1.00 },
  };

  for (let i = 0; i < particleCount; i++) {
    const i3 = i * 3;
    positions[i3]     = (Math.random() - 0.5) * 200;
    positions[i3 + 1] = (Math.random() - 0.5) * 200;
    positions[i3 + 2] = (Math.random() - 0.5) * 200;
    
    const speed = 0.02 + Math.random() * 0.03;
    baseVelocities[i3]     = (Math.random() - 0.5) * speed;
    baseVelocities[i3 + 1] = (Math.random() - 0.5) * speed;
    baseVelocities[i3 + 2] = (Math.random() - 0.5) * speed;
    velocities[i3]     = baseVelocities[i3];
    velocities[i3 + 1] = baseVelocities[i3 + 1];
    velocities[i3 + 2] = baseVelocities[i3 + 2];
    
    sizes[i] = 0.4 + Math.random() * 0.4;
    phases[i] = Math.random() * Math.PI * 2;
    
    colors[i3]     = COLORS.idle.r;
    colors[i3 + 1] = COLORS.idle.g;
    colors[i3 + 2] = COLORS.idle.b;
  }

  const geometry = new THREE.BufferGeometry();
  geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
  geometry.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

  const material = new THREE.ShaderMaterial({
    uniforms: {
      uTime: { value: 0 },
      uIntensity: { value: 0 },
      uPixelRatio: { value: renderer.getPixelRatio() },
    },
    vertexShader: `
      attribute float size;
      attribute vec3 color;
      varying vec3 vColor;
      varying float vAlpha;
      uniform float uTime;
      uniform float uIntensity;
      uniform float uPixelRatio;
      
      void main() {
        vColor = color;
        vec4 mvPos = modelViewMatrix * vec4(position, 1.0);
        
        float pulse = 1.0 + sin(uTime * 2.0 + position.x * 0.1) * 0.3 * uIntensity;
        gl_PointSize = size * pulse * uPixelRatio * (80.0 / -mvPos.z);
        gl_PointSize = clamp(gl_PointSize, 1.0, 12.0);
        
        vAlpha = smoothstep(200.0, 20.0, -mvPos.z) * (0.4 + uIntensity * 0.5);
        
        gl_Position = projectionMatrix * mvPos;
      }
    `,
    fragmentShader: `
      varying vec3 vColor;
      varying float vAlpha;
      
      void main() {
        float d = length(gl_PointCoord - 0.5);
        if (d > 0.5) discard;
        
        float core = smoothstep(0.5, 0.1, d);
        float glow = smoothstep(0.5, 0.0, d) * 0.4;
        float alpha = (core + glow) * vAlpha;
        
        gl_FragColor = vec4(vColor, alpha);
      }
    `,
    transparent: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
  });

  const particles = new THREE.Points(geometry, material);
  scene.add(particles);

  const MAX_CONNECTIONS = 200;
  const linePositions = new Float32Array(MAX_CONNECTIONS * 6);
  const lineColors = new Float32Array(MAX_CONNECTIONS * 6);
  const lineGeometry = new THREE.BufferGeometry();
  lineGeometry.setAttribute('position', new THREE.BufferAttribute(linePositions, 3));
  lineGeometry.setAttribute('color', new THREE.BufferAttribute(lineColors, 3));
  const lineMaterial = new THREE.LineBasicMaterial({ 
    vertexColors: true, transparent: true, opacity: 0.15, blending: THREE.AdditiveBlending 
  });
  const lines = new THREE.LineSegments(lineGeometry, lineMaterial);
  scene.add(lines);

  const sysState = {
    gpuUtil: 0,
    cpuUtil: 0,
    ramUtil: 0,
    gpuTemp: 0,
    activeAgents: 0,
    tokensPerSec: 0,
    isStreaming: false,
    lastToolCall: 0,
    lastUserMessageTime: 0,
    intensity: 0,
    targetIntensity: 0,
  };

  window._particleSysState = sysState;

  let mouseX = 0, mouseY = 0;
  document.addEventListener('mousemove', (e) => {
    mouseX = (e.clientX / window.innerWidth) * 2 - 1;
    mouseY = -(e.clientY / window.innerHeight) * 2 + 1;
  });

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  // Particle burst queue
  let _particleBurstQueue = 0;
  window._particleBurst = function(count) { _particleBurstQueue += (count || 20); };

  let time = 0;
  
  function animate() {
    requestAnimationFrame(animate);
    time += 0.016;
    
    sysState.intensity += (sysState.targetIntensity - sysState.intensity) * 0.05;
    const I = sysState.intensity;
    
    // Tool call recency boost (decays over 10s)
    const toolRecency = sysState.lastToolCall ? Math.max(0, 1 - (Date.now() - sysState.lastToolCall) / 10000) : 0;
    // Message rate boost (decays over 30s)  
    const msgRecency = sysState.lastUserMessageTime ? Math.max(0, 1 - (Date.now() - sysState.lastUserMessageTime) / 30000) : 0;
    
    // Read from window._systemLoad for reactive particles
    const sl = window._systemLoad || { cpu: 0, gpu: 0, streaming: false, toolsActive: 0 };
    
    sysState.targetIntensity = Math.min(1, Math.max(0.05,
      sl.cpu * 0.25 +
      sl.gpu * 0.25 +
      (sysState.ramUtil > 60 ? (sysState.ramUtil / 100) * 0.1 : 0) +
      (sysState.gpuTemp > 50 ? (sysState.gpuTemp / 100) * 0.1 : 0) +
      (sysState.activeAgents > 0 ? Math.min(sysState.activeAgents * 0.08, 0.2) : 0) +
      (sl.streaming ? 0.3 : 0) +
      toolRecency * 0.2 +
      msgRecency * 0.1
    ));

    // ─── Color lerp based on CPU load: blue→purple→cyan→amber ───
    let targetColor;
    const cpuLoad = sl.cpu;
    if (sl.streaming) {
      targetColor = COLORS.token; // white burst during streaming
    } else if (cpuLoad > 0.9) {
      // Amber/hot
      targetColor = { r: 0.96, g: 0.75, b: 0.14 };
    } else if (cpuLoad > 0.6) {
      // Cyan
      const t = (cpuLoad - 0.6) / 0.3;
      targetColor = {
        r: 0.20 + t * 0.76,
        g: 0.74 + t * 0.01,
        b: 0.97 - t * 0.83
      };
    } else if (cpuLoad > 0.3) {
      // Purple
      const t = (cpuLoad - 0.3) / 0.3;
      targetColor = {
        r: 0.55 - t * 0.35,
        g: 0.42 + t * 0.32,
        b: 0.96 + t * 0.01
      };
    } else {
      // Idle blue
      targetColor = COLORS.idle;
    }
    // Override for specific states
    if (sysState.gpuTemp > 75) targetColor = COLORS.hot;
    else if (sysState.activeAgents > 0 && cpuLoad < 0.3) targetColor = COLORS.agent;

    const posArr = particles.geometry.attributes.position.array;
    const colArr = particles.geometry.attributes.color.array;
    const sizeArr = particles.geometry.attributes.size.array;

    // Speed tracks CPU via _systemLoad
    const baseSpeed = 1.5 + sl.cpu * 4;
    const speedMult = baseSpeed + I * 4;
    const turbulence = 0.02 + I * 0.25 + sl.cpu * 0.15;
    const attraction = 0.001 + I * 0.003;
    
    // Connection threshold: more connections when tools active
    const connectionThresholdDynamic = 8 + (sl.toolsActive || 0) * 2;

    for (let i = 0; i < particleCount; i++) {
      const i3 = i * 3;
      
      posArr[i3]     += velocities[i3] * speedMult + (Math.random() - 0.5) * turbulence;
      posArr[i3 + 1] += velocities[i3 + 1] * speedMult + (Math.random() - 0.5) * turbulence;
      posArr[i3 + 2] += velocities[i3 + 2] * speedMult + (Math.random() - 0.5) * turbulence;

      posArr[i3]     -= posArr[i3] * attraction;
      posArr[i3 + 1] -= posArr[i3 + 1] * attraction;
      posArr[i3 + 2] -= posArr[i3 + 2] * attraction;

      const mouseStrength = 0.0005 + I * 0.002;
      posArr[i3]     += (mouseX * 30 - posArr[i3]) * mouseStrength;
      posArr[i3 + 1] += (mouseY * 30 - posArr[i3 + 1]) * mouseStrength;

      const breath = Math.sin(time * 1.5 + phases[i]) * (0.5 + I * 2);
      posArr[i3 + 1] += breath * 0.01;

      const bounds = 100 - I * 30;
      if (Math.abs(posArr[i3]) > bounds) velocities[i3] *= -1;
      if (Math.abs(posArr[i3 + 1]) > bounds) velocities[i3 + 1] *= -1;
      if (Math.abs(posArr[i3 + 2]) > bounds) velocities[i3 + 2] *= -1;

      const lerpSpeed = 0.02;
      colArr[i3]     += (targetColor.r - colArr[i3]) * lerpSpeed;
      colArr[i3 + 1] += (targetColor.g - colArr[i3 + 1]) * lerpSpeed;
      colArr[i3 + 2] += (targetColor.b - colArr[i3 + 2]) * lerpSpeed;
      
      if (sysState.isStreaming && Math.random() < 0.005) {
        colArr[i3] = 1; colArr[i3 + 1] = 1; colArr[i3 + 2] = 1;
      }

      sizeArr[i] = (0.4 + Math.random() * 0.4) * (1 + I * 1.5);
    }
    
    // Handle burst particles (on streaming_start)
    if (_particleBurstQueue > 0) {
      const burstCount = Math.min(_particleBurstQueue, 30);
      for (let b = 0; b < burstCount && b < particleCount; b++) {
        const idx = Math.floor(Math.random() * particleCount);
        const i3 = idx * 3;
        // Boost velocity
        velocities[i3] = (Math.random() - 0.5) * 0.3;
        velocities[i3 + 1] = (Math.random() - 0.5) * 0.3;
        velocities[i3 + 2] = (Math.random() - 0.5) * 0.3;
        // Flash white
        colArr[i3] = 1; colArr[i3 + 1] = 1; colArr[i3 + 2] = 1;
        sizeArr[idx] = 1.2 + Math.random() * 0.8;
      }
      _particleBurstQueue = 0;
    }

    let lineIdx = 0;
    const connectionThreshold = connectionThresholdDynamic + (1 - I) * 8;
    if (I > 0.15) {
      for (let i = 0; i < Math.min(particleCount, 500) && lineIdx < MAX_CONNECTIONS; i += 3) {
        const i3 = i * 3;
        for (let j = i + 3; j < Math.min(particleCount, 500) && lineIdx < MAX_CONNECTIONS; j += 3) {
          const j3 = j * 3;
          const dx = posArr[i3] - posArr[j3];
          const dy = posArr[i3+1] - posArr[j3+1];
          const dz = posArr[i3+2] - posArr[j3+2];
          const dist = Math.sqrt(dx*dx + dy*dy + dz*dz);
          
          if (dist < connectionThreshold) {
            const li = lineIdx * 6;
            linePositions[li]   = posArr[i3];
            linePositions[li+1] = posArr[i3+1];
            linePositions[li+2] = posArr[i3+2];
            linePositions[li+3] = posArr[j3];
            linePositions[li+4] = posArr[j3+1];
            linePositions[li+5] = posArr[j3+2];
            
            const fade = 1 - dist / connectionThreshold;
            lineColors[li]   = targetColor.r * fade;
            lineColors[li+1] = targetColor.g * fade;
            lineColors[li+2] = targetColor.b * fade;
            lineColors[li+3] = targetColor.r * fade;
            lineColors[li+4] = targetColor.g * fade;
            lineColors[li+5] = targetColor.b * fade;
            lineIdx++;
          }
        }
      }
    }
    for (let i = lineIdx * 6; i < MAX_CONNECTIONS * 6; i++) linePositions[i] = 0;
    
    lineGeometry.attributes.position.needsUpdate = true;
    lineGeometry.attributes.color.needsUpdate = true;
    lineMaterial.opacity = I * 0.3;
    lineGeometry.setDrawRange(0, lineIdx * 2);

    particles.geometry.attributes.position.needsUpdate = true;
    particles.geometry.attributes.color.needsUpdate = true;
    particles.geometry.attributes.size.needsUpdate = true;
    
    particles.rotation.y += 0.0003 + I * 0.002;
    particles.rotation.x = Math.sin(time * 0.2) * 0.05 * (1 + I);
    
    material.uniforms.uTime.value = time;
    material.uniforms.uIntensity.value = I;
    
    renderer.render(scene, camera);
  }

  animate();
  window.particleScene = { pause: () => cancelAnimationFrame(rafHandle), resume: () => animate(), destroy: () => { cancelAnimationFrame(rafHandle); renderer.dispose(); } };
};

// ─── WebSocket Connection ───
function connect() {
  const secret = state.secret || window.location.hash.slice(1) || 'rasputin-neural-2026';
  state.secret = secret;

  const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
  const host = window.location.host || 'localhost:9001';
  state.ws = new WebSocket(`${protocol}//${host}`);

  state.ws.onopen = () => {
    console.log('WebSocket connected');
    state.reconnectAttempts = 0;
    state.ws.send(JSON.stringify({ type: 'auth', secret: state.secret }));
    
    // Clean up any orphaned streaming indicators from previous session
    cleanupOrphanedIndicators();
  };

  state.ws.onmessage = (e) => {
    try {
      const msg = JSON.parse(e.data);
      handleMessage(msg);
    } catch (err) {
      console.error('Parse error:', err);
    }
  };

  state.ws.onerror = (err) => {
    console.error('WebSocket error:', err);
    updateConnStatus('disconnected');
  };

  state.ws.onclose = () => {
    console.log('WebSocket closed');
    updateConnStatus('disconnected');
    if (state.authenticated && state.reconnectAttempts < state.maxReconnect) {
      state.reconnectAttempts++;
      updateConnStatus('reconnecting');
      setTimeout(connect, Math.min(1000 * state.reconnectAttempts, 10000));
    }
  };
}

function updateConnStatus(status) {
  const dot = $('#conn-dot');
  const text = $('#conn-text');
  if (status === 'connected') {
    dot.className = 'conn-dot';
    text.textContent = 'Connected';
  } else if (status === 'reconnecting') {
    dot.className = 'conn-dot reconnecting';
    text.textContent = 'Reconnecting...';
  } else {
    dot.className = 'conn-dot disconnected';
    text.textContent = 'Disconnected';
  }
}

function handleMessage(msg) {
  // Debug: Log ALL events to trace state clearing
  // console.log('[Event]', msg.type, 'lastEventType:', state.lastEventType, 'hasLastCard:', !!state.lastThinkingCard);
  
  switch (msg.type) {
    case 'auth':
      if (msg.status === 'ok') {
        state.authenticated = true;
        state.startTime = Date.now();
        $('#auth-screen').classList.add('hidden');
        $('#app').classList.add('visible');
        updateConnStatus('connected');
        toast('✅ Connected to Rasputin 2 Nexus', 'success');
      } else {
        $('#auth-error').textContent = '❌ Invalid access key';
      }
      break;

    case 'chat_history':
      if (msg.messages && msg.messages.length) {
        console.log(`[Chat] Received ${msg.messages.length} history messages from server`);
        const messagesArea = $('#chat-messages');
        // Only load if chat is mostly empty (no localStorage history loaded)
        const existingMsgs = messagesArea ? messagesArea.querySelectorAll('.chat-msg-wrap').length : 0;
        if (existingMsgs < 5) {
          msg.messages.forEach(m => {
            const role = (m.from === 'rasputin' || m.from === 'ai' || m.from === 'assistant') ? 'ai' : 'user';
            // Use internal addMessage with skipSave to avoid re-persisting to localStorage
            if (window._chatAddMessageInternal) {
              window._chatAddMessageInternal(role, m.text, m.ts, null, { skipSave: true });
            } else if (window.addChatMessage) {
              window.addChatMessage(role, m.text, m.ts);
            }
          });
          // Scroll to bottom after loading history
          const chatMsgs = $('#chat-messages');
          if (chatMsgs) requestAnimationFrame(() => chatMsgs.scrollTo({ top: chatMsgs.scrollHeight, behavior: 'auto' }));
        }
      }
      break;

    case 'stream_history':
      if (msg.events && msg.events.length) {
        console.log(`[Stream] Replaying ${msg.events.length} recent events`);
        // Clear the "STANDING BY" empty state
        const streamScroll = $('#stream-scroll');
        if (streamScroll) {
          const emptyState = streamScroll.querySelector('.stream-empty');
          if (emptyState) emptyState.remove();
        }
        // Replay events into Neural Stream
        msg.events.forEach(evt => {
          switch (evt.type) {
            case 'thinking':
              handleThinking(evt);
              break;
            case 'tool_call':
              handleToolCall(evt);
              break;
            case 'tool_result':
              handleToolResult(evt);
              break;
          }
        });
      }
      break;

    case 'telemetry':
      handleTelemetry(msg.data);
      break;

    case 'streaming_start':
      handleStreamingStart(msg);
      if (window._particleSysState) window._particleSysState.isStreaming = true;
      if (window._particleBurst) window._particleBurst(20); // Burst particles on stream start
      break;

    case 'thinking':
      handleThinking(msg);
      addTimelineEvent('🧠', 'Reasoning', msg.ts);
      // Note: handleThinking() sets state.lastEventType = 'thinking' internally
      break;

    case 'token_stream':
      handleTokenStream(msg);
      break;

    case 'streaming_end':
      handleStreamingEnd(msg);
      addTimelineEvent('🟣', 'AI response', msg.ts);
      if (window._particleSysState) window._particleSysState.isStreaming = false;
      // Don't clear lastEventType here - streaming and thinking are independent
      break;

    case 'token_usage':
      handleTokenUsage(msg);
      break;

    case 'tool_call':
      handleToolCall(msg);
      addTimelineEvent('🔵', msg.description || msg.tool, msg.ts);
      if (window._particleSysState) window._particleSysState.lastToolCall = Date.now();
      // Don't clear lastEventType - tool calls are part of the same response flow
      // Only user_message should reset thinking grouping
      break;

    case 'tool_result':
      handleToolResult(msg);
      break;

    case 'user_message':
      state.lastUserMessageTime = Date.now();
      state.lastThinkingCard = null; // Clear thinking card tracker on new message
      console.log('[State] Clearing lastEventType due to user_message');
      state.lastEventType = null; // Clear to prevent thinking from appending
      addTimelineEvent('🟡', (msg.text || '').slice(0, 40) + ((msg.text || '').length > 40 ? '...' : ''), msg.ts);
      if (window._particleSysState) window._particleSysState.lastUserMessageTime = Date.now();
      // DISABLED: Don't show conversation in Neural Stream
      // addStreamMessage('user', msg.text, msg.ts);
      // Don't re-add user messages to chat — already rendered locally by sendMessage()
      break;

    case 'agent_update':
      handleAgentUpdate(msg);
      if (msg.action === 'spawn') {
        addTimelineEvent('🟢', `Sub-agent: ${msg.task || 'spawned'}`, msg.ts);
      }
      break;

    case 'artifact':
      handleArtifact(msg);
      addTimelineEvent('📦', `Artifact: ${msg.title || 'generated'}`, msg.ts);
      // Show artifacts in workspace preview
      if (msg.url && typeof window.loadWorkspaceUrl === 'function') {
        window.loadWorkspaceUrl(msg.url, msg.title || 'Artifact');
      }
      break;

    case 'widget':
      handleWidget(msg);
      addTimelineEvent('🎛️', `Widget: ${msg.title || 'interactive'}`, msg.ts);
      break;

    case 'file_shared':
      handleFileShared(msg);
      addTimelineEvent('📎', `File: ${msg.name}`, msg.ts);
      break;

    case 'latency_sample':
      handleLatencySample(msg);
      break;

    case 'gateway_chat':
    case 'gateway_agent':
    case 'gateway_presence':
    case 'gateway_cron':
      handleGatewayEvent(msg);
      break;
  }
}

// ─── Telemetry Handler ───
function handleTelemetry(data) {
  try {
    if (data.model) {
      state.currentModel = data.model;
      const mn = $('#model-name'); if (mn) mn.textContent = data.model;
      const dot = $('#model-dot');
      if (dot) {
        if (data.model.toLowerCase().includes('opus')) { dot.style.background = 'var(--purple)'; dot.style.boxShadow = '0 0 12px var(--purple-glow)'; }
        else if (data.model.toLowerCase().includes('sonnet')) { dot.style.background = 'var(--blue)'; dot.style.boxShadow = '0 0 12px var(--blue-glow)'; }
        else if (data.model.toLowerCase().includes('cerebras')) { dot.style.background = 'var(--amber)'; dot.style.boxShadow = '0 0 12px var(--amber-glow)'; }
      }
    }
  } catch(e) { console.warn('Telemetry model error:', e); }

  try {
    if (data.messageCount !== undefined) { state.messages = data.messageCount; const el = $('#stat-msgs'); if (el) el.textContent = data.messageCount; }
    if (data.toolCallCount !== undefined) { state.toolCalls = data.toolCallCount; const el = $('#stat-tools'); if (el) el.textContent = data.toolCallCount; }
    if (data.totalCost !== undefined) {
      state.sessionCost = data.totalCost;
      updateCost(data.totalCost);
      const el = $('#stat-cost'); if (el) el.textContent = '$' + formatCost(data.totalCost);
    }
    if (data.uptimeMs) { const el = $('#stat-uptime'); if (el) el.textContent = formatTime(data.uptimeMs); }
    // Latency metrics
    if (data.latency) {
      const p95El = $('#stat-p95');
      const ttftEl = $('#stat-ttft');
      if (p95El) p95El.textContent = data.latency.latency.p95 > 0 ? formatLatency(data.latency.latency.p95) : '—';
      if (ttftEl) ttftEl.textContent = data.latency.ttft.p95 > 0 ? formatLatency(data.latency.ttft.p95) : '—';
    // Update latency histogram
    if (data.latency) {
      updateLatencyHistogram(data.latency);
    }
    }
  } catch(e) { console.warn('Telemetry stats error:', e); }

  try {
    if (data.gpu && data.gpu.length > 0) updateGPUs(data.gpu);
  } catch(e) { console.warn('Telemetry GPU error:', e); }

  try {
    if (data.nvtop) updateNVTOP(data.nvtop);
  } catch(e) { console.warn('Telemetry NVTOP error:', e); }

  try {
    if (data.top) updateTOP(data.top);
  } catch(e) { console.warn('Telemetry TOP error:', e); }

  try {
    if (data.services) renderServices(data.services);
  } catch(e) { console.warn('Telemetry services error:', e); }

  try {
  } catch(e) { /* ecosystem removed */ }

  try {
    if (window._particleSysState) {
      const ps = window._particleSysState;
      if (data.gpu && data.gpu.length > 0) {
        ps.gpuUtil = Math.max(...data.gpu.map(g => g.utilization || 0));
        ps.gpuTemp = Math.max(...data.gpu.map(g => g.temperature || 0));
      }
      if (data.system) { ps.cpuUtil = data.system.cpu || 0; ps.ramUtil = data.system.ram || 0; }
      ps.activeAgents = data.activeSessions || 0;
    }
    // Set window._systemLoad for reactive particle system
    window._systemLoad = {
      cpu: Math.min(1, (data.system?.cpu || 0) / 100),
      gpu: data.gpu && data.gpu.length > 0 ? Math.min(1, Math.max(...data.gpu.map(g => (g.utilization || 0) / 100))) : 0,
      streaming: !!(window._particleSysState && window._particleSysState.isStreaming),
      toolsActive: Object.keys(state.toolCards || {}).length,
    };
  } catch(e) { console.warn('Telemetry particles error:', e); }

  // Pulse system card on telemetry
  const sysCard = document.getElementById('nvtop-card');
  if (sysCard && !sysCard._pulsing) {
    sysCard._pulsing = true;
    sysCard.style.transition = 'box-shadow 0.15s ease-out';
    sysCard.style.boxShadow = '0 0 20px oklch(0.75 0.24 145 / 0.15), 0 4px 16px oklch(0 0 0 / 0.25)';
    setTimeout(() => { sysCard.style.boxShadow = ''; sysCard._pulsing = false; }, 300);
  }

  // Route to ModernMonitor
  try {
    if (typeof ModernMonitor !== 'undefined' && data.system) {
      const sys = data.system;
      const B2MB = 1048576; // bytes to MB
      ModernMonitor.update({
        sys: {
          cpuCores: sys.cpuPerCore || [],
          cpuFreq: sys.cpuFreqAvg || 0,
          cpuTemp: sys.cpuTemp || 0,
          memUsed: (sys.memUsed || 0) / B2MB,
          memTotal: (sys.memTotal || 1) / B2MB,
          swapUsed: (sys.swapUsed || 0) / B2MB,
          swapTotal: (sys.swapTotal || 0) / B2MB,
          uptime: sys.uptime || 0,
          netRx: sys.netRx || 0,
          netTx: sys.netTx || 0,
          diskReadMBs: sys.diskReadMBs || 0,
          diskWriteMBs: sys.diskWriteMBs || 0,
          diskUsed: (sys.diskUsed || 0) / B2MB,
          diskTotal: (sys.diskTotal || 1) / B2MB,
          diskPct: sys.disk || 0,
        },
        gpus: (data.gpu || []).map(g => ({
          name: g.name,
          utilization: g.utilization || 0,
          memUsed: g.memoryUsed || 0,
          memTotal: g.memoryTotal || 1,
          temperature: g.temperature || 0,
          power: g.powerDraw || 0,
        })),
        processes: (data.top?.processes || []).slice(0, 15),
      });
    }
  } catch(e) { console.warn('ModernMonitor update error:', e); }
}

