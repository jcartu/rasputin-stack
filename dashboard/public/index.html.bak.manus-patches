    alertEl.style.borderColor = criticalAlert.severity === 'critical' ? 'var(--red)' : 'var(--amber)';
  } else if (data.projectedMonthEnd && data.projectedMonthEnd > budget * 0.75) {
    const pct = ((data.projectedMonthEnd / budget) * 100).toFixed(0);
    alertMsgEl.innerHTML = `On track for ${pct}% of monthly budget ($${data.projectedMonthEnd.toFixed(2)} / $${budget}) <a href="/budget.html" style="color: var(--cyan); text-decoration: underline; margin-left: 8px;">Manage Budget →</a>`;
    alertEl.style.display = 'block';
    alertEl.style.background = 'var(--amber-glow)';
    alertEl.style.borderColor = 'var(--amber)';
  } else {
    alertEl.style.display = 'none';
  }
  
  // Draw mini chart (use dailySpending if available, fallback to timeSeries)
  const chartData = data.dailySpending || data.timeSeries || [];
  drawForecastChart(chartData);
}

function drawForecastChart(timeSeries) {
  const canvas = $('#forecast-chart');
  if (!canvas) return;
  
  const ctx = canvas.getContext('2d');
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * window.devicePixelRatio;
  canvas.height = rect.height * window.devicePixelRatio;
  ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  
  const w = rect.width;
  const h = rect.height;
  
  // Clear
  ctx.clearRect(0, 0, w, h);
  
  if (!timeSeries || timeSeries.length === 0) {
    ctx.fillStyle = 'var(--text-3)';
    ctx.font = '10px var(--font-mono)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('Collecting data...', w / 2, h / 2);
    return;
  }
  
  // Find max cost for scaling
  const maxCost = Math.max(...timeSeries.map(d => d.cost), 0.01);
  const padding = 10;
  const barWidth = (w - padding * 2) / timeSeries.length;
  
  // Draw bars
  timeSeries.forEach((d, i) => {
    const barHeight = (d.cost / maxCost) * (h - padding * 2);
    const x = padding + i * barWidth;
    const y = h - padding - barHeight;
    
    // Gradient from purple to cyan
    const gradient = ctx.createLinearGradient(x, y, x, h - padding);
    gradient.addColorStop(0, '#a78bfa');
    gradient.addColorStop(1, '#22d3ee');
    
    ctx.fillStyle = gradient;
    ctx.fillRect(x, y, barWidth - 2, barHeight);
    
    // Label (date)
    if (i % 2 === 0) {
      ctx.fillStyle = 'var(--text-3)';
      ctx.font = '8px var(--font-mono)';
      ctx.textAlign = 'center';
      ctx.fillText(d.date.split('-').slice(1).join('/'), x + barWidth / 2, h - 2);
    }
  });
  
  // Draw max cost label
  ctx.fillStyle = 'var(--text-2)';
  ctx.font = '9px var(--font-mono)';
  ctx.textAlign = 'left';
  ctx.fillText('$' + maxCost.toFixed(2), 2, 10);
}

