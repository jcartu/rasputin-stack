<style>
/* ════════════════════════════════════════════════════════════════════════
   RASPUTIN NEURAL DASHBOARD V4 — 2026 VISUAL OVERHAUL
   Bloomberg Terminal aesthetic • WebGL particles • Glassmorphism 2.0
   Dense information display • oklch colors • Glow effects • Micro-animations
   ════════════════════════════════════════════════════════════════════════ */

* { margin:0; padding:0; box-sizing:border-box; }

:root {
  color-scheme: dark;
  
  /* OKLCH Colors - Perceptually uniform, vibrant */
  --void: oklch(0.06 0.01 270);
  --base: oklch(0.08 0.015 265);
  --surface: oklch(0.11 0.02 270);
  --elevated: oklch(0.15 0.025 270);
  --raised: oklch(0.19 0.025 265);
  
  --text-1: oklch(0.98 0.005 270);
  --text-2: oklch(0.72 0.012 270);
  --text-3: oklch(0.48 0.018 270);
  --text-ghost: oklch(0.30 0.015 270);
  
  --purple: oklch(0.68 0.30 290);
  --purple-glow: oklch(0.68 0.30 290 / 0.5);
  --cyan: oklch(0.78 0.22 195);
  --cyan-glow: oklch(0.78 0.22 195 / 0.5);
  --green: oklch(0.75 0.24 145);
  --green-glow: oklch(0.75 0.24 145 / 0.5);
  --amber: oklch(0.85 0.20 85);
  --amber-glow: oklch(0.85 0.20 85 / 0.5);
  --red: oklch(0.65 0.29 25);
  --red-glow: oklch(0.65 0.29 25 / 0.5);
  --pink: oklch(0.72 0.26 340);
  --orange: oklch(0.77 0.21 50);
  --blue: oklch(0.72 0.20 240);
  
  --glass: oklch(0.10 0.015 270 / 0.25);
  --glass-border: oklch(0.38 0.04 270 / 0.15);
  --glass-strong: oklch(0.14 0.02 270 / 0.35);
  
  --font-display: 'Space Grotesk', system-ui, -apple-system, sans-serif;
  --font-body: 'Geist', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  
  --radius: 14px;
  --radius-sm: 8px;
  --radius-lg: 18px;
  
  --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --spring-smooth: cubic-bezier(0.22, 1, 0.36, 1);
  --snap: cubic-bezier(0.16, 1, 0.3, 1);
}

/* ═══ ANIMATED BORDER HOUDINI ═══ */
@property --border-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}
@keyframes border-rotate {
  to { --border-angle: 360deg; }
}

html { font-size: 15px; }
body {
  font-family: var(--font-body);
  background: var(--void);
  color: var(--text-1);
  overflow: hidden;
  height: 100dvh;
  width: 100vw;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

::selection {
  background: var(--purple-glow);
  color: var(--text-1);
}

::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: oklch(0.28 0.02 270); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: oklch(0.38 0.03 270); }

button {
  cursor: pointer;
  border: none;
  background: none;
  font: inherit;
  color: inherit;
}

/* ═══ PARTICLE CANVAS — MAKE IT VISIBLE ═══ */
#particle-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  opacity: 0.85;
  pointer-events: none;
}

/* ═══ AURORA BACKGROUND ═══ */
.aurora-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  background: 
    radial-gradient(ellipse 80% 50% at 15% 20%, oklch(0.50 0.28 290 / 0.12) 0%, transparent 50%),
    radial-gradient(ellipse 70% 60% at 85% 25%, oklch(0.55 0.26 320 / 0.10) 0%, transparent 50%),
    radial-gradient(ellipse 90% 50% at 50% 90%, oklch(0.60 0.20 195 / 0.08) 0%, transparent 50%),
    var(--void);
  animation: aurora-shift 25s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes aurora-shift {
  0% { filter: hue-rotate(0deg) brightness(1); }
  50% { filter: hue-rotate(15deg) brightness(1.05); }
  100% { filter: hue-rotate(-10deg) brightness(0.98); }
}

/* ═══ AUTH SCREEN ═══ */
#auth-screen {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--void);
  transition: opacity 0.6s var(--snap), visibility 0.6s;
}
#auth-screen.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.auth-box {
  text-align: center;
  z-index: 1;
  animation: auth-float 3s ease-in-out infinite;
}
@keyframes auth-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.auth-logo {
  font-size: 5rem;
  margin-bottom: 1.5rem;
  filter: drop-shadow(0 0 30px var(--purple-glow));
}

.auth-title {
  font-family: var(--font-display);
  font-size: 3.5rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--purple), var(--cyan), var(--pink));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 3rem;
  letter-spacing: -2px;
}

.auth-subtitle {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  color: var(--text-3);
  margin-bottom: 2rem;
  letter-spacing: 2px;
}

.auth-input-wrap {
  position: relative;
  width: 380px;
  margin: 0 auto 2rem;
}
.auth-input-wrap input {
  width: 100%;
  padding: 18px 24px;
  background: var(--glass-strong);
  backdrop-filter: blur(8px) saturate(150%);
  border: 1.5px solid var(--glass-border);
  border-radius: var(--radius);
  font-family: var(--font-mono);
  font-size: 1.1rem;
  letter-spacing: 3px;
  color: var(--text-1);
  transition: all 0.3s var(--spring-smooth);
}
.auth-input-wrap input:focus {
  outline: none;
  border-color: var(--purple);
  box-shadow: 0 0 40px var(--purple-glow), inset 0 1px 0 oklch(1 0 0 / 0.1);
  transform: translateY(-2px);
}
.auth-input-wrap input::placeholder {
  color: var(--text-ghost);
  letter-spacing: 1px;
}

.auth-btn {
  padding: 16px 48px;
  background: linear-gradient(135deg, var(--purple), oklch(0.55 0.32 285));
  border-radius: var(--radius);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: all 0.2s var(--spring);
  box-shadow: 0 8px 32px var(--purple-glow);
}
.auth-btn:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 12px 48px var(--purple-glow);
}
.auth-btn:active {
  transform: translateY(-1px) scale(0.98);
  transition-duration: 80ms;
}

.auth-error {
  color: var(--red);
  font-size: 0.95rem;
  margin-top: 1.5rem;
  min-height: 1.5em;
  font-family: var(--font-mono);
}

.auth-footer {
  margin-top: 4rem;
  font-size: 0.75rem;
  color: var(--text-ghost);
  font-family: var(--font-mono);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.encrypt-icon {
  font-size: 1rem;
  color: var(--green);
  animation: lock-pulse 2s ease-in-out infinite;
}
@keyframes lock-pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ═══ MAIN APP ═══ */
#app {
  display: none;
  height: 100dvh;
  width: 100vw;
  position: relative;
  z-index: 1;
}
#app.visible {
  display: flex;
  flex-direction: column;
  animation: app-fadein 0.8s var(--snap);
}
@keyframes app-fadein {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ═══ TOP BAR ═══ */
.topbar {
  height: 60px;
  background: oklch(0.08 0.01 270 / 0.2);
  backdrop-filter: blur(10px) saturate(140%);
  border-bottom: 1px solid var(--glass-border);
  padding: 0 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-shrink: 0;
  z-index: 100;
  box-shadow: 0 1px 0 oklch(1 0 0 / 0.02) inset, 0 4px 24px oklch(0 0 0 / 0.3);
}

.topbar-logo {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.3rem;
  letter-spacing: -0.5px;
  display: flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, var(--purple), var(--cyan), var(--purple), var(--cyan));
  background-size: 300% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: logo-gradient-shift 6s ease-in-out infinite;
}
@keyframes logo-gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}
.topbar-logo .emoji {
  font-size: 1.8rem;
  filter: drop-shadow(0 0 12px var(--purple-glow));
  animation: logo-pulse 4s ease-in-out infinite;
}
@keyframes logo-pulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 12px var(--purple-glow)); }
  50% { transform: scale(1.08); filter: drop-shadow(0 0 20px var(--purple-glow)); }
}

.topbar-divider {
  width: 1px;
  height: 28px;
  background: var(--glass-border);
}

.model-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  background: var(--glass);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: 24px;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 600;
}
.model-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--purple);
  box-shadow: 0 0 12px var(--purple-glow);
  animation: dot-pulse 2s ease-in-out infinite;
}
@keyframes dot-pulse {
  0%, 100% { box-shadow: 0 0 8px var(--purple-glow); }
  50% { box-shadow: 0 0 20px var(--purple-glow); }
}

.conn-status {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8rem;
  color: var(--text-3);
  font-family: var(--font-mono);
}
.conn-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 12px var(--green-glow);
  transition: all 0.3s;
  position: relative;
}
.conn-dot::after {
  content: '';
  position: absolute;
  inset: -3px;
  border-radius: 50%;
  border: 1px solid var(--green);
  opacity: 0;
  animation: conn-ping 2s ease-out infinite;
}
@keyframes conn-ping {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(2.2); opacity: 0; }
}
.conn-dot.disconnected {
  background: var(--red);
  box-shadow: 0 0 12px var(--red-glow);
}
.conn-dot.reconnecting {
  background: var(--amber);
  box-shadow: 0 0 12px var(--amber-glow);
  animation: blink 1s step-end infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.encrypt-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.75rem;
  color: var(--green);
  font-family: var(--font-mono);
  font-weight: 600;
}
.encrypt-icon-sm {
  font-size: 1rem;
  animation: lock-pulse 2s ease-in-out infinite;
}

.topbar-stats {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 0.75rem;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 6px;
}
.stat-label {
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.stat-value {
  color: var(--text-1);
  font-weight: 700;
  font-size: 0.82rem;
  text-shadow: 0 0 8px currentColor;
  letter-spacing: 0.3px;
}
.stat-item:has(#stat-cost) .stat-value {
  color: var(--amber);
  font-size: 0.88rem;
  font-weight: 800;
}

.topbar-actions {
  display: flex;
  gap: 6px;
}

/* ═══ NAV PILLS ═══ */
.nav-pill {
  position: relative;
  color: oklch(0.65 0.06 280);
  font-size: 11.5px;
  font-weight: 500;
  text-decoration: none;
  padding: 5px 12px;
  border: 1px solid oklch(0.25 0.02 280 / 0.6);
  border-radius: 20px;
  white-space: nowrap;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  background: oklch(0.12 0.01 280 / 0.4);
  backdrop-filter: blur(4px);
  cursor: pointer;
  font-family: var(--font);
  letter-spacing: 0.2px;
}
.nav-pill:hover {
  color: oklch(0.90 0.15 195);
  border-color: oklch(0.60 0.15 195 / 0.6);
  background: oklch(0.18 0.04 195 / 0.3);
  box-shadow: 0 0 12px oklch(0.60 0.15 195 / 0.15), inset 0 0 8px oklch(0.60 0.15 195 / 0.05);
  transform: translateY(-1px);
}
.nav-pill:active {
  transform: translateY(0);
  box-shadow: 0 0 6px oklch(0.60 0.15 195 / 0.1);
}
.cmd-k-pill {
  color: oklch(0.70 0.12 85);
  border-color: oklch(0.30 0.06 85 / 0.5);
  background: oklch(0.14 0.03 85 / 0.3);
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
}
.cmd-k-pill:hover {
  color: oklch(0.92 0.18 85);
  border-color: oklch(0.65 0.15 85 / 0.6);
  background: oklch(0.20 0.06 85 / 0.3);
  box-shadow: 0 0 12px oklch(0.65 0.15 85 / 0.15);
}
.nav-pill[data-tooltip]:hover::after {
  content: attr(data-tooltip);
  position: absolute;
  top: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%);
  background: oklch(0.10 0.02 265 / 0.95);
  border: 1px solid oklch(0.35 0.04 270 / 0.4);
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 11px;
  font-weight: 400;
  color: oklch(0.82 0.03 270);
  white-space: normal;
  width: max-content;
  max-width: 260px;
  line-height: 1.5;
  z-index: 9999;
  pointer-events: none;
  box-shadow: 0 8px 32px oklch(0 0 0 / 0.5);
  backdrop-filter: blur(12px);
  animation: tooltip-in 0.2s ease-out;
}
.nav-pill[data-tooltip]:hover::before {
  content: '';
  position: absolute;
  top: calc(100% + 4px);
  left: 50%;
  transform: translateX(-50%);
  border: 5px solid transparent;
  border-bottom-color: oklch(0.35 0.04 270 / 0.4);
  z-index: 9999;
  pointer-events: none;
  animation: tooltip-in 0.2s ease-out;
}
@keyframes tooltip-in {
  from { opacity: 0; transform: translateX(-50%) translateY(4px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.topbar-nav-links {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding: 2px 0;
}
.topbar-nav-links::-webkit-scrollbar { display: none; }

.topbar-btn {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  transition: all 0.15s var(--spring);
}
.topbar-btn:hover {
  background: var(--glass);
  transform: scale(1.08);
}
.topbar-btn:active {
  transform: scale(0.95);
  transition-duration: 60ms;
}

/* ═══ ITERATION 1: FULL-HEIGHT COLUMN LAYOUT — CHAT LEFT, STREAM RIGHT ═══ */
.bento-container {
  flex: 1;
  overflow: hidden;
  padding: 12px;
  display: grid;
  grid-template-columns: minmax(400px, 1.6fr) minmax(340px, 1.3fr) minmax(300px, 1fr);
  grid-template-rows: 1fr;
  gap: 10px;
  height: calc(100vh - 60px - 70px - 28px);
  max-width: none;
  margin: 0;
  width: 100%;
}

/* ═══ ULTRAWIDE (>3840px) — Use full width with 5-zone layout ═══ */
.bento-card {
  background: linear-gradient(145deg, oklch(0.09 0.018 270 / 0.28), oklch(0.06 0.012 265 / 0.22));
  backdrop-filter: blur(12px) saturate(160%);
  border: 1px solid oklch(0.32 0.04 270 / 0.2);
  border-top: 1px solid oklch(0.40 0.05 270 / 0.25);
  border-radius: var(--radius);
  padding: 12px;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 0;
  min-width: 0;
  opacity: 1;
  transition: all 0.3s var(--spring-smooth);
  box-shadow: 
    0 1px 0 oklch(1 0 0 / 0.03) inset,
    0 6px 20px oklch(0 0 0 / 0.3),
    0 0 0 1px oklch(0.35 0.04 270 / 0.15),
    0 0 40px oklch(0.20 0.04 270 / 0.04);
  animation: card-enter 0.6s var(--spring);
}
@keyframes card-enter {
  from { transform: scale(0.97) translateY(10px); }
  to { transform: scale(1) translateY(0); }
}

/* ═══ ANIMATED GRADIENT BORDER — Rotating conic gradient ═══ */
.bento-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: conic-gradient(
    from var(--border-angle),
    var(--glow-color),
    transparent 18%,
    transparent 42%,
    var(--glow-color) 55%,
    transparent 72%,
    transparent 90%,
    var(--glow-color)
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  animation: border-rotate 8s linear infinite;
  opacity: 0.45;
  transition: opacity 0.4s ease;
  z-index: 1;
  pointer-events: none;
}
.bento-card:hover::before {
  opacity: 0.85;
}

/* ═══ SCANLINE OVERLAY — Cyberpunk atmosphere ═══ */
.bento-container::before {
  content: '';
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    oklch(0 0 0 / 0.03) 2px,
    oklch(0 0 0 / 0.03) 4px
  );
  pointer-events: none;
  z-index: 1000;
  animation: scanline-drift 8s linear infinite;
}
@keyframes scanline-drift {
  from { transform: translateY(0); }
  to { transform: translateY(4px); }
}

/* ═══ HORIZONTAL SCAN LINE — Star Trek LCARS feel ═══ */
.bento-container::after {
  content: '';
  position: fixed;
  left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 5%, oklch(0.78 0.22 195 / 0.15) 20%, oklch(0.78 0.22 195 / 0.3) 50%, oklch(0.78 0.22 195 / 0.15) 80%, transparent 95%);
  pointer-events: none;
  z-index: 1001;
  animation: h-scan 6s ease-in-out infinite;
}
@keyframes h-scan {
  0% { top: 0; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: 100vh; opacity: 0; }
}

/* ═══ CARD GLOW PULSE — Alive feeling ═══ */
.bento-card {
  --glow-color: oklch(0.68 0.30 290 / 0.08);
}
#chat-card { --glow-color: oklch(0.68 0.30 290 / 0.12); }
#stream-card { --glow-color: oklch(0.78 0.22 195 / 0.15); }
#nvtop-card { --glow-color: oklch(0.75 0.24 145 / 0.10); }
#missions-card { --glow-color: oklch(0.85 0.20 85 / 0.10); }
#agents-card { --glow-color: oklch(0.72 0.26 340 / 0.10); }
#tools-card { --glow-color: oklch(0.78 0.22 195 / 0.10); }
#missions-card { --glow-color: oklch(0.85 0.20 85 / 0.10); }

@keyframes subtle-breathe {
  0%, 100% { box-shadow: 0 0 20px var(--glow-color), 0 4px 16px oklch(0 0 0 / 0.25); }
  50% { box-shadow: 0 0 35px var(--glow-color), 0 4px 16px oklch(0 0 0 / 0.25); }
}
.bento-card {
  animation: card-enter 0.6s var(--spring), subtle-breathe 4s ease-in-out infinite;
  animation-delay: 0s, calc(var(--card-index, 0) * 0.5s);
}
.bento-card:hover {
  border-color: oklch(0.52 0.12 270 / 0.6);
  box-shadow: 
    0 2px 0 oklch(1 0 0 / 0.04) inset,
    0 12px 40px oklch(0 0 0 / 0.4),
    0 0 0 1px var(--purple-glow),
    0 0 28px var(--glow-color);
  transform: translateY(-3px);
  animation-play-state: paused;
}

/* LCARS corner brackets */
.card-title::before {
  content: '┌';
  position: absolute;
  left: -2px;
  top: -2px;
  color: var(--glow-color);
  font-size: 1.2em;
  opacity: 0.5;
  font-family: var(--font-mono);
}
.card-title { position: relative; }

.card-title {
  font-family: var(--font-display);
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-1);
  margin-bottom: 12px;
  padding-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
  text-shadow: 0 0 12px var(--glow-color);
  border-bottom: 1px solid oklch(0.3 0.02 270 / 0.3);
  position: relative;
}
.card-title::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 60%;
  height: 1px;
  background: linear-gradient(90deg, var(--glow-color), transparent);
  opacity: 0.8;
}
.card-icon {
  font-size: 1.1rem;
  filter: drop-shadow(0 0 10px currentColor);
}

/* ═══ CARD TITLE SHIMMER — Premium hover sweep ═══ */
@keyframes title-shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}
.bento-card:hover .card-title > span:not(.card-icon) {
  background: linear-gradient(
    90deg,
    var(--text-1) 0%,
    var(--text-1) 40%,
    oklch(0.95 0.15 290) 50%,
    var(--text-1) 60%,
    var(--text-1) 100%
  );
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: title-shimmer 1.5s ease-in-out;
}

/* ═══ CHAT — COL 1, FULL HEIGHT ═══ */
#chat-card {
  grid-column: 1;
  grid-row: 1 / -1;
  display: flex;
  flex-direction: column;
}

/* ═══ NEURAL STREAM — COL 2, FULL HEIGHT (next to chat) ═══ */
#stream-card {
  grid-column: 2;
  grid-row: 1 / -1;
  display: flex;
  flex-direction: column;
}
.stream-scroll {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-right: 4px;
}

.stream-msg {
  position: relative;
  padding: 8px 12px 22px 12px;
  border-radius: var(--radius-sm);
  border-left: 3px solid transparent;
  font-size: 0.85rem;
  line-height: 1.5;
  transition: all 0.2s;
  animation: msg-slide 0.15s var(--spring);
  background: oklch(0.08 0.015 270 / 0.2);
}
@keyframes msg-slide {
  from { opacity: 0; transform: translateX(20px); }
  to { opacity: 1; transform: translateX(0); }
}
.stream-msg:hover {
  background: oklch(0.13 0.02 270 / 0.25);
}

.stream-msg.role-ai {
  border-left-color: var(--purple);
  background: oklch(0.68 0.30 290 / 0.05);
}
.stream-msg.role-user {
  border-left-color: var(--amber);
  background: oklch(0.85 0.20 85 / 0.05);
}
.stream-msg.role-tool {
  border-left-color: var(--cyan);
  background: oklch(0.78 0.22 195 / 0.05);
}

.stream-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
  font-size: 0.65rem;
}
.stream-time {
  position: absolute;
  bottom: 4px;
  right: 8px;
  color: var(--text-3);
  font-family: var(--font-mono);
  font-size: 0.6rem;
  opacity: 0;
  transition: opacity 0.2s;
}
.stream-msg:hover .stream-time {
  opacity: 1;
}
.stream-role {
  padding: 2px 6px;
  border-radius: 4px;
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}
.role-ai .stream-role {
  background: oklch(0.68 0.30 290 / 0.2);
  color: var(--purple);
  text-shadow: 0 0 8px var(--purple-glow);
}
.role-user .stream-role {
  background: oklch(0.85 0.20 85 / 0.2);
  color: var(--amber);
  text-shadow: 0 0 8px var(--amber-glow);
}
.role-tool .stream-role {
  background: oklch(0.78 0.22 195 / 0.2);
  color: var(--cyan);
  text-shadow: 0 0 8px var(--cyan-glow);
}

.stream-text {
  color: var(--text-1);
  white-space: pre-wrap;
  word-break: break-word;
}

.stream-cursor {
  display: inline-block;
  width: 2px;
  height: 1em;
  background: var(--purple);
  margin-left: 2px;
  vertical-align: text-bottom;
  animation: blink 1s step-end infinite;
  box-shadow: 0 0 8px var(--purple-glow);
}

/* ═══ TOOL CALL CARD ═══ */
/* ═══ TOOL CALL CARDS — Premium stream integration ═══ */
.tool-call-card {
  position: relative;
  margin: 6px 0;
  border-radius: var(--radius-sm);
  border: 1px solid oklch(0.78 0.22 195 / 0.15);
  border-left: 3px solid var(--cyan);
  background: linear-gradient(135deg, oklch(0.10 0.03 195 / 0.35), oklch(0.07 0.02 210 / 0.25));
  overflow: hidden;
  animation: tool-fade-in 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(4px);
  transition: all 0.25s ease;
}
.tool-call-card:hover {
  border-color: oklch(0.78 0.22 195 / 0.4);
  background: linear-gradient(135deg, oklch(0.13 0.04 195 / 0.45), oklch(0.09 0.03 210 / 0.35));
  box-shadow: 0 4px 20px oklch(0.78 0.22 195 / 0.12);
  transform: translateX(2px);
}
.tool-call-card:empty,
.tool-call-card:not(:has(.tool-name:not(:empty))) {
  display: none;
}
@keyframes tool-fade-in {
  from { opacity: 0; transform: translateX(16px) scale(0.98); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}

.tool-header {
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 0.72rem;
}
.tool-spinner {
  width: 14px;
  height: 14px;
  border: 2px solid oklch(0.78 0.22 195 / 0.2);
  border-top-color: var(--cyan);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }
.tool-check {
  display: none;
  width: 14px; height: 14px;
  flex-shrink: 0;
}
.tool-check svg { width: 14px; height: 14px; }
.tool-check svg path {
  stroke: var(--green); stroke-width: 3;
  stroke-linecap: round; stroke-linejoin: round; fill: none;
  stroke-dasharray: 24; stroke-dashoffset: 24;
  animation: check-draw 0.6s ease forwards;
}
@keyframes check-draw { to { stroke-dashoffset: 0; } }
.tool-call-card.complete .tool-spinner { display: none; }
.tool-call-card.complete .tool-check { display: block; }
.tool-call-card.complete {
  border-left-color: var(--green);
  background: linear-gradient(135deg, oklch(0.10 0.03 150 / 0.2), oklch(0.07 0.02 170 / 0.15));
}

.tool-name {
  color: var(--cyan);
  font-weight: 700;
  text-shadow: 0 0 10px oklch(0.78 0.22 195 / 0.3);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  flex: 1; min-width: 0;
}
.tool-call-card.complete .tool-name { color: var(--green); text-shadow: 0 0 10px oklch(0.78 0.22 150 / 0.3); }
.tool-time {
  color: var(--text-ghost);
  font-size: 0.55rem;
  white-space: nowrap;
  opacity: 0.5;
  transition: opacity 0.2s;
  flex-shrink: 0;
}
.tool-call-card:hover .tool-time { opacity: 1; }

.tool-input {
  padding: 2px 12px 6px;
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--text-3);
  max-height: 60px;
  overflow-y: auto;
  white-space: pre-wrap; word-break: break-all;
  line-height: 1.4;
}

.tool-result {
  display: none;
  padding: 6px 12px;
  border-top: 1px solid oklch(0.78 0.22 195 / 0.1);
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--text-2);
  max-height: 60px;
  overflow-y: auto;
  animation: result-slide 0.2s ease;
  background: oklch(0.06 0.01 195 / 0.3);
}
@keyframes result-slide {
  from { opacity: 0; max-height: 0; }
  to { opacity: 1; max-height: 60px; }
}
.tool-call-card.complete .tool-result { display: block; }

/* ═══ AGENT UPDATE CARDS — Sub-agent lifecycle in stream ═══ */
.agent-update-card {
  margin: 6px 0;
  padding: 8px 14px;
  background: linear-gradient(135deg, oklch(0.10 0.04 150 / 0.3), oklch(0.07 0.02 170 / 0.2));
  border: 1px solid oklch(0.78 0.22 150 / 0.15);
  border-left: 3px solid var(--green);
  border-radius: var(--radius-sm);
  animation: stream-slide-in 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(4px);
  transition: all 0.25s ease;
}
.agent-update-card:hover {
  border-color: oklch(0.78 0.22 150 / 0.35);
  box-shadow: 0 4px 20px oklch(0.78 0.22 150 / 0.1);
  transform: translateX(2px);
}
.agent-update-card[data-action="error"] {
  border-left-color: var(--red);
  background: linear-gradient(135deg, oklch(0.10 0.04 25 / 0.3), oklch(0.07 0.02 15 / 0.2));
}
.agent-update-card[data-action="spawn"] {
  border-left-color: var(--green);
}
.agent-update-card[data-action="complete"] {
  border-left-color: var(--purple);
  background: linear-gradient(135deg, oklch(0.10 0.04 280 / 0.3), oklch(0.07 0.02 300 / 0.2));
}

@keyframes slideInRight {
  from { opacity: 0; transform: translateX(-20px); }
  to { opacity: 1; transform: translateX(0); }
}

/* ─── Artifact Cards ─── */
.artifact-card {
  margin: 10px 0;
  animation: fadeInUp 0.15s var(--spring);
}

.artifact-card button:hover {
  background: var(--purple);
  transform: translateY(-1px);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ─── Widget Cards ─── */
.widget-card {
  margin: 10px 0;
  animation: bounceIn 0.6s var(--spring);
}

.widget-card button:hover:not(:disabled) {
  background: var(--cyan);
  color: var(--void);
  transform: scale(1.02);
  box-shadow: 0 4px 20px var(--cyan-glow);
}

@keyframes bounceIn {
  0% { opacity: 0; transform: scale(0.8); }
  50% { transform: scale(1.05); }
  100% { opacity: 1; transform: scale(1); }
}

/* ─── File Cards ─── */
.file-card {
  margin: 16px 0;
  animation: slideInLeft 0.15s var(--spring);
}

.file-card a:hover {
  background: var(--green);
  color: var(--void);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px var(--green-glow);
}

@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(20px); }
  to { opacity: 1; transform: translateX(0); }
}

/* ─── Gateway Event Cards ─── */
.gateway-event-card {
  margin: 6px 0;
  animation: fadeIn 0.15s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ═══ SYSTEM — COL 3 TOP ═══ */
#nvtop-card {
  display: none !important;
}

/* ═══ MISSIONS — COL 3 BOTTOM ═══ */
#missions-card {
  display: none !important;
}

/* ═══ SUB-AGENTS — COL 4 FULL HEIGHT (Tools merged into Neural Stream) ═══ */
#agents-card {
  display: none !important;
}

/* ═══ TOOLS — HIDDEN (merged into Neural Stream) ═══ */
#tools-card {
  display: none !important;
}

/* ═══ WORKSPACE PANEL ═══ */
#workspace-card .ws-cmd { color: #00e5ff; font-weight: 600; }
#workspace-card .ws-err { color: #ff3d71; }
#workspace-card .ws-path { color: #a78bfa; }
#workspace-card .ws-ok { color: #0dff92; }
#workspace-card {
  grid-column: 3;
  grid-row: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

.workspace-tab {
  background: transparent;
  border: 1px solid var(--glass-border);
  color: var(--text-3);
  padding: 3px 10px;
  border-radius: 6px;
  font-size: 0.6rem;
  font-family: var(--font-mono);
  cursor: pointer;
  transition: all 0.2s;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.workspace-tab:hover {
  border-color: var(--cyan);
  color: var(--text-2);
}
.workspace-tab.active {
  background: oklch(0.78 0.22 195 / 0.12);
  border-color: var(--cyan);
  color: var(--cyan);
}

/* ─── Window functions ─── */
/* ═══ HIDDEN PANELS (not in 3-panel layout) ═══ */
#forecast-card, #latency-card, #predictive-latency-widget, #gpu-card {
  display: none !important;
}


/* ─── Thinking Stream ─── */
/* ═══ THINKING/REASONING CARDS — The brain of the stream ═══ */
.thinking-card {
  background: linear-gradient(135deg, oklch(0.11 0.05 280 / 0.55), oklch(0.07 0.03 300 / 0.35));
  border: 1px solid oklch(0.55 0.18 280 / 0.3);
  border-left: 3px solid oklch(0.7 0.25 280);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  margin: 6px 0;
  font-size: 12px;
  line-height: 1.5;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  animation: stream-slide-in 0.35s cubic-bezier(0.22, 1, 0.36, 1), thinking-breathe 3s ease-in-out infinite 0.4s;
  box-shadow: 0 2px 16px oklch(0.68 0.30 290 / 0.1), inset 0 1px 0 oklch(0.6 0.15 280 / 0.08);
  transition: all 0.3s ease;
  backdrop-filter: blur(4px);
}
.thinking-card:hover {
  border-color: oklch(0.65 0.20 280 / 0.5);
  box-shadow: 0 4px 24px oklch(0.68 0.30 290 / 0.18), inset 0 1px 0 oklch(0.6 0.15 280 / 0.12);
  transform: translateX(2px);
}
.thinking-card.complete {
  animation: stream-slide-in 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}
@keyframes stream-slide-in {
  from { opacity: 0; transform: translateX(16px) scale(0.98); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}
@keyframes thinking-breathe {
  0%, 100% { box-shadow: 0 2px 16px oklch(0.68 0.30 290 / 0.1); border-left-color: oklch(0.7 0.25 280); }
  50% { box-shadow: 0 2px 24px oklch(0.68 0.30 290 / 0.22); border-left-color: oklch(0.82 0.30 285); }
}
.thinking-card .thinking-header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 8px;
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: oklch(0.78 0.18 280);
}
.thinking-card .thinking-icon {
  width: 15px; height: 15px;
  animation: thinking-pulse 1.5s ease-in-out infinite;
  filter: drop-shadow(0 0 4px oklch(0.7 0.25 280 / 0.5));
}
@keyframes thinking-pulse {
  0%, 100% { opacity: 0.6; filter: drop-shadow(0 0 4px oklch(0.7 0.25 280 / 0.3)); }
  50% { opacity: 1; filter: drop-shadow(0 0 8px oklch(0.7 0.25 280 / 0.6)); }
}
.thinking-card.complete .thinking-icon {
  animation: none; opacity: 1;
  color: var(--green) !important;
  filter: drop-shadow(0 0 4px oklch(0.78 0.22 150 / 0.5));
}
.thinking-card.complete .thinking-header { color: var(--green); }
.thinking-card.complete {
  border-left-color: var(--green) !important;
  border-color: oklch(0.78 0.22 150 / 0.25);
  background: linear-gradient(135deg, oklch(0.10 0.04 150 / 0.3), oklch(0.07 0.02 170 / 0.2));
  box-shadow: 0 2px 16px oklch(0.78 0.22 150 / 0.12) !important;
}
.thinking-card .thinking-text {
  color: oklch(0.82 0.03 280);
  font-family: var(--font-mono);
  font-size: 11.5px;
  line-height: 1.7;
  max-height: 180px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: oklch(0.4 0.1 280) transparent;
  padding: 4px 0;
}
.thinking-card .thinking-text::-webkit-scrollbar { width: 4px; }
.thinking-card .thinking-text::-webkit-scrollbar-thumb { background: oklch(0.4 0.1 280); border-radius: 2px; }
.thinking-card .thinking-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
  padding-top: 6px;
  border-top: 1px solid oklch(0.55 0.18 280 / 0.12);
  font-size: 9.5px;
  color: oklch(0.55 0.08 280);
  font-family: var(--font-mono);
}
.thinking-card.collapsed .thinking-text { max-height: 45px; }
.thinking-card .thinking-toggle {
  cursor: pointer;
  color: oklch(0.65 0.18 280);
  font-size: 9.5px;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 2px 8px;
  border-radius: 4px;
  transition: all 0.2s;
}
.thinking-card .thinking-toggle:hover { color: oklch(0.85 0.18 280); background: oklch(0.65 0.18 280 / 0.1); }

.gpu-item {
  margin-bottom: 10px;
  padding: 10px;
  background: oklch(0.08 0.015 260 / 0.2);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  border-left: 3px solid var(--purple);
  box-shadow: 0 0 12px var(--purple-glow);
  transition: all 0.2s;
}
.gpu-item:hover {
  background: oklch(0.12 0.02 260 / 0.25);
  border-left-color: var(--cyan);
  box-shadow: 0 0 16px var(--cyan-glow);
  transform: translateX(2px);
}
.gpu-name {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-1);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 8px;
  text-shadow: 0 0 8px var(--purple-glow);
}
.gpu-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 10px var(--green-glow);
}
.gpu-metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
  font-size: 0.65rem;
  font-family: var(--font-mono);
}
.gpu-metric {
  padding: 4px;
  background: oklch(0.08 0.01 270 / 0.15);
  border-radius: 4px;
}
.gpu-metric-label {
  color: var(--text-3);
  font-size: 0.55rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 2px;
}
.gpu-metric-value {
  color: var(--text-1);
  font-weight: 700;
  font-size: 0.85rem;
  text-shadow: 0 0 8px currentColor;
}
.gpu-bar {
  height: 3px;
  background: oklch(0.12 0.01 270 / 0.15);
  border-radius: 2px;
  overflow: hidden;
  margin-top: 3px;
}
.gpu-bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s var(--spring-smooth);
  box-shadow: 0 0 8px currentColor;
}

/* ═══ SUB-AGENTS — COMPACT ═══ */
#forecast-card, #latency-card {
  display: none !important;
}
.agent-item {
  position: relative;
  padding: 6px 8px 18px 8px;
  background: oklch(0.08 0.015 270 / 0.2);
  border: 1px solid var(--glass-border);
  border-left: 3px solid var(--purple);
  border-radius: var(--radius-sm);
  margin-bottom: 6px;
  font-size: 0.7rem;
  transition: all 0.2s;
  box-shadow: 0 0 8px var(--purple-glow);
}
.agent-item:hover {
  background: oklch(0.13 0.02 270 / 0.3);
  transform: translateX(2px);
}
.agent-item.active {
  border-left-color: var(--green);
  box-shadow: 0 0 12px var(--green-glow);
}
.agent-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}
.agent-status-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 8px var(--green-glow);
}
.agent-label {
  font-weight: 700;
  color: var(--text-1);
  font-family: var(--font-mono);
  font-size: 0.65rem;
}
.agent-model {
  margin-left: auto;
  color: var(--text-3);
  font-size: 0.6rem;
}
.agent-task {
  color: var(--text-2);
  font-size: 0.65rem;
  margin-bottom: 3px;
  line-height: 1.2;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.agent-meta {
  display: flex;
  gap: 8px;
  font-size: 0.6rem;
  color: var(--text-3);
  font-family: var(--font-mono);
}
.agent-time {
  position: absolute;
  bottom: 3px;
  right: 6px;
  color: var(--text-3);
  font-size: 0.55rem;
  font-family: var(--font-mono);
  opacity: 0;
  transition: opacity 0.2s;
}
.agent-item:hover .agent-time {
  opacity: 1;
}

/* ═══ COST TRACKING — COMPACT ═══ */
/* cost-card removed — cost shown in header bar */
.cost-big {
  font-family: var(--font-mono);
  font-size: 2rem;
  font-weight: 800;
  color: var(--green);
  text-align: center;
  margin-bottom: 6px;
  text-shadow: 0 0 20px var(--green-glow);
  animation: cost-glow 3s ease-in-out infinite;
}
@keyframes cost-glow {
  0%, 100% { text-shadow: 0 0 15px var(--green-glow); }
  50% { text-shadow: 0 0 30px var(--green-glow); }
}
.cost-label {
  font-size: 0.65rem;
  color: var(--text-3);
  text-align: center;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* ═══ TOOL CALLS ═══ */

/* ═══ MISSIONS PANEL ═══ */
.mission-item {
  padding: 6px 8px;
  border-radius: 6px;
  background: oklch(0.12 0.02 270 / 0.15);
  margin-bottom: 6px;
  cursor: pointer;
  transition: all 0.2s;
  border-left: 3px solid transparent;
}
.mission-item:hover {
  background: oklch(0.16 0.03 270 / 0.2);
}
.mission-item.status-active { border-left-color: var(--green); }
.mission-item.status-done { border-left-color: var(--cyan); opacity: 0.6; }
.mission-item.status-paused { border-left-color: var(--amber); }
.mission-item.status-planned { border-left-color: var(--text-3); }
.mission-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
}
.mission-name {
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--text-1);
}
.mission-eta {
  font-size: 0.55rem;
  font-family: var(--font-mono);
  color: var(--text-3);
  white-space: nowrap;
}
.mission-desc {
  font-size: 0.6rem;
  color: var(--text-2);
  margin-top: 2px;
  line-height: 1.3;
}
.mission-progress {
  margin-top: 5px;
  height: 4px;
  background: oklch(0.12 0.015 270 / 0.3);
  border-radius: 3px;
  overflow: hidden;
  box-shadow: inset 0 1px 2px oklch(0 0 0 / 0.2);
}
.mission-progress-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: 0 0 8px currentColor, 0 0 3px currentColor;
  position: relative;
}
.mission-progress-fill::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 20px;
  height: 100%;
  background: linear-gradient(90deg, transparent, oklch(1 0 0 / 0.3));
  border-radius: 3px;
  animation: progress-shimmer 2s ease-in-out infinite;
}
@keyframes progress-shimmer {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}
.mission-tasks {
  margin-top: 4px;
  display: none;
  padding-left: 8px;
}
.mission-item.expanded .mission-tasks {
  display: block;
}
.mission-task {
  font-size: 0.58rem;
  font-family: var(--font-mono);
  color: var(--text-2);
  padding: 1px 0;
  display: flex;
  gap: 4px;
}
.mission-task .task-icon {
  flex-shrink: 0;
}
.tool-feed-item {
  padding: 5px 8px;
  margin-bottom: 4px;
  background: oklch(0.08 0.015 270 / 0.2);
  border-left: 3px solid var(--cyan);
  border-radius: var(--radius-sm);
  font-size: 0.65rem;
  animation: slide-in 0.15s var(--spring);
  box-shadow: 0 0 8px var(--cyan-glow);
}
@keyframes slide-in {
  from { opacity: 0; transform: translateX(-10px); }
  to { opacity: 1; transform: translateX(0); }
}
.tool-feed-item.success {
  border-left-color: var(--green);
  opacity: 0.7;
}
.tool-feed-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 2px;
}
.tool-feed-desc {
  font-weight: 600;
  color: var(--text-1);
  flex: 1;
}
.tool-feed-time {
  color: var(--text-ghost);
  font-size: 0.55rem;
  font-family: var(--font-mono);
}
.tool-feed-status {
  font-size: 0.8rem;
}

/* ═══ RICH CHAT INTERFACE v2 — Telegram Replacement ═══ */
#chat-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* Chat header bar */
.chat-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--glass-border);
  background: oklch(0.06 0.015 270 / 0.4);
  backdrop-filter: blur(12px);
  flex-shrink: 0;
}
.chat-header-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, oklch(0.68 0.30 290), oklch(0.55 0.25 260));
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  box-shadow: 0 0 12px oklch(0.68 0.30 290 / 0.4);
}
.chat-header-info { flex: 1; }
.chat-header-name {
  font-family: var(--font-display);
  font-weight: 700; font-size: 0.85rem;
  color: var(--text-1); letter-spacing: 0.5px;
}
.chat-header-status {
  font-size: 0.65rem; color: var(--green);
  display: flex; align-items: center; gap: 4px;
}
.chat-header-status::before {
  content: ''; width: 6px; height: 6px;
  border-radius: 50%; background: var(--green);
  box-shadow: 0 0 6px var(--green);
  animation: status-pulse 2s infinite;
}
@keyframes status-pulse {
  0%, 100% { opacity: 1; } 50% { opacity: 0.5; }
}
.chat-header-actions { display: flex; gap: 6px; }
.chat-header-actions button {
  width: 30px; height: 30px; border-radius: 8px;
  border: 1px solid var(--glass-border);
  background: oklch(0.10 0.02 270 / 0.3);
  color: var(--text-2); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem; transition: all 0.2s;
}
.chat-header-actions button:hover {
  background: oklch(0.68 0.30 290 / 0.2);
  border-color: oklch(0.68 0.30 290 / 0.4);
  color: var(--text-1);
}

/* Messages area */
#chat-messages {
  flex: 1; overflow-y: auto; overflow-x: hidden;
  padding: 16px 20px; display: flex; flex-direction: column;
  gap: 16px; min-height: 0; scroll-behavior: smooth;
  scrollbar-width: thin;
  scrollbar-color: oklch(0.25 0.03 270 / 0.3) transparent;
}
#chat-messages .chat-msg-wrap.grouped { margin-top: -12px; }
#chat-messages::-webkit-scrollbar { width: 4px; }
#chat-messages::-webkit-scrollbar-track { background: transparent; }
#chat-messages::-webkit-scrollbar-thumb {
  background: oklch(0.30 0.04 270 / 0.4); border-radius: 2px;
}

/* ═══ CHAT — ChatGPT/Grok-Style Conversation UI ═══ */

/* Date separator */
.chat-date-sep { text-align: center; padding: 16px 0 12px; }
.chat-date-sep span {
  background: oklch(0.10 0.02 270 / 0.6);
  padding: 5px 16px; border-radius: 20px;
  font-size: 0.65rem; color: var(--text-3);
  font-family: var(--font-mono); letter-spacing: 1.2px;
  text-transform: uppercase;
  border: 1px solid oklch(0.22 0.03 270 / 0.25);
  backdrop-filter: blur(8px);
}

/* ── Message Wrapper ── */
.chat-msg-wrap {
  display: flex; gap: 12px; max-width: 100%;
  animation: msg-enter 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative; padding: 0 4px;
}
.chat-msg-wrap.user {
  align-self: flex-end; flex-direction: row-reverse;
  max-width: 78%;
}
.chat-msg-wrap.ai {
  align-self: flex-start; max-width: 100%;
}
/* Grouped messages — tighter spacing, no avatar repeat */
.chat-msg-wrap.grouped { margin-top: -4px; }
.chat-msg-wrap.grouped .chat-avatar { visibility: hidden; }
.chat-msg-wrap.grouped .chat-sender { display: none; }

@keyframes msg-enter {
  0% { opacity: 0; transform: translateY(16px) scale(0.97); }
  60% { opacity: 1; transform: translateY(-2px) scale(1.005); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

/* ── Avatar ── */
.chat-avatar {
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.8rem; flex-shrink: 0; margin-top: 4px;
}
.chat-msg-wrap.ai .chat-avatar {
  background: linear-gradient(135deg, oklch(0.55 0.25 290 / 0.5), oklch(0.40 0.22 260 / 0.5));
  border: 1px solid oklch(0.60 0.25 290 / 0.4);
  box-shadow: 0 0 10px oklch(0.60 0.25 290 / 0.15);
}
.chat-msg-wrap.user .chat-avatar { display: none; }

/* ── Bubble — AI (ChatGPT-style: no bubble, clean text) ── */
.chat-bubble {
  position: relative; min-width: 40px;
  word-wrap: break-word; overflow-wrap: break-word;
}
.chat-bubble.ai {
  background: none; border: none;
  padding: 2px 0 8px 0; color: var(--text-1);
  font-size: 0.92rem; line-height: 1.72;
}
/* Sender label for AI messages */
.chat-sender {
  font-size: 0.7rem; font-weight: 700; color: var(--purple);
  margin-bottom: 4px; letter-spacing: 0.3px;
  font-family: var(--font-display);
}
/* Bottom divider for AI messages */
.chat-msg-wrap.ai::after {
  content: ''; position: absolute; bottom: -8px; left: 40px; right: 0;
  height: 1px;
  background: linear-gradient(90deg, oklch(0.25 0.04 280 / 0.3), transparent 80%);
}
.chat-msg-wrap.ai:last-child::after,
.chat-msg-wrap.ai + .chat-msg-wrap.user ~ .chat-msg-wrap.ai:first-of-type::after { display: none; }

/* ── Bubble — User (right-aligned gradient bubble) ── */
.chat-bubble.user {
  background: linear-gradient(135deg, oklch(0.22 0.12 280 / 0.65), oklch(0.18 0.10 295 / 0.65));
  border: 1px solid oklch(0.50 0.18 280 / 0.25);
  border-radius: 18px; border-bottom-right-radius: 4px;
  padding: 10px 16px; color: var(--text-1);
  font-size: 0.88rem; line-height: 1.6;
  box-shadow: 0 2px 12px oklch(0.60 0.25 290 / 0.08);
  backdrop-filter: blur(4px);
}
.chat-bubble.user:hover {
  box-shadow: 0 4px 20px oklch(0.60 0.25 290 / 0.15);
  border-color: oklch(0.55 0.18 280 / 0.35);
}

/* ── Hover Actions ── */
.chat-msg-actions {
  position: absolute; top: 0px;
  display: flex; gap: 1px; opacity: 0; transition: opacity 0.15s;
  z-index: 10; background: oklch(0.10 0.025 270 / 0.92);
  backdrop-filter: blur(12px); border-radius: 8px;
  border: 1px solid oklch(0.25 0.04 270 / 0.3); padding: 2px;
  box-shadow: 0 4px 12px oklch(0 0 0 / 0.3);
}
.chat-msg-wrap.ai .chat-msg-actions { right: 0; }
.chat-msg-wrap.user .chat-msg-actions { left: 0; }
.chat-msg-wrap:hover .chat-msg-actions { opacity: 1; }
.chat-msg-actions button {
  width: 28px; height: 28px; border: none;
  background: transparent; color: var(--text-3);
  cursor: pointer; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.72rem; transition: all 0.15s;
}
.chat-msg-actions button:hover {
  background: oklch(0.60 0.25 290 / 0.15); color: var(--text-1);
}

/* ── Reply Quote ── */
.chat-reply-quote {
  padding: 6px 12px; margin-bottom: 8px;
  border-left: 3px solid var(--purple);
  background: oklch(0.10 0.02 270 / 0.25);
  border-radius: 0 8px 8px 0; font-size: 0.75rem; color: var(--text-3);
  max-height: 44px; overflow: hidden; cursor: pointer; transition: background 0.2s;
}
.chat-reply-quote:hover { background: oklch(0.14 0.03 270 / 0.3); }
.chat-reply-quote .reply-author {
  color: var(--purple); font-weight: 700; font-size: 0.65rem;
  margin-bottom: 2px;
}

/* ── Message Meta ── */
.chat-meta {
  display: flex; align-items: center; justify-content: flex-end;
  gap: 6px; margin-top: 6px; padding-top: 2px;
}
.chat-time {
  font-size: 0.6rem; color: oklch(0.50 0.03 270); font-family: var(--font-mono);
}
.chat-status { font-size: 0.6rem; }
.chat-status.delivered { color: oklch(0.55 0.15 290 / 0.8); }
.chat-status.read { color: var(--cyan); }

/* ── Markdown Typography (ChatGPT-quality) ── */
.chat-bubble .chat-content { overflow-wrap: break-word; position: relative; }
.chat-content-collapsed {
  max-height: 120px;
  overflow: hidden;
  -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  transition: max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.chat-content-collapsed + .chat-collapse-toggle { margin-top: -8px; }
.chat-collapse-toggle {
  display: block;
  width: 100%;
  padding: 6px 0;
  background: none;
  border: none;
  color: var(--purple);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 600;
  cursor: pointer;
  text-align: center;
  letter-spacing: 0.5px;
  transition: color 0.2s;
}
.chat-collapse-toggle:hover { color: oklch(0.78 0.30 290); }

/* ═══ SLASH COMMANDS DROPDOWN ═══ */
.slash-menu {
  display: none;
  position: absolute;
  bottom: 100%;
  left: 12px;
  right: 12px;
  margin-bottom: 4px;
  background: oklch(0.10 0.02 270 / 0.95);
  backdrop-filter: blur(16px);
  border: 1px solid oklch(0.38 0.06 270 / 0.3);
  border-radius: 12px;
  padding: 6px;
  max-height: 240px;
  overflow-y: auto;
  z-index: 100;
  box-shadow: 0 -8px 30px oklch(0 0 0 / 0.4);
  animation: slash-appear 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}
.slash-menu.open { display: block; }
@keyframes slash-appear {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
.slash-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.15s;
}
.slash-item:hover, .slash-item.active {
  background: oklch(0.68 0.30 290 / 0.12);
}
.slash-item-icon {
  font-size: 1rem;
  width: 28px;
  text-align: center;
}
.slash-item-info { flex: 1; min-width: 0; }
.slash-item-name {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text-1);
}
.slash-item-desc {
  font-size: 0.6rem;
  color: var(--text-3);
  margin-top: 1px;
}
.chat-bubble .chat-content > *:first-child { margin-top: 0; }
.chat-bubble .chat-content > *:last-child { margin-bottom: 0; }
.chat-bubble .chat-content h1,
.chat-bubble .chat-content h2,
.chat-bubble .chat-content h3,
.chat-bubble .chat-content h4 {
  font-family: var(--font-display); color: var(--text-1); line-height: 1.35;
  margin: 16px 0 8px;
}
.chat-bubble .chat-content h1 { font-size: 1.2rem; font-weight: 700; border-bottom: 1px solid oklch(0.22 0.03 270 / 0.3); padding-bottom: 6px; }
.chat-bubble .chat-content h2 { font-size: 1.05rem; font-weight: 700; }
.chat-bubble .chat-content h3 { font-size: 0.95rem; font-weight: 600; color: var(--purple); }
.chat-bubble .chat-content h4 { font-size: 0.88rem; font-weight: 600; }
.chat-bubble .chat-content p { margin: 8px 0; }
.chat-bubble .chat-content strong { color: var(--text-1); font-weight: 700; }
.chat-bubble .chat-content em { font-style: italic; color: oklch(0.82 0.06 270); }
.chat-bubble .chat-content a {
  color: var(--cyan); text-decoration: none;
  border-bottom: 1px solid oklch(0.78 0.22 195 / 0.25);
  transition: all 0.2s;
}
.chat-bubble .chat-content a:hover {
  color: oklch(0.88 0.18 195);
  border-bottom-color: oklch(0.78 0.22 195 / 0.5);
}
.chat-bubble .chat-content blockquote {
  border-left: 3px solid oklch(0.55 0.18 290 / 0.6); margin: 12px 0;
  padding: 10px 16px; background: oklch(0.08 0.015 270 / 0.3);
  border-radius: 0 10px 10px 0; color: var(--text-2);
}
.chat-bubble .chat-content ul, .chat-bubble .chat-content ol {
  margin: 8px 0; padding-left: 24px;
}
.chat-bubble .chat-content li { margin: 4px 0; line-height: 1.6; }
.chat-bubble .chat-content li::marker { color: oklch(0.60 0.20 290 / 0.7); }
.chat-bubble .chat-content hr {
  border: none; height: 1px;
  background: linear-gradient(90deg, transparent, oklch(0.35 0.05 270 / 0.4), transparent);
  margin: 12px 0;
}

/* ── Inline Code ── */
.chat-bubble .chat-content code:not(pre code) {
  background: oklch(0.13 0.03 270 / 0.55);
  padding: 2px 8px; border-radius: 6px;
  font-size: 0.82rem; font-family: var(--font-mono);
  color: oklch(0.85 0.14 290);
  border: 1px solid oklch(0.25 0.04 280 / 0.25);
}

/* ── Code Blocks (gorgeous dark editor style) ── */
.chat-code-block {
  margin: 12px 0; border-radius: 12px; overflow: hidden;
  border: 1px solid oklch(0.20 0.03 270 / 0.35);
  background: oklch(0.06 0.01 270 / 0.8);
  box-shadow: 0 2px 8px oklch(0 0 0 / 0.15);
}
.chat-bubble .chat-content pre {
  margin: 0; border-radius: 0; border: none;
  background: transparent !important;
  position: relative; overflow: visible;
}
.chat-bubble .chat-content pre code {
  display: block; padding: 16px 18px; overflow-x: auto;
  font-size: 0.82rem; font-family: var(--font-mono);
  line-height: 1.65; tab-size: 2;
  scrollbar-width: thin;
  scrollbar-color: oklch(0.30 0.04 280 / 0.3) transparent;
  white-space: pre; word-wrap: normal;
  max-height: 500px; overflow-y: auto;
}
.chat-bubble .chat-content pre code::-webkit-scrollbar { height: 6px; width: 6px; }
.chat-bubble .chat-content pre code::-webkit-scrollbar-track { background: transparent; }
.chat-bubble .chat-content pre code::-webkit-scrollbar-thumb { background: oklch(0.30 0.05 280 / 0.4); border-radius: 3px; }
.chat-bubble .chat-content pre code::-webkit-scrollbar-thumb:hover { background: oklch(0.40 0.06 280 / 0.5); }
/* Standalone pre */
.chat-bubble .chat-content pre:not(.chat-code-block pre) {
  margin: 12px 0; border-radius: 12px; overflow: hidden;
  border: 1px solid oklch(0.20 0.03 270 / 0.35);
  background: oklch(0.06 0.01 270 / 0.8) !important;
  box-shadow: 0 2px 8px oklch(0 0 0 / 0.15);
}
.chat-bubble .chat-content pre:not(.chat-code-block pre) code { border-radius: 12px; }
.chat-code-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 14px;
  background: oklch(0.08 0.015 270 / 0.6);
  border-bottom: 1px solid oklch(0.18 0.02 270 / 0.3);
  font-size: 0.68rem; font-family: var(--font-mono); color: var(--text-3);
  text-transform: lowercase; letter-spacing: 0.5px;
}
.chat-code-copy {
  border: none; background: oklch(0.15 0.02 270 / 0.4);
  color: var(--text-3); cursor: pointer;
  padding: 4px 12px; border-radius: 6px;
  font-size: 0.62rem; font-family: var(--font-mono); transition: all 0.2s;
}
.chat-code-copy:hover { background: var(--purple); color: white; box-shadow: 0 0 8px oklch(0.60 0.25 290 / 0.3); }
.chat-code-copy.copied { background: var(--green); color: oklch(0.10 0.02 145); }

/* ── Tables ── */
.chat-bubble .chat-content table {
  width: 100%; border-collapse: collapse; margin: 12px 0;
  font-size: 0.78rem; font-family: var(--font-mono);
  border: 1px solid oklch(0.20 0.02 270 / 0.25);
  border-radius: 8px; overflow: hidden;
}
.chat-bubble .chat-content th {
  background: oklch(0.10 0.02 270 / 0.4); color: var(--purple);
  padding: 8px 12px; text-align: left; font-weight: 700;
  border-bottom: 2px solid oklch(0.55 0.20 290 / 0.2);
  font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px;
}
.chat-bubble .chat-content td {
  padding: 6px 12px;
  border-bottom: 1px solid oklch(0.18 0.02 270 / 0.15); color: var(--text-2);
}
.chat-bubble .chat-content tr:hover td { background: oklch(0.12 0.02 270 / 0.12); }

/* Task lists */
.chat-bubble .chat-content input[type="checkbox"] {
  accent-color: var(--purple); margin-right: 6px;
}

/* ── Media ── */
.chat-bubble .chat-media-img {
  max-width: 100%; max-height: 400px; border-radius: 12px;
  margin: 8px 0; cursor: pointer; transition: all 0.3s;
  border: 1px solid oklch(0.18 0.02 270 / 0.25);
}
.chat-bubble .chat-media-img:hover {
  box-shadow: 0 4px 24px oklch(0.60 0.25 290 / 0.15);
  transform: scale(1.01);
}
.chat-bubble video { max-width: 100%; border-radius: 12px; margin: 8px 0; }
.chat-bubble audio {
  width: 100%; max-height: 40px; margin: 8px 0;
  filter: hue-rotate(250deg) brightness(0.7);
}

/* ── File Card ── */
.chat-file-card {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px;
  background: oklch(0.08 0.015 270 / 0.35);
  border: 1px solid oklch(0.22 0.03 270 / 0.25);
  border-radius: 12px; margin: 8px 0; cursor: pointer; transition: all 0.2s;
}
.chat-file-card:hover { background: oklch(0.11 0.02 270 / 0.4); border-color: var(--cyan); }
.chat-file-icon {
  width: 40px; height: 40px; border-radius: 10px;
  background: linear-gradient(135deg, oklch(0.78 0.22 195 / 0.15), oklch(0.60 0.18 210 / 0.15));
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; flex-shrink: 0;
}
.chat-file-info { flex: 1; min-width: 0; }
.chat-file-name {
  font-size: 0.78rem; color: var(--cyan); font-weight: 600;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.chat-file-size { font-size: 0.62rem; color: var(--text-3); font-family: var(--font-mono); }

/* ── HTML/SVG Render (Artifact-style) ── */
.chat-html-render {
  margin: 12px 0; padding: 12px;
  background: oklch(0.06 0.01 270 / 0.4);
  border: 1px solid oklch(0.22 0.03 270 / 0.3);
  border-radius: 12px; overflow: hidden;
}
.chat-html-render iframe {
  width: 100%; border: none; border-radius: 8px;
  min-height: 120px; background: white;
}
.chat-svg-render {
  margin: 10px 0; padding: 16px; display: flex; justify-content: center;
  background: oklch(0.06 0.01 270 / 0.3);
  border: 1px solid oklch(0.22 0.03 270 / 0.2);
  border-radius: 12px;
}
.chat-svg-render svg { max-width: 100%; height: auto; }

/* ── Typing Indicator ── */
.chat-typing-indicator {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 0; animation: msg-enter 0.2s ease;
}
.chat-typing-dots {
  display: flex; gap: 5px; padding: 12px 16px;
  background: oklch(0.08 0.015 270 / 0.35);
  border: 1px solid oklch(0.22 0.03 270 / 0.2);
  border-radius: 18px; border-bottom-left-radius: 4px;
}
.chat-typing-dots span {
  width: 7px; height: 7px; background: oklch(0.55 0.20 290);
  border-radius: 50%; animation: typing-bounce 1.4s infinite;
  box-shadow: 0 0 6px oklch(0.55 0.20 290 / 0.3);
}
.chat-typing-dots span:nth-child(2) { animation-delay: 0.15s; }
.chat-typing-dots span:nth-child(3) { animation-delay: 0.3s; }
@keyframes typing-bounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.3; }
  30% { transform: translateY(-6px); opacity: 1; }
}

/* ── Streaming Cursor ── */
.chat-cursor {
  display: inline-block; width: 2px; height: 1.1em;
  background: var(--purple); animation: cursor-blink 0.8s step-end infinite;
  vertical-align: text-bottom; margin-left: 2px;
  box-shadow: 0 0 6px oklch(0.60 0.25 290 / 0.4);
  border-radius: 1px;
}
@keyframes cursor-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

/* ── Thinking Bar ── */
.chat-thinking-bar {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px;
  background: oklch(0.08 0.015 270 / 0.25);
  border-radius: 20px;
  border: 1px solid oklch(0.55 0.20 290 / 0.12);
  margin: 6px 0; font-size: 0.72rem; color: var(--text-3);
  cursor: pointer; transition: all 0.2s;
}
.chat-thinking-bar:hover {
  background: oklch(0.11 0.02 270 / 0.35);
  border-color: oklch(0.55 0.20 290 / 0.25);
}
.chat-thinking-bar .brain-icon { animation: brain-pulse 1.5s infinite; }
@keyframes brain-pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}
.chat-thinking-content {
  max-height: 0; overflow: hidden; transition: max-height 0.3s ease;
  font-size: 0.72rem; color: var(--text-3); font-family: var(--font-mono);
  line-height: 1.5; padding: 0 14px;
  background: oklch(0.06 0.01 270 / 0.25); border-radius: 0 0 10px 10px;
  margin-top: -4px;
}
.chat-thinking-content.expanded {
  max-height: 300px; overflow-y: auto; padding: 10px 14px;
}

/* ── Tool Call (inline pill) ── */
.chat-tool-call {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 12px;
  background: oklch(0.78 0.22 195 / 0.06);
  border: 1px solid oklch(0.78 0.22 195 / 0.12);
  border-radius: 20px; margin: 3px 0;
  font-size: 0.68rem; font-family: var(--font-mono);
  color: oklch(0.70 0.18 195);
}
.chat-tool-call .tool-spinner {
  width: 10px; height: 10px;
  border: 1.5px solid oklch(0.78 0.22 195 / 0.2);
  border-top-color: var(--cyan); border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Scroll to Bottom FAB ── */
#chat-scroll-btn {
  position: absolute; bottom: 75px; right: 16px;
  width: 38px; height: 38px; border-radius: 50%;
  border: 1px solid oklch(0.55 0.20 290 / 0.25);
  background: oklch(0.08 0.02 270 / 0.9);
  backdrop-filter: blur(12px); color: var(--purple);
  cursor: pointer; display: none; align-items: center;
  justify-content: center; font-size: 1rem; z-index: 20;
  transition: all 0.2s; box-shadow: 0 4px 16px oklch(0 0 0 / 0.35);
}
#chat-scroll-btn:hover {
  background: oklch(0.55 0.20 290 / 0.9); color: white;
  box-shadow: 0 0 20px oklch(0.55 0.20 290 / 0.3);
}
#chat-scroll-btn .unread-badge {
  position: absolute; top: -4px; right: -4px;
  background: oklch(0.60 0.25 25); color: white;
  font-size: 0.55rem; font-weight: 700;
  min-width: 16px; height: 16px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center; padding: 0 4px;
}

/* ── Reply Bar ── */
#chat-reply-bar {
  display: none; align-items: center; gap: 10px;
  padding: 10px 14px; background: oklch(0.07 0.015 270 / 0.4);
  border-top: 1px solid oklch(0.55 0.20 290 / 0.15);
  border-left: 3px solid var(--purple);
  font-size: 0.75rem; color: var(--text-2);
}
#chat-reply-bar.active { display: flex; }
#chat-reply-bar .reply-text { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
#chat-reply-bar .reply-close {
  cursor: pointer; color: var(--text-3); font-size: 1rem; transition: color 0.2s;
}
#chat-reply-bar .reply-close:hover { color: var(--red); }

/* ── Input Area (polished) ── */
#chat-input-area {
  border-top: 1px solid oklch(0.22 0.03 270 / 0.3);
  background: linear-gradient(180deg, oklch(0.06 0.012 270 / 0.5), oklch(0.04 0.008 270 / 0.6));
  backdrop-filter: blur(12px);
  padding: 10px 12px; display: flex !important; flex-direction: column;
  gap: 0; flex-shrink: 0 !important; min-height: 58px;
}
#chat-input-row { display: flex; align-items: flex-end; gap: 8px; }
#chat-textarea {
  flex: 1; background: oklch(0.08 0.015 270 / 0.35);
  border: 1px solid oklch(0.25 0.03 270 / 0.25);
  border-radius: 20px; padding: 10px 16px;
  color: var(--text-1); font-size: 0.88rem;
  font-family: var(--font-body); outline: none;
  resize: none; min-height: 42px; max-height: 200px;
  line-height: 1.5; transition: border-color 0.2s, box-shadow 0.2s;
  overflow-y: auto; scrollbar-width: thin;
  scrollbar-color: oklch(0.25 0.03 270 / 0.3) transparent;
}
#chat-textarea:focus {
  border-color: oklch(0.60 0.22 290 / 0.6);
  box-shadow: 0 0 20px oklch(0.60 0.25 290 / 0.15), 0 0 40px oklch(0.55 0.20 290 / 0.06), inset 0 0 8px oklch(0.55 0.18 290 / 0.04);
  background: oklch(0.09 0.018 270 / 0.5);
}
#chat-textarea::placeholder { color: oklch(0.40 0.03 270); }
.chat-input-btn {
  width: 38px; height: 38px; border-radius: 50%; border: none;
  background: oklch(0.10 0.02 270 / 0.3); color: var(--text-2);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; font-size: 1.05rem; flex-shrink: 0;
}
.chat-input-btn:hover { background: oklch(0.55 0.20 290 / 0.15); color: var(--text-1); }
#chat-send-btn {
  background: linear-gradient(135deg, oklch(0.55 0.25 290), oklch(0.45 0.22 260));
  color: white; box-shadow: 0 2px 12px oklch(0.55 0.25 290 / 0.25);
}
#chat-send-btn:hover {
  box-shadow: 0 4px 20px oklch(0.55 0.25 290 / 0.4); transform: scale(1.05);
}
#chat-send-btn.has-text {
  animation: send-pulse 2s ease-in-out infinite;
}
@keyframes send-pulse {
  0%, 100% { box-shadow: 0 2px 12px oklch(0.55 0.25 290 / 0.25); }
  50% { box-shadow: 0 2px 20px oklch(0.55 0.25 290 / 0.45); }
}
.chat-input-btn.recording {
  background: oklch(0.50 0.22 25) !important;
  color: white !important; animation: pulse-record 1s infinite;
}
@keyframes pulse-record {
  0%, 100% { box-shadow: 0 0 0 0 oklch(0.50 0.22 25 / 0.4); }
  50% { box-shadow: 0 0 0 8px oklch(0.50 0.22 25 / 0); }
}

/* ── Drag-drop ── */
#chat-drop-overlay {
  position: absolute; inset: 0;
  background: oklch(0.05 0.02 270 / 0.88);
  backdrop-filter: blur(12px); display: none;
  align-items: center; justify-content: center;
  z-index: 50; border-radius: var(--radius);
}
#chat-drop-overlay.active { display: flex; }
.chat-drop-content { text-align: center; color: var(--purple); }
.chat-drop-icon { font-size: 3.5rem; margin-bottom: 14px; animation: drop-bounce 1s infinite; }
@keyframes drop-bounce {
  0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); }
}
.chat-drop-text { font-size: 0.95rem; font-weight: 600; letter-spacing: 1px; }
.chat-drop-sub { font-size: 0.72rem; color: var(--text-3); margin-top: 6px; }

/* ── Stream Stats ── */
.chat-stream-stats {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 2px 10px;
  background: oklch(0.08 0.01 270 / 0.25); border-radius: 8px;
  font-size: 0.58rem; font-family: var(--font-mono); color: oklch(0.50 0.03 270);
}

/* ── Lightbox ── */
#chat-lightbox {
  position: fixed; inset: 0;
  background: oklch(0 0 0 / 0.9);
  backdrop-filter: blur(20px);
  display: none; align-items: center; justify-content: center;
  z-index: 10000; cursor: zoom-out;
}
#chat-lightbox.active { display: flex; }
#chat-lightbox img {
  max-width: 92vw; max-height: 92vh; border-radius: 12px;
  box-shadow: 0 0 60px oklch(0.55 0.20 290 / 0.2);
}
#chat-lightbox .lb-close {
  position: absolute; top: 20px; right: 20px;
  width: 42px; height: 42px; border-radius: 50%;
  border: 1px solid oklch(1 0 0 / 0.15);
  background: oklch(0.12 0.02 270 / 0.7); color: white;
  cursor: pointer; display: flex; align-items: center;
  justify-content: center; font-size: 1.4rem;
  backdrop-filter: blur(8px);
}

/* ── Search ── */
#chat-search-bar {
  position: absolute; top: 0; left: 0; right: 0;
  background: oklch(0.07 0.015 270 / 0.95);
  backdrop-filter: blur(16px); padding: 10px 14px;
  display: none; align-items: center; gap: 10px;
  z-index: 30; border-bottom: 1px solid oklch(0.20 0.03 270 / 0.25);
}
#chat-search-bar.active { display: flex; }
#chat-search-input {
  flex: 1; background: oklch(0.10 0.02 270 / 0.3);
  border: 1px solid oklch(0.25 0.03 270 / 0.25);
  border-radius: 10px; padding: 8px 14px;
  color: var(--text-1); font-size: 0.82rem;
  font-family: var(--font-body); outline: none;
}
#chat-search-input:focus { border-color: oklch(0.55 0.18 290 / 0.4); }
.chat-search-count { font-size: 0.68rem; color: var(--text-3); font-family: var(--font-mono); white-space: nowrap; }
.chat-search-close {
  cursor: pointer; color: var(--text-3); font-size: 1rem;
  transition: color 0.2s; border: none; background: none;
}
.chat-search-close:hover { color: var(--text-1); }

/* Old compat */
#chat-input-bar { display: none; }

/* ═══ NVTOP — GPU PROCESS MONITOR ═══ */
.nvtop-gpu-card {
  margin-bottom: 8px;
  padding: 8px;
  background: oklch(0.08 0.015 270 / 0.2);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
}
.nvtop-gpu-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--text-1);
}
.nvtop-metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
  font-size: 0.65rem;
  font-family: var(--font-mono);
}
.nvtop-metric {
  padding: 4px;
  background: oklch(0.08 0.01 270 / 0.15);
  border-radius: 4px;
}
.nvtop-metric-label {
  color: var(--text-3);
  font-size: 0.55rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 2px;
}
.nvtop-metric-value {
  color: var(--text-1);
  font-weight: 700;
  font-size: 0.75rem;
  text-shadow: 0 0 8px currentColor;
}
.nvtop-metric-bar {
  height: 3px;
  background: oklch(0.12 0.01 270 / 0.15);
  border-radius: 2px;
  overflow: hidden;
  margin-top: 2px;
}
.nvtop-metric-bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s var(--spring-smooth);
  box-shadow: 0 0 6px currentColor;
}
.nvtop-process-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 4px 6px;
  background: oklch(0.08 0.01 270 / 0.15);
  border-left: 2px solid var(--cyan);
  border-radius: 4px;
  margin-bottom: 4px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  transition: all 0.2s;
}
.nvtop-process-row:hover {
  background: oklch(0.12 0.015 270 / 0.4);
  transform: translateX(2px);
}
.nvtop-process-pid {
  color: var(--text-3);
  min-width: 40px;
}
.nvtop-process-name {
  flex: 1;
  color: var(--text-1);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.nvtop-process-mem {
  color: var(--cyan);
  font-weight: 700;
  min-width: 60px;
  text-align: right;
  text-shadow: 0 0 8px var(--cyan-glow);
}

/* ═══ TOP — SYSTEM PROCESS MONITOR ═══ */
/* top-card merged into nvtop-card */
.top-system-info {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
  margin-bottom: 8px;
  padding: 6px;
  background: oklch(0.08 0.015 270 / 0.2);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
}
.top-info-item {
  font-family: var(--font-mono);
  font-size: 0.6rem;
}
.top-info-label {
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 2px;
}
.top-info-value {
  font-size: 0.75rem;
  color: var(--text-1);
  font-weight: 700;
}
.top-process-header {
  display: grid;
  grid-template-columns: 50px 60px 50px 50px 1fr;
  gap: 6px;
  padding: 4px 6px;
  background: oklch(0.12 0.015 270 / 0.7);
  border-radius: 4px;
  font-weight: 700;
  color: var(--text-2);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-size: 0.55rem;
  margin-bottom: 4px;
  font-family: var(--font-mono);
}
.top-process-row {
  display: grid;
  grid-template-columns: 50px 60px 50px 50px 1fr;
  gap: 6px;
  padding: 4px 6px;
  background: oklch(0.08 0.01 270 / 0.15);
  border-left: 2px solid var(--purple);
  border-radius: 4px;
  margin-bottom: 3px;
  transition: all 0.2s;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 0.6rem;
}
.top-process-row:hover {
  background: oklch(0.12 0.015 270 / 0.4);
  transform: translateX(2px);
}
.top-process-pid {
  color: var(--text-3);
}
.top-process-user {
  color: var(--text-2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.top-process-cpu {
  color: var(--purple);
  font-weight: 700;
  text-shadow: 0 0 8px var(--purple-glow);
}
.top-process-mem {
  color: var(--blue);
  font-weight: 700;
}
.top-process-cmd {
  color: var(--text-1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ═══ COMMAND BAR (⌘K) ═══ */
.cmd-overlay {
  position: fixed;
  inset: 0;
  z-index: 9998;
  background: oklch(0 0 0 / 0.55);
  backdrop-filter: blur(12px) saturate(120%);
  display: none;
  place-items: start center;
  padding-top: 16vh;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.cmd-overlay.visible {
  display: grid;
  animation: cmd-overlay-in 0.2s ease forwards;
}
@keyframes cmd-overlay-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.cmd-panel {
  width: min(680px, 92vw);
  background: oklch(0.12 0.02 270 / 0.85);
  backdrop-filter: blur(40px) saturate(180%);
  border: 1px solid oklch(0.35 0.05 270 / 0.4);
  border-radius: var(--radius-lg);
  box-shadow:
    0 0 0 1px oklch(0.25 0.03 270 / 0.5),
    0 24px 80px oklch(0 0 0 / 0.65),
    0 0 60px oklch(0.68 0.30 290 / 0.08);
  overflow: hidden;
  animation: cmd-enter 0.25s var(--spring);
}
@keyframes cmd-enter {
  from { opacity: 0; transform: scale(0.95) translateY(-12px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.cmd-input-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 20px;
  border-bottom: 1px solid oklch(0.30 0.03 270 / 0.4);
}
.cmd-search-icon {
  font-size: 1.2rem;
  opacity: 0.5;
}
.cmd-input {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text-1);
  font-size: 1.1rem;
  font-family: var(--font-display);
  font-weight: 500;
  letter-spacing: -0.3px;
}
.cmd-input::placeholder { color: var(--text-ghost); }
.cmd-input:focus { outline: none; }
.cmd-esc-hint {
  padding: 3px 8px;
  border-radius: 5px;
  background: oklch(0.18 0.02 270 / 0.6);
  border: 1px solid oklch(0.30 0.03 270 / 0.4);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-3);
}

.cmd-section-label {
  padding: 8px 20px 4px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-3);
}

.cmd-results {
  max-height: 420px;
  overflow-y: auto;
  padding: 6px 8px 8px;
}
.cmd-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 14px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: all 0.1s ease;
  margin-bottom: 2px;
}
.cmd-item.selected {
  background: oklch(0.68 0.30 290 / 0.12);
  border: 1px solid oklch(0.68 0.30 290 / 0.2);
}
.cmd-item:not(.selected) {
  border: 1px solid transparent;
}
.cmd-item:hover:not(.selected) {
  background: oklch(0.20 0.02 270 / 0.4);
}
.cmd-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.15rem;
  flex-shrink: 0;
}
.cmd-icon.nav { background: oklch(0.68 0.30 290 / 0.15); }
.cmd-icon.action { background: oklch(0.78 0.22 195 / 0.15); }
.cmd-icon.system { background: oklch(0.75 0.24 145 / 0.15); }
.cmd-text { flex: 1; min-width: 0; }
.cmd-name {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-1);
  font-family: var(--font-display);
}
.cmd-name mark {
  background: oklch(0.68 0.30 290 / 0.3);
  color: var(--text-1);
  border-radius: 2px;
  padding: 0 1px;
}
.cmd-desc {
  font-size: 0.7rem;
  color: var(--text-3);
  margin-top: 1px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cmd-key {
  padding: 3px 8px;
  border-radius: 5px;
  background: oklch(0.15 0.02 270 / 0.5);
  border: 1px solid oklch(0.30 0.03 270 / 0.3);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-3);
  flex-shrink: 0;
}
.cmd-empty {
  padding: 32px 20px;
  text-align: center;
  color: var(--text-3);
  font-size: 0.85rem;
}
.cmd-footer {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 20px;
  border-top: 1px solid oklch(0.30 0.03 270 / 0.3);
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-ghost);
}
.cmd-footer kbd {
  padding: 2px 6px;
  border-radius: 4px;
  background: oklch(0.18 0.02 270 / 0.5);
  border: 1px solid oklch(0.30 0.03 270 / 0.3);
  font-family: inherit;
  margin: 0 2px;
}

/* ⌘K hint button in topbar */
.cmdk-hint {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  background: oklch(0.12 0.02 270 / 0.3);
  border: 1px solid oklch(0.30 0.03 270 / 0.3);
  border-radius: 8px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-3);
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
}
.cmdk-hint:hover {
  background: oklch(0.18 0.03 270 / 0.4);
  border-color: var(--purple);
  color: var(--text-2);
  box-shadow: 0 0 12px oklch(0.68 0.30 290 / 0.15);
}

/* ═══ TOAST ═══ */
.toast-container {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 10000;
  display: flex;
  flex-direction: column;
  gap: 10px;
  pointer-events: none;
}
.toast {
  padding: 14px 20px;
  background: var(--elevated);
  backdrop-filter: blur(20px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  font-size: 0.9rem;
  box-shadow: 0 12px 40px oklch(0 0 0 / 0.5);
  pointer-events: auto;
  display: flex;
  align-items: center;
  gap: 10px;
  animation: toast-slide 0.15s var(--spring);
}
@keyframes toast-slide {
  from { opacity: 0; transform: translateX(100%); }
  to { opacity: 1; transform: translateX(0); }
}
.toast.removing {
  animation: toast-remove 0.3s var(--snap) forwards;
}
@keyframes toast-remove {
  to { opacity: 0; transform: translateX(100%); }
}
.toast.info { border-left: 3px solid var(--blue); }
.toast.success { border-left: 3px solid var(--green); }
.toast.error { border-left: 3px solid var(--red); }

/* ═══ VOICE CHAT BAR ═══ */
.voice-chat-bar {
  height: 70px;
  background: oklch(0.08 0.01 270 / 0.2);
  backdrop-filter: blur(10px) saturate(140%);
  border-top: 1px solid var(--glass-border);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
  z-index: 100;
  box-shadow: 0 -1px 0 oklch(1 0 0 / 0.02) inset, 0 -4px 24px oklch(0 0 0 / 0.2);
}

.voice-selector {
  width: 280px;
  padding: 10px 14px;
  background: var(--glass-strong);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  color: var(--text-1);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  cursor: pointer;
  transition: all 0.2s var(--spring-smooth);
}
.voice-selector:focus {
  outline: none;
  border-color: var(--purple);
  box-shadow: 0 0 20px var(--purple-glow);
}

.chat-input-wrap {
  flex: 1;
  display: flex;
  gap: 8px;
  align-items: center;
}
.chat-input {
  flex: 1;
  padding: 12px 16px;
  background: var(--glass-strong);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  color: var(--text-1);
  font-family: var(--font-body);
  font-size: 0.95rem;
  transition: all 0.2s var(--spring-smooth);
}
.chat-input:focus {
  outline: none;
  border-color: var(--purple);
  box-shadow: 0 0 20px var(--purple-glow);
}
.chat-input::placeholder {
  color: var(--text-ghost);
}

.mic-btn, .send-btn {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-sm);
  background: var(--glass);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  cursor: pointer;
  transition: all 0.15s var(--spring);
}
.mic-btn:hover, .send-btn:hover {
  background: var(--purple);
  border-color: var(--purple);
  box-shadow: 0 0 20px var(--purple-glow);
  transform: scale(1.08);
}
.mic-btn:active, .send-btn:active {
  transform: scale(0.95);
  transition-duration: 60ms;
}

.mic-btn.recording {
  background: var(--red);
  border-color: var(--red);
  box-shadow: 0 0 30px var(--red-glow);
  animation: pulse-recording 1s ease-in-out infinite;
}
@keyframes pulse-recording {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.voice-status {
  min-width: 140px;
  padding: 8px 12px;
  background: var(--glass);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-3);
  text-align: center;
}
.voice-status.listening {
  color: var(--green);
  border-color: var(--green);
  box-shadow: 0 0 12px var(--green-glow);
}
.voice-status.speaking {
  color: var(--cyan);
  border-color: var(--cyan);
  box-shadow: 0 0 12px var(--cyan-glow);
}

/* TTS Controls */
.tts-toggle-btn {
  padding: 8px 14px;
  background: var(--glass);
  backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  cursor: pointer;
  transition: all 0.2s var(--spring-smooth);
}
.tts-toggle-btn:hover {
  background: var(--glass-strong);
  transform: scale(1.05);
}
.tts-toggle-btn.active {
  background: var(--green);
  border-color: var(--green);
  color: var(--void);
  box-shadow: 0 0 20px var(--green-glow);
}
.tts-toggle-btn.active .tts-icon {
  animation: volume-pulse 1.5s ease-in-out infinite;
}
@keyframes volume-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}
.tts-icon {
  font-size: 1.2rem;
}
.tts-label {
  font-weight: 700;
  letter-spacing: 0.5px;
}

.tts-stop-btn {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-sm);
  background: var(--red);
  border: 1px solid var(--red);
  box-shadow: 0 0 20px var(--red-glow);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  cursor: pointer;
  transition: all 0.15s var(--spring);
  animation: pulse-stop 1s ease-in-out infinite;
}
@keyframes pulse-stop {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}
.tts-stop-btn:hover {
  transform: scale(1.15);
}
.tts-stop-btn:active {
  transform: scale(0.95);
}

/* Message TTS Button */
.msg-tts-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  margin-left: 6px;
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: 4px;
  font-size: 0.85rem;
  cursor: pointer;
  opacity: 0;
  transition: all 0.2s var(--spring-smooth);
}
.stream-msg:hover .msg-tts-btn {
  opacity: 1;
}
.msg-tts-btn:hover {
  background: var(--cyan);
  border-color: var(--cyan);
  box-shadow: 0 0 12px var(--cyan-glow);
  transform: scale(1.1);
}
.msg-tts-btn.playing {
  opacity: 1;
  background: var(--cyan);
  border-color: var(--cyan);
  box-shadow: 0 0 12px var(--cyan-glow);
  animation: waveform 1s ease-in-out infinite;
}
@keyframes waveform {
  0%, 100% { transform: scaleY(1); }
  25% { transform: scaleY(1.2); }
  50% { transform: scaleY(0.8); }
  75% { transform: scaleY(1.1); }
}

/* Streaming Indicator */
.streaming-indicator {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 3px 8px;
  background: oklch(0.68 0.30 290 / 0.15);
  border: 1px solid var(--purple);
  border-radius: 10px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--purple);
  margin-left: 6px;
  animation: stream-glow 2s ease-in-out infinite;
}
.streaming-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--purple);
  box-shadow: 0 0 10px var(--purple-glow);
  animation: stream-pulse 1.2s ease-in-out infinite;
}
@keyframes stream-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.4); opacity: 0.6; }
}
@keyframes stream-glow {
  0%, 100% { 
    box-shadow: 0 0 8px var(--purple-glow);
    border-color: var(--purple);
  }
  50% { 
    box-shadow: 0 0 16px var(--purple-glow), 0 0 24px var(--purple-glow);
    border-color: oklch(0.78 0.35 290);
  }
}

.stream-msg.tts-active {
  background: oklch(0.78 0.22 195 / 0.08);
  border-left-color: var(--cyan);
  box-shadow: 0 0 20px var(--cyan-glow);
  transform: translateX(4px);
}

/* ═══ ACTIVITY TICKER ═══ */
.activity-ticker{
  position:fixed;bottom:0;left:0;right:0;height:28px;z-index:200;
  background:oklch(0.06 0.015 270/0.85);backdrop-filter:blur(8px);
  border-top:1px solid var(--glass-border);
  overflow:hidden;display:flex;align-items:center;
  font-family:var(--font-mono);font-size:0.65rem;color:var(--text-2);
}
.ticker-label{
  flex-shrink:0;padding:0 10px;font-weight:700;color:var(--purple);
  text-transform:uppercase;letter-spacing:1px;font-size:0.55rem;
  border-right:1px solid var(--glass-border);height:100%;display:flex;align-items:center;
  text-shadow:0 0 8px var(--purple-glow);background:oklch(0.08 0.01 270/0.5);
}
.ticker-track{
  flex:1;overflow:hidden;position:relative;height:100%;display:flex;align-items:center;
}
.ticker-scroll{
  display:flex;gap:32px;white-space:nowrap;
  animation:ticker-scroll 60s linear infinite;
  padding-left:100%;
}
.ticker-scroll:hover{animation-play-state:paused}
@keyframes ticker-scroll{
  0%{transform:translateX(0)}
  100%{transform:translateX(-50%)}
}
.ticker-item{
  display:inline-flex;align-items:center;gap:6px;flex-shrink:0;
  padding:2px 8px;border-radius:4px;transition:background 0.15s;
}
.ticker-item:hover{background:oklch(0.15 0.02 270/0.3)}
.ticker-time{color:var(--text-3);font-size:0.55rem}
.ticker-icon{font-size:0.75rem}
.ticker-text{color:var(--text-2)}

/* ═══ RESPONSIVE ═══ */
@media (max-width: 1400px) {
  html { font-size: 12px; }
}
@media (max-width: 900px) {
  .topbar-stats { display: none; }
  .voice-selector { width: 180px; font-size: 0.7rem; }
  .voice-status { min-width: 100px; font-size: 0.65rem; }
}

/* ═══ ULTRAWIDE (>3840px) — 5-COLUMN COMMAND BRIDGE ═══ */
@media (min-width: 3841px) {
  .bento-container {
    max-width: 100%;
    grid-template-columns: minmax(600px, 1.6fr) minmax(500px, 1.3fr) minmax(400px, 1fr);
    grid-template-rows: 1fr;
    gap: 14px;
    padding: 14px 18px;
  }
  #chat-card {
    grid-column: 1 !important;
    grid-row: 1 !important;
  }
  #stream-card {
    grid-column: 2 !important;
    grid-row: 1 !important;
  }
  #nvtop-card {
    grid-column: 3 !important;
    grid-row: 1 !important;
    overflow-y: auto !important;
    max-height: none !important;
  }
  #missions-card {
    display: none !important;
  }
  #agents-card {
    display: none !important;
  }
  #tools-card {
    display: none !important;
  }
  #forecast-card {
    display: none !important;
  }
  .bento-card { padding: 14px; }
  .card-title { font-size: 1rem; }
  .stream-msg { font-size: 0.95rem; }
  .agent-item { font-size: 0.8rem; }
  #chat-messages { font-size: 0.95rem; }
  
  /* 8K chat optimizations */
  #chat-card {
    min-width: 500px !important;
  }
  .chat-header { padding: 14px 18px; }
  .chat-header-avatar { width: 42px; height: 42px; font-size: 1.3rem; }
  .chat-header-name { font-size: 1rem; }
  .chat-header-status { font-size: 0.75rem; }
  .chat-msg-wrap { max-width: 85%; }
  .chat-bubble { font-size: 0.95rem; padding: 14px 18px; border-radius: 18px; }
  .chat-avatar { width: 34px; height: 34px; font-size: 0.9rem; }
  .chat-bubble .chat-content pre code { font-size: 0.85rem; }
  .chat-bubble .chat-content code:not(pre code) { font-size: 0.88rem; }
  .chat-time { font-size: 0.65rem; }
  #chat-textarea { font-size: 0.95rem; padding: 12px 18px; min-height: 44px; }
  .chat-input-btn { width: 42px; height: 42px; font-size: 1.15rem; }
  #chat-input-area { padding: 12px 14px; }
  .chat-date-sep span { font-size: 0.7rem; padding: 5px 16px; }
  .chat-reply-quote { font-size: 0.78rem; }
  .chat-msg-actions button { width: 30px; height: 30px; font-size: 0.8rem; }
  .chat-code-header { font-size: 0.7rem; }
  .chat-code-copy { font-size: 0.7rem; padding: 3px 10px; }
  .chat-bubble .chat-content th { font-size: 0.78rem; }
  .chat-bubble .chat-content td { font-size: 0.82rem; }
  .chat-file-card { padding: 12px 16px; }
  .chat-file-name { font-size: 0.85rem; }
  .chat-file-size { font-size: 0.7rem; }
  #chat-scroll-btn { width: 42px; height: 42px; font-size: 1.15rem; bottom: 80px; }
  
  /* Ambient glow on full-height columns */
  #chat-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, transparent, oklch(0.68 0.30 290 / 0.6), transparent);
    animation: column-pulse 4s ease-in-out infinite;
  }
  #stream-card::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, transparent, oklch(0.78 0.22 195 / 0.6), transparent);
    animation: column-pulse 4s ease-in-out infinite reverse;
  }
}
@keyframes column-pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* ═══ TABLET — 2-COLUMN LAYOUT ═══ */
@media (max-width: 1024px) {
  html { font-size: 13px; }
  
  body { overflow: auto; overflow-x: hidden; }
  
  #particle-canvas, .aurora-bg { display: none !important; }
  
  .bento-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    height: auto;
    min-height: calc(100vh - 60px - 70px);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  
  #stream-card, #nvtop-card, #missions-card, #agents-card,
  #tools-card, #chat-card, #gpu-card, #forecast-card, #latency-card {
    grid-column: auto;
    grid-row: auto;
    min-height: 280px;
    max-height: 500px;
  }
  
  #stream-card { grid-column: 1 / 3; min-height: 350px; }
  #chat-card { grid-column: 1 / 3; min-height: 350px; max-height: 500px; order: -1; }
  #chat-textarea { font-size: 16px !important; min-height: 42px; }
  .chat-input-btn { width: 42px; height: 42px; min-width: 42px; }
  .chat-bubble { max-width: 80%; }
  
  .topbar-stats { display: none; }
  .topbar-divider:nth-child(2) ~ a { display: none; }
  
  .hamburger-menu { display: flex !important; }
  .topbar-nav-links { display: none; }
  .topbar-nav-links.open { 
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    background: oklch(0.08 0.015 270 / 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border);
    padding: 12px;
    gap: 8px;
    z-index: 200;
  }
  .topbar-nav-links.open a {
    display: block;
    padding: 10px 14px;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  
  .bento-card {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
}

/* ═══ MOBILE — SINGLE COLUMN ═══ */
@media (max-width: 768px) {
  html { font-size: 12px; }
  
  body { overflow: auto; overflow-x: hidden; }
  
  #particle-canvas, .aurora-bg { display: none !important; }
  
  .topbar {
    height: 52px;
    padding: 0 12px;
    gap: 8px;
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .topbar-logo { font-size: 1.1rem; }
  .topbar-logo .emoji { font-size: 1.4rem; }
  .topbar-stats { display: none !important; }
  .topbar-actions { gap: 4px; }
  .topbar-btn { width: 44px; height: 44px; font-size: 1.2rem; }
  .encrypt-badge { display: none; }
  .model-badge { padding: 4px 8px; font-size: 0.7rem; }
  .conn-status { display: none; }
  
  /* Hide inline nav links, show hamburger */
  .topbar > a { display: none !important; }
  .topbar > .topbar-divider:nth-child(2) { display: none; }
  .hamburger-menu { display: flex !important; }
  
  .bento-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 8px;
    height: auto;
    min-height: calc(100vh - 52px - 64px);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  
  #stream-card, #nvtop-card, #missions-card, #agents-card,
  #tools-card, #chat-card, #gpu-card, #forecast-card, #latency-card {
    grid-column: auto !important;
    grid-row: auto !important;
    width: 100%;
    min-height: 250px;
    max-height: 450px;
  }
  
  #chat-card {
    min-height: 350px;
    max-height: 70vh;
    order: -1; /* Chat first on mobile */
  }
  
  /* Mobile chat optimizations */
  .chat-header { padding: 8px 12px; }
  .chat-header-avatar { width: 28px; height: 28px; font-size: 0.9rem; }
  .chat-header-name { font-size: 0.8rem; }
  .chat-header-status { font-size: 0.6rem; }
  .chat-header-actions button { width: 32px; height: 32px; }
  #chat-textarea { font-size: 16px !important; padding: 10px 14px; min-height: 44px; border-radius: 22px; }
  .chat-input-btn { width: 44px; height: 44px; font-size: 1.2rem; min-width: 44px; }
  #chat-input-area { padding: 8px; }
  .chat-bubble { font-size: 0.85rem; padding: 10px 14px; max-width: 85%; }
  .chat-avatar { width: 28px; height: 28px; font-size: 0.75rem; }
  .chat-msg-wrap { max-width: 90%; }
  .chat-date-sep span { font-size: 0.65rem; }
  .chat-msg-actions { display: none; } /* No hover actions on mobile */
  #chat-scroll-btn { width: 40px; height: 40px; bottom: 70px; right: 12px; }
  .chat-search-bar { padding: 8px; }
  .chat-search-bar input { font-size: 16px !important; } /* Prevent iOS zoom */
  
  .bento-card {
    border-radius: var(--radius-sm);
    padding: 10px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  
  .card-title { font-size: 0.7rem; margin-bottom: 8px; }
  .card-icon { font-size: 1rem; }
  
  /* GPU metrics stack vertically on mobile */
