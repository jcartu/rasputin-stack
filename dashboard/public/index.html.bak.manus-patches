function handleStreamingStart(msg) {
  // Don't render conversation text in Neural Stream — chat panel handles it
  state.streamingMsg = null;
  state.streamStartTime = Date.now();
  state.streamTokenCount = 0;
  // Create streaming chat bubble only
  if (window.startChatStream) window.startChatStream(msg.ts);
}

function handleTokenStream(msg) {
  const text = msg.text || '';
  
  // Comprehensive system noise filter
  const isSystemNoise = (
    text === 'NO_REPLY' ||
    text === 'HEARTBEAT_OK' ||
    text.startsWith('Read HEARTBEAT.md') ||
    text.includes('Follow it strictly') ||
    text.startsWith('Conversation info (untrusted metadata):') ||
    /^Conversation info \(untrusted metadata\):/i.test(text) ||
    /^\s*```?json\s*\n?\s*\{/i.test(text) ||
    text.includes('[Queued announce messages') ||
    text.includes('A subagent task') ||
    text.includes('Summarize this naturally for the user') ||
    text.startsWith('Pre-compaction memory flush') ||
    /Stats: runtime \d+s • tokens/i.test(text) ||
    (text.includes('{') && text.includes('}') && text.includes('"conversation_label"'))
  );
  
  if (isSystemNoise) return;
  
  // Stream to chat panel ONLY — Neural Stream stays clean for technical events
  if (window.updateChatStream) window.updateChatStream(text);
}

function cleanupOrphanedIndicators() {
  const allIndicators = document.querySelectorAll('.streaming-indicator');
  console.log('[Cleanup] Found streaming indicators:', allIndicators.length);
  
  allIndicators.forEach(indicator => {
    const parent = indicator.closest('.stream-msg');
    if (parent) {
      const text = parent.querySelector('.stream-text')?.textContent || '';
      const wordCount = text.split(/\s+/).filter(w => w.length > 0).length;
      
      const indicatorText = indicator.querySelector('.streaming-text');
      if (indicatorText) {
        indicatorText.textContent = wordCount > 0 ? `✓ COMPLETE • ${wordCount} words` : '✓ COMPLETE';
      }
      
      // Change to green
      indicator.style.background = 'var(--green-glow)';
      indicator.style.borderColor = 'var(--green)';
      indicator.style.color = 'var(--green)';
      indicator.style.animation = 'none';
      
      const dot = indicator.querySelector('.streaming-dot');
      if (dot) {
        dot.style.background = 'var(--green)';
        dot.style.animation = 'none';
        dot.style.boxShadow = '0 0 10px var(--green-glow)';
      }
      
      // Fade out after 500ms
      setTimeout(() => {
        indicator.style.transition = 'opacity 0.2s ease';
        indicator.style.opacity = '0';
        setTimeout(() => indicator.remove(), 200);
      }, 500);
    }
  });
}

function handleStreamingEnd(msg) {
