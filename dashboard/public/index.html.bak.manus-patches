// ─── Latency Histogram Rendering ───
let latencyHistogramChart = null;

function updateLatencyHistogram(latencyData) {
  try {
    // Update stats displays
    const p50El = $('#latency-p50');
    const p95El = $('#latency-p95');
    const p99El = $('#latency-p99');
    const avgEl = $('#latency-avg');
    const samplesEl = $('#latency-samples');
    
    if (p50El) p50El.textContent = latencyData.latency.p50 > 0 ? formatLatency(latencyData.latency.p50) : '—';
    if (p95El) p95El.textContent = latencyData.latency.p95 > 0 ? formatLatency(latencyData.latency.p95) : '—';
    if (p99El) p99El.textContent = latencyData.latency.p99 > 0 ? formatLatency(latencyData.latency.p99) : '—';
    if (avgEl) avgEl.textContent = latencyData.latency.avg > 0 ? formatLatency(latencyData.latency.avg) : '—';
    if (samplesEl) samplesEl.textContent = `${latencyData.sampleCount} samples`;
    
    // Update TTFT stats
    const ttftP50El = $('#ttft-p50');
    const ttftP95El = $('#ttft-p95');
    const ttftAvgEl = $('#ttft-avg');
    
    if (ttftP50El) ttftP50El.textContent = latencyData.ttft.p50 > 0 ? formatLatency(latencyData.ttft.p50) : '—';
    if (ttftP95El) ttftP95El.textContent = latencyData.ttft.p95 > 0 ? formatLatency(latencyData.ttft.p95) : '—';
    if (ttftAvgEl) ttftAvgEl.textContent = latencyData.ttft.avg > 0 ? formatLatency(latencyData.ttft.avg) : '—';
    
    // ═══ ENHANCED STATS: GPU Correlation, Trends, Anomalies ═══
    if (latencyData.enhancements) {
      const enhancements = latencyData.enhancements;
      
      // GPU Correlation Display
      const gpuCorrDiv = $('#gpu-latency-correlation');
      const gpuCorrText = $('#gpu-correlation-text');
      if (gpuCorrDiv && gpuCorrText && enhancements.gpuCorrelation && enhancements.gpuCorrelation.enabled) {
        const corr = enhancements.gpuCorrelation;
        gpuCorrText.textContent = `${corr.message} (r=${corr.correlation}, n=${corr.sampleCount})`;
        gpuCorrDiv.style.display = 'block';
      } else if (gpuCorrDiv) {
        gpuCorrDiv.style.display = 'none';
      }
      
      // Anomaly Alerts (prepend to latency card if anomalies detected)
      if (enhancements.anomalies && enhancements.anomalies.count > 0) {
        const latencyCard = $('#latency-card');
        let anomalyBanner = $('#anomaly-banner');
        if (!anomalyBanner && latencyCard) {
          anomalyBanner = document.createElement('div');
          anomalyBanner.id = 'anomaly-banner';
          anomalyBanner.style.cssText = 'background:oklch(0.30 0.15 30/0.3);padding:8px 12px;border-radius:6px;border:1px solid oklch(0.70 0.20 30);margin-bottom:10px;font-size:0.65rem;color:oklch(0.70 0.20 30);animation:pulse 2s ease-in-out infinite;';
          latencyCard.insertBefore(anomalyBanner, latencyCard.firstChild);
        }
        if (anomalyBanner) {
          anomalyBanner.textContent = enhancements.anomalies.message;
        }
      } else {
        const anomalyBanner = $('#anomaly-banner');
        if (anomalyBanner) anomalyBanner.remove();
      }
    }
    
    // Render histogram
    const canvas = $('#latency-histogram');
    if (!canvas || !latencyData.histogram || latencyData.histogram.length === 0) return;
    
    const ctx = canvas.getContext('2d');
    const width = canvas.width = canvas.offsetWidth * window.devicePixelRatio;
    const height = canvas.height = canvas.offsetHeight * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    
    // Clear canvas
    ctx.clearRect(0, 0, w, h);
    
    // Get histogram data
    const histogram = latencyData.histogram;
    const maxCount = Math.max(...histogram.map(b => b.count), 1);
    
    // Colors
    const barColor = 'oklch(0.60 0.15 270)';
    const p50Color = 'oklch(0.70 0.15 150)'; // green
    const p95Color = 'oklch(0.75 0.15 60)'; // yellow
    const p99Color = 'oklch(0.70 0.20 30)'; // red
    
    // Draw bars
    const barWidth = w / histogram.length;
    const padding = 2;
    
    histogram.forEach((bucket, i) => {
      const barHeight = (bucket.count / maxCount) * (h - 30);
      const x = i * barWidth;
      const y = h - barHeight - 20;
      
      ctx.fillStyle = barColor;
      ctx.fillRect(x + padding, y, barWidth - padding * 2, barHeight);
    });
    
    // Draw P50/P95/P99 markers
    const minVal = histogram[0].min;
    const maxVal = histogram[histogram.length - 1].max;
    const range = maxVal - minVal;
    
    function drawPercentileLine(value, color, label) {
      if (value <= 0 || range <= 0) return;
      const x = ((value - minVal) / range) * w;
      
      // Draw vertical line
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      ctx.setLineDash([4, 4]);
      ctx.beginPath();
      ctx.moveTo(x, h - 20);
      ctx.lineTo(x, 0);
      ctx.stroke();
      ctx.setLineDash([]);
      
      // Draw label
      ctx.fillStyle = color;
      ctx.font = '10px "JetBrains Mono", monospace';
      ctx.fillText(label, x + 4, 12);
    }
    
    drawPercentileLine(latencyData.latency.p50, p50Color, 'P50');
    drawPercentileLine(latencyData.latency.p95, p95Color, 'P95');
    drawPercentileLine(latencyData.latency.p99, p99Color, 'P99');
    
    // Draw X-axis labels
    ctx.fillStyle = 'oklch(0.50 0.02 270)';
    ctx.font = '9px "JetBrains Mono", monospace';
    ctx.textAlign = 'left';
    ctx.fillText(minVal + 'ms', 0, h - 4);
    ctx.textAlign = 'right';
    ctx.fillText(maxVal + 'ms', w, h - 4);
    ctx.textAlign = 'center';
    ctx.fillText(Math.round((minVal + maxVal) / 2) + 'ms', w / 2, h - 4);
    
  } catch (e) {
    console.warn('Latency histogram error:', e);
  }
}

function formatLatency(ms) {
  if (ms < 1000) return Math.round(ms) + 'ms';
  return (ms / 1000).toFixed(2) + 's';
}

