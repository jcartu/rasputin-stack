    // Update chart
    this.drawChart();
  },
  
  // Draw trend chart
  drawChart() {
    if (!this.chart || !this.chart.ctx || this.history.length < 2) return;
    
    const { canvas, ctx } = this.chart;
    const width = canvas.width = canvas.offsetWidth * window.devicePixelRatio;
    const height = canvas.height = canvas.offsetHeight * window.devicePixelRatio;
    
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    const displayWidth = canvas.offsetWidth;
    const displayHeight = canvas.offsetHeight;
    
    // Clear
    ctx.clearRect(0, 0, displayWidth, displayHeight);
    
    // Get data
    const data = this.history.slice(-60); // Last 60 seconds
    if (data.length < 2) return;
    
    const maxLatency = Math.max(...data.map(s => s.latency), this.thresholds.latencyHigh);
    const minLatency = Math.min(...data.map(s => s.latency), 0);
    const range = maxLatency - minLatency || 1;
    
    // Draw threshold lines
    const criticalY = displayHeight - ((this.thresholds.latencyCritical - minLatency) / range * displayHeight);
    const highY = displayHeight - ((this.thresholds.latencyHigh - minLatency) / range * displayHeight);
    
    ctx.strokeStyle = 'rgba(255, 0, 100, 0.2)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(0, criticalY);
    ctx.lineTo(displayWidth, criticalY);
    ctx.stroke();
    
    ctx.strokeStyle = 'rgba(255, 180, 0, 0.2)';
    ctx.beginPath();
    ctx.moveTo(0, highY);
    ctx.lineTo(displayWidth, highY);
    ctx.stroke();
    ctx.setLineDash([]);
    
    // Draw latency line
    ctx.strokeStyle = 'rgba(0, 212, 255, 0.8)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    
    data.forEach((sample, i) => {
      const x = (i / (data.length - 1)) * displayWidth;
      const y = displayHeight - ((sample.latency - minLatency) / range * displayHeight);
      
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    
    ctx.stroke();
    
    // Draw gradient fill
    const gradient = ctx.createLinearGradient(0, 0, 0, displayHeight);
    gradient.addColorStop(0, 'rgba(0, 212, 255, 0.3)');
    gradient.addColorStop(1, 'rgba(0, 212, 255, 0)');
    
    ctx.fillStyle = gradient;
    ctx.beginPath();
    data.forEach((sample, i) => {
      const x = (i / (data.length - 1)) * displayWidth;
      const y = displayHeight - ((sample.latency - minLatency) / range * displayHeight);
      
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    });
    ctx.lineTo(displayWidth, displayHeight);
    ctx.lineTo(0, displayHeight);
    ctx.closePath();
    ctx.fill();
  }
};

