// ─── Gateway Events ───
function handleGatewayEvent(msg) {
  const payload = msg.payload || {};
  
  const isNoisyEvent = (
    payload.stream === 'assistant' ||
    payload.data?.text ||
    (payload.runId && !payload.status) ||
    JSON.stringify(payload).includes('"stream":"assistant"') ||
    JSON.stringify(payload).includes('"data":{"text"')
  );
  if (isNoisyEvent) return;
  if (msg.type === 'gateway_presence') return;
  
  const isMeaningful = (
    payload.status === 'completed' || payload.status === 'failed' || payload.status === 'accepted' ||
    payload.action === 'spawn' || payload.action === 'complete' || msg.type === 'gateway_cron'
  );
  if (!isMeaningful) return;
  
  incrementStreamCount('gateway');
  const container = $('#stream-scroll');
  const el = document.createElement('div');
  el.className = 'stream-pill';
  el.dataset.eventType = 'gateway';
  
  const time = formatTimestamp(msg.timestamp || Date.now());
  const eventType = msg.type.replace('gateway_', '');
  
  let preview = '';
  if (eventType === 'cron') {
    const jobName = payload.jobName || payload.name || 'Job';
    const status = payload.status || payload.action || 'running';
    const statusEmoji = status === 'ok' || status === 'completed' ? '✓' : status === 'failed' || status === 'error' ? '✗' : '⟳';
    preview = `${statusEmoji} ${jobName}`;
    if (payload.nextRunAtMs) {
      const minutes = Math.round((new Date(payload.nextRunAtMs) - Date.now()) / 60000);
      preview += minutes < 60 ? ` · next ${minutes}m` : ` · next ${Math.round(minutes/60)}h`;
    }
  } else if (eventType === 'chat') {
    preview = '💬 Message from Telegram';
  } else {
    preview = payload.status ? `Status: ${payload.status}` : JSON.stringify(payload).slice(0, 80);
  }
  
  const typeColors = { chat: 'var(--cyan)', agent: 'var(--purple)', cron: 'var(--amber)' };
  const typeIcons = { chat: '💬', agent: '🤖', cron: '⏰' };
  const color = typeColors[eventType] || 'var(--text-2)';
  
  el.style.borderLeft = `3px solid ${color}`;
  el.innerHTML = `
    <span class="pill-icon">${typeIcons[eventType] || '🌐'}</span>
    <span class="pill-text" style="color:${color};">${preview}</span>
    <span class="pill-time">${time}</span>
  `;
  
  container.appendChild(el);
  pruneStream();
  scrollToBottom();
}

// ─── Auto-prune stream events (max 30 visible) ───
function pruneStream() {
  const container = $('#stream-scroll');
  if (!container) return;
  // Clean up ghost elements that are explicitly marked for removal (not CSS animation starts!)
  container.querySelectorAll(':scope > .stream-pruned').forEach(el => el.remove());
  // Remove oldest events if over limit
  const eventChildren = Array.from(container.children).filter(c => !c.classList.contains('stream-empty'));
  let excess = eventChildren.length - STREAM_MAX_VISIBLE;
  for (let i = 0; i < excess && i < eventChildren.length; i++) {
    eventChildren[i].classList.add('stream-pruned');
    eventChildren[i].style.opacity = '0';
    eventChildren[i].style.transition = 'opacity 0.3s';
    // Remove after fade animation
    setTimeout(() => { if (eventChildren[i].parentNode) eventChildren[i].remove(); }, 350);
  }
}

// ─── Stream Messages ───
function formatTimestamp(ts) {
  const date = new Date(ts);
  const now = new Date();
  const isToday = date.toDateString() === now.toDateString();
  
  if (isToday) {
    return date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
  } else {
    return date.toLocaleString('en-US', { 
      month: 'short', 
      day: 'numeric', 
      hour: 'numeric', 
      minute: '2-digit',
      hour12: true 
    });
  }
}

function handleThinking(msg) {
  const container = $('#stream-scroll');
  const text = (msg.text || '').trim();
  if (!text || text.length === 0 || /^\s*$/.test(text)) {
    console.log('[Thinking] Rejected empty/whitespace thinking event');
    return;
  }
  incrementStreamCount('thinking');
  
  // console.log('[Thinking] Event received, lastEventType:', state.lastEventType, 'hasLastCard:', !!state.lastThinkingCard);
  
  // Check if last event was also thinking - if so, append to that card
  if (state.lastEventType === 'thinking' && state.lastThinkingCard) {
    const el = state.lastThinkingCard;
    
    console.log('[Thinking] Attempting to append, element exists:', !!el, 'inDOM:', !!(el && el.parentNode));
    
    // Make sure the element still exists in DOM
    if (el && el.parentNode) {
      const currentText = el._fullText || '';
      const combinedText = currentText + '\n\n' + text;
      const wordCount = combinedText.split(/\s+/).length;
      const preview = combinedText.length > 2000 ? combinedText.slice(0, 2000) + '…' : combinedText;
      const isLong = combinedText.length > 2000;
      
      el._fullText = combinedText;
      el._preview = preview;
      
      // Update collapsed state first if needed
      if (isLong && !el.classList.contains('collapsed')) {
        el.classList.add('collapsed');
        const metaDiv = el.querySelector('.thinking-meta');
        if (metaDiv && !metaDiv.querySelector('.thinking-toggle')) {
          const toggle = document.createElement('span');
          toggle.className = 'thinking-toggle';
          toggle.onclick = () => toggleThinking(el.id);
          toggle.textContent = 'expand ▾';
          metaDiv.appendChild(toggle);
        }
      }
      
      // Update the text display (after checking collapsed state)
      const textDiv = el.querySelector('.thinking-text');
      if (textDiv) {
        textDiv.textContent = isLong && el.classList.contains('collapsed') ? preview : combinedText;
      }
      
      // Update word count
      const metaDiv = el.querySelector('.thinking-meta span');
      if (metaDiv) {
        metaDiv.textContent = `${wordCount} words${msg.model ? ' · ' + msg.model : ''}`;
      }
      
      // CRITICAL: Set this IMMEDIATELY so next thinking event appends
      state.lastEventType = 'thinking';
      
      // console.log('[Thinking] Successfully appended, combined length:', combinedText.length);
      return; // Successfully appended
    }
  }
  
  console.log('[Thinking] Creating new card');
  
  // Create new thinking card
  const time = formatTimestamp(msg.ts);
  const wordCount = text.split(/\s+/).length;
  const preview = text.length > 2000 ? text.slice(0, 2000) + '…' : text;
  const isLong = text.length > 2000;
  const id = 'think-' + Date.now();
  
  const el = document.createElement('div');
  el.className = 'thinking-card' + (isLong ? ' collapsed' : '');
  el.id = id;
  el.dataset.eventType = 'thinking';
  el.innerHTML = `
    <div class="thinking-header">
      <svg class="thinking-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/>
        <path d="M9 22h6"/>
        <path d="M10 22v-1"/>
        <path d="M14 22v-1"/>
      </svg>
      <span>Reasoning</span>
      <span style="margin-left:auto">${time}</span>
    </div>
    <div class="thinking-text"></div>
    <div class="thinking-meta">
      <span>${wordCount} words${msg.model ? ' · ' + msg.model : ''}</span>
      ${isLong ? `<span class="thinking-toggle" onclick="toggleThinking('${id}')">expand ▾</span>` : ''}
    </div>
  `;
  el._fullText = text;
  el._preview = preview;
  el._addedAt = Date.now();
  
  // Set text content safely (after innerHTML to avoid XSS)
  const textDiv = el.querySelector('.thinking-text');
  if (textDiv) {
    textDiv.textContent = isLong ? preview : text;
  }
  
  container.appendChild(el);
  pruneStream(); // Auto-prune to keep max 30 events
  scrollToBottom();
  
  // Track this as the last thinking card and set last event type
  state.lastThinkingCard = el;
  state.lastEventType = 'thinking';
}

function toggleThinking(id) {
  const el = document.getElementById(id);
  if (!el) return;
  const textEl = el.querySelector('.thinking-text');
  const toggleEl = el.querySelector('.thinking-toggle');
  if (el.classList.contains('collapsed')) {
    el.classList.remove('collapsed');
    textEl.textContent = el._fullText;
    toggleEl.textContent = 'collapse ▴';
  } else {
    el.classList.add('collapsed');
    textEl.textContent = el._preview;
    toggleEl.textContent = 'expand ▾';
  }
}

function addStreamMessage(role, text, ts) {
  const container = $('#stream-scroll');
  // Clean text
  text = (text || '').replace(/\[message_id:\s*\d+\]\s*/g, '').replace(/\[media attached:.*?\]\n?/gs, '').trim();
  
  // Skip empty messages
  if (!text || text.length < 3) return null;
  
  // Comprehensive system noise filter
  const isSystemNoise = (
    // Internal responses
    text === 'NO_REPLY' ||
    text === 'HEARTBEAT_OK' ||
    
    // Heartbeat prompts
    text.startsWith('Read HEARTBEAT.md') ||
    text.includes('Follow it strictly. Do not infer or repeat old tasks') ||
    text.includes('reply HEARTBEAT_OK') ||
    
    // Conversation metadata blocks
    text.startsWith('Conversation info (untrusted metadata):') ||
    /^Conversation info \(untrusted metadata\):/i.test(text) ||
    
    // JSON metadata
    /^\s*```?json\s*\n?\s*\{/i.test(text) ||
    /^\s*\{\s*\n?\s*"conversation_label"/i.test(text) ||
    
    // Queued messages & sub-agent completions
    text.includes('[Queued announce messages') ||
    text.includes('A subagent task') ||
    text.includes('just completed successfully') ||
    text.includes('Summarize this naturally for the user') ||
    text.includes('Do not mention technical details like tokens') ||
    
    // Pre-compaction flushes
    text.startsWith('Pre-compaction memory flush') ||
    
    // Bootstrap/system
    text.includes('BOOTSTRAP.md') ||
    text.includes('workspace context') ||
    
    // Stats blocks
    /Stats: runtime \d+s • tokens/i.test(text) ||
    text.includes('sessionKey agent:main') ||
    
    // Multi-line JSON blocks
    (text.includes('{') && text.includes('}') && text.includes('"conversation_label"'))
  );
  
  if (isSystemNoise) return null;
  
  const el = document.createElement('div');
  el.className = `stream-msg role-${role}`;

  const time = formatTimestamp(ts);
  
  el.innerHTML = `
    <div class="stream-meta">
      <span class="stream-role">${role}</span>
    </div>
    <div class="stream-text">${text}</div>
    <span class="stream-time">${time}</span>
  `;

  container.appendChild(el);
  pruneStream();
  while (container.children.length > 50) container.removeChild(container.firstChild);
  scrollToBottom();

  return el;
}

let scrollRAF = null;
function scrollToBottom() {
  // Use double requestAnimationFrame to ensure layout is computed
  if (scrollRAF) return; // Already queued
  
  scrollRAF = requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const container = $('#stream-scroll');
      // Scroll the last child into view (more reliable than scrollTop)
      const lastChild = container.lastElementChild;
      if (lastChild) {
        lastChild.scrollIntoView({ behavior: 'instant', block: 'end', inline: 'nearest' });
      } else {
        container.scrollTop = container.scrollHeight;
      }
      scrollRAF = null;
    });
  });
}

