  // Calculate trend (linear regression slope)
  calculateTrend() {
    if (this.history.length < 10) return { slope: 0, direction: 'stable' };
    
    const recent = this.history.slice(-30); // Last 30 samples
    const n = recent.length;
    
    let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
    
    recent.forEach((sample, i) => {
      sumX += i;
      sumY += sample.latency;
      sumXY += i * sample.latency;
      sumX2 += i * i;
    });
    
    const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
    
    let direction = 'stable';
    if (slope > 20) direction = 'rising';
    else if (slope > 50) direction = 'critical';
    else if (slope < -20) direction = 'falling';
    
    return { slope: slope.toFixed(2), direction };
  },
  
  // Calculate risk score (0-100)
  calculateRisk() {
    if (this.history.length < 5) return 0;
    
    let risk = 0;
    
    // Recent latency average
    const recent = this.history.slice(-10);
    const avgLatency = recent.reduce((sum, s) => sum + s.latency, 0) / recent.length;
    
    if (avgLatency > this.thresholds.latencyHigh) risk += 30;
    if (avgLatency > this.thresholds.latencyCritical) risk += 40;
    
    // Trend
    const trend = this.calculateTrend();
    if (trend.direction === 'rising') risk += 20;
    if (trend.direction === 'critical') risk += 30;
    
    // WebSocket errors
    const wsErrorRate = this.wsErrors.length;
    if (wsErrorRate >= this.thresholds.wsErrorRate) risk += 30;
    
    // Recent spikes
    const maxRecent = Math.max(...recent.map(s => s.latency));
    if (maxRecent > this.thresholds.latencyCritical * 1.5) risk += 20;
    
    return Math.min(100, risk);
  },
  
  // Predict time to issue (in seconds, or null if none predicted)
  predictTimeToIssue() {
    const trend = this.calculateTrend();
    const risk = this.calculateRisk();
    
    if (risk < 50) return null;
    if (trend.direction === 'critical') return 30; // 30 seconds
    if (trend.direction === 'rising') return 120; // 2 minutes
    if (risk > 70) return 60; // 1 minute
    
    return null;
  },
  
  // Generate insights
  generateInsights() {
    const insights = [];
    const trend = this.calculateTrend();
    const risk = this.calculateRisk();
    const wsErrorRate = this.wsErrors.length;
    
    if (this.history.length < 5) {
      return ['📊 Collecting baseline data...'];
    }
    
    const recent = this.history.slice(-10);
    const avgLatency = recent.reduce((sum, s) => sum + s.latency, 0) / recent.length;
    
    if (trend.direction === 'rising' || trend.direction === 'critical') {
      insights.push(`📈 Latency trending upward (+${trend.slope}ms/s)`);
