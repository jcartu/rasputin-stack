    // Color code utilization
    let utilColor = 'var(--green)';
    if (gpu.utilization >= 80) utilColor = 'var(--red)';
    else if (gpu.utilization >= 50) utilColor = 'var(--amber)';
    
    // Color code temperature
    let tempColor = 'var(--green)';
    if (gpu.temperature >= 75) tempColor = 'var(--red)';
    else if (gpu.temperature >= 60) tempColor = 'var(--amber)';
    
    const memPct = Math.round((gpu.memoryUsed / gpu.memoryTotal) * 100);
    
    el.innerHTML = `
