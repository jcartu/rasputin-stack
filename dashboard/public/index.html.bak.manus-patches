function updateFilterBadges() {
  Object.keys(streamCounts).forEach(k => {
    const badge = document.getElementById(`badge-${k}`);
    if (badge) {
      const oldVal = badge.textContent;
      const newVal = String(streamCounts[k]);
      if (oldVal !== newVal) {
        badge.textContent = newVal;
        badge.classList.remove('updated');
        void badge.offsetWidth; // force reflow
        badge.classList.add('updated');
      }
    }
  });
}

function incrementStreamCount(type) {
  streamCounts[type] = (streamCounts[type] || 0) + 1;
  streamCounts.all++;
  updateFilterBadges();
}

// ─── Tool Calls ───
function addToolFeedItem(msg) {
  // Track file operations in workspace panel
  const tool = msg.tool || msg.description || '';
  if (typeof window.addWorkspaceFile === 'function') {
    const input = msg.input || {};
    const path = input.file_path || input.path || input.file || '';
    if (path && (tool === 'read' || tool === 'write' || tool === 'edit')) {
      window.addWorkspaceFile(path, tool);
    }
  }

  const container = $('#tools-container');
  if (!container) return;
  const placeholder = container.querySelector('[data-placeholder]');
  if (placeholder) placeholder.remove();
  
  const desc = msg.description || msg.tool || 'tool';
  const params = msg.input ? Object.keys(msg.input).map(k => {
    const v = String(msg.input[k]).slice(0, 60);
    return `${k}: ${v}`;
  }).join(' · ') : '';
  const time = formatTimestamp(msg.ts);
  
  const item = document.createElement('div');
  item.className = 'tool-feed-item';
  item.dataset.toolId = msg.id;
  item.innerHTML = `
    <div class="tool-feed-header">
      <span class="tool-feed-status" style="color: var(--amber);">⏳</span>
      <span style="color: var(--purple); font-weight: 600;">${desc}</span>
      <span class="tool-feed-time">${time}</span>
    </div>
    ${params ? `<div class="tool-feed-desc">${params}</div>` : ''}
  `;
  container.insertBefore(item, container.firstChild);
  while (container.children.length > 30) container.removeChild(container.lastChild);
}

function flushToolGroup() {
  if (_toolGroupBuffer.length < TOOL_GROUP_MIN) {
    // Not enough to group — render individually
    _toolGroupBuffer.forEach(m => renderSingleToolCard(m));
  } else {
    // Create grouped card
    const container = $('#stream-scroll');
    const group = document.createElement('div');
    group.className = 'stream-group-card';
    group.dataset.eventType = 'tool';
    const count = _toolGroupBuffer.length;
    const names = _toolGroupBuffer.map(m => m.description || m.tool || 'tool');
    group.innerHTML = `
      <div class="group-header" onclick="this.parentElement.classList.toggle('expanded')">
        <span class="group-count">${count}</span>
        <span style="color:var(--cyan);font-weight:600;">tool calls</span>
        <span style="color:var(--text-3);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-left:4px;">${names.slice(0,3).join(', ')}${count > 3 ? '…' : ''}</span>
        <span style="color:var(--text-ghost);font-size:0.55rem;">${formatTimestamp(_toolGroupBuffer[0].ts)}</span>
      </div>
      <div class="group-items"></div>
    `;
    const itemsDiv = group.querySelector('.group-items');
    _toolGroupBuffer.forEach(m => {
      const name = m.description || m.tool || 'tool';
      const item = document.createElement('div');
      item.className = 'group-item';
      item.innerHTML = `<span style="color:var(--cyan);">🔧</span><span style="color:var(--text-1);font-weight:500;">${name}</span><span style="margin-left:auto;color:var(--text-ghost);font-size:0.5rem;">${formatTimestamp(m.ts)}</span>`;
      itemsDiv.appendChild(item);
    });
    // Track cards for result matching (store under both id and toolCallId)
    _toolGroupBuffer.forEach(m => {
      state.toolCards[m.id] = group;
      if (m.toolCallId) state.toolCards[m.toolCallId] = group;
    });
    group._addedAt = Date.now();
    container.appendChild(group);
    pruneStream();
  }
  _toolGroupBuffer = [];
  _toolGroupTimer = null;
}

function renderSingleToolCard(msg) {
  const card = document.createElement('div');
  card.className = 'tool-call-card';
  card.id = `tool-${msg.id}`;
  card.dataset.eventType = 'tool';
  
  const displayName = msg.description || msg.tool || '';
  if (!displayName) return;
  
  const time = formatTimestamp(msg.ts);
  const inputSummary = msg.input ? Object.entries(msg.input).map(([k,v]) => {
    const val = String(v).slice(0, 50).replace(/\n/g, ' ');
    return `${k}: ${val}`;
  }).join(' · ').slice(0, 120) : '';
  
  card.innerHTML = `
    <div class="tool-header">
      <div class="tool-spinner"></div>
      <div class="tool-check">
        <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
      </div>
      <span class="tool-name">${displayName}</span>
      <span class="tool-time" style="opacity:1;position:static;margin-left:auto;">${time}</span>
    </div>
    ${inputSummary ? `<div style="padding:2px 12px 6px;font-size:0.6rem;font-family:var(--font-mono);color:var(--text-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${inputSummary}</div>` : ''}
    <div class="tool-result"></div>
  `;

  const container = $('#stream-scroll');
  card._addedAt = Date.now();
  container.appendChild(card);
  pruneStream();
  // Store under both msg.id AND msg.toolCallId so handleToolResult can find it
  state.toolCards[msg.id] = card;
  if (msg.toolCallId) state.toolCards[msg.toolCallId] = card;
  // Also store under a normalized key
  card.dataset.toolId = msg.id || msg.toolCallId || '';
  scrollToBottom();
}

function handleToolCall(msg) {
  addToolFeedItem(msg);
  incrementStreamCount('tool');
  
  const displayName = msg.description || msg.tool || '';
  if (!displayName) return;
  
  // Wire exec/shell commands to workspace terminal
  const tool = msg.tool || msg.description || '';
  const input = msg.input || {};
  if ((tool === 'exec' || tool === 'shell' || tool === 'bash' || tool === 'execute_command' || displayName.includes('exec')) && input.command) {
    window.addWorkspaceTerminal('\x1b[36m❯ ' + input.command + '\x1b[0m', false);
    switchWorkspaceTab('terminal');
  }
  // Wire browser/navigate to workspace preview
  if ((tool === 'browser' || tool === 'navigate' || displayName.includes('browser')) && input.url) {
    window.loadWorkspaceUrl(input.url, input.url);
  }
  
  // Buffer for grouping
  _toolGroupBuffer.push(msg);
  if (_toolGroupTimer) clearTimeout(_toolGroupTimer);
  _toolGroupTimer = setTimeout(flushToolGroup, TOOL_GROUP_WINDOW);
}

function handleToolResult(msg) {
  // Pipe tool results to workspace terminal
  if (msg.result && typeof window.addWorkspaceTerminal === 'function') {
    const result = String(msg.result).trim();
    if (result && result.length > 0 && result !== 'Completed') {
      const lines = result.split('\n').slice(0, 20);
      lines.forEach(line => {
        const isErr = /error|fail|exception|traceback/i.test(line);
        window.addWorkspaceTerminal(line, isErr);
      });
      if (result.split('\n').length > 20) {
        window.addWorkspaceTerminal('  ... (' + (result.split('\n').length - 20) + ' more lines)', false);
      }
    }
  }
  // Update feed panel
  const feedItem = document.querySelector(`[data-tool-id="${msg.toolCallId}"]`);
  if (feedItem) {
    feedItem.classList.add('success');
    const status = feedItem.querySelector('.tool-feed-status');
    if (status) { status.textContent = '✅'; status.style.color = 'var(--green)'; }
  }
  
  const card = state.toolCards[msg.toolCallId];
  if (!card) return;

  // If it's a group card, just mark internally
  if (card.classList.contains('stream-group-card')) {
    delete state.toolCards[msg.toolCallId];
    return;
  }

  card.classList.add('complete');
  const resultEl = card.querySelector('.tool-result');
  if (resultEl) resultEl.textContent = msg.result || 'Completed';
  
  // Auto-collapse after 3s
  setTimeout(() => {
    if (card.parentNode) {
      card.classList.add('collapsed');
      card.onclick = () => card.classList.toggle('collapsed');
    }
  }, 3000);
  
  delete state.toolCards[msg.toolCallId];
  scrollToBottom();
}

