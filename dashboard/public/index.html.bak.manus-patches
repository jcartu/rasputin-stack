            </div>
          </div>
          <div style="font-size: 0.58rem; font-family: var(--font-mono); color: ${tempColor}; font-weight: 700; white-space: nowrap; text-shadow: 0 0 8px ${tempColor}40;">${temp}°C</div>
        </div>
      `;
    }).join('');
  },
  
  updateNetwork(sys) {
    const upKBps = Math.round((sys.netTx || 0) / 1024);
    const downKBps = Math.round((sys.netRx || 0) / 1024);
    
    $('#net-up-modern').textContent = upKBps > 1024 ? `${(upKBps / 1024).toFixed(1)} MB/s` : `${upKBps} KB/s`;
    $('#net-down-modern').textContent = downKBps > 1024 ? `${(downKBps / 1024).toFixed(1)} MB/s` : `${downKBps} KB/s`;
    
    this.netHistory.push({ up: upKBps, down: downKBps });
    if (this.netHistory.length > this.maxNetHistory) this.netHistory.shift();
    
    if (this.netCtx && this.netCanvas) {
      const ctx = this.netCtx;
      const canvas = this.netCanvas;
      const w = canvas.width;
      const h = canvas.height;
      
      ctx.clearRect(0, 0, w, h);
      
      const maxVal = Math.max(...this.netHistory.map(d => Math.max(d.up, d.down)), 100);
      const step = w / this.maxNetHistory;
      
      // Upload (green)
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(46, 213, 115, 0.8)';
      ctx.lineWidth = 2;
      ctx.shadowBlur = 8;
      ctx.shadowColor = 'rgba(46, 213, 115, 0.5)';
      this.netHistory.forEach((d, i) => {
        const x = i * step;
        const y = h - (d.up / maxVal) * h;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();
      ctx.shadowBlur = 0;
      
      // Download (cyan)
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(52, 172, 224, 0.8)';
      ctx.lineWidth = 2;
      ctx.shadowBlur = 8;
      ctx.shadowColor = 'rgba(52, 172, 224, 0.5)';
      this.netHistory.forEach((d, i) => {
        const x = i * step;
        const y = h - (d.down / maxVal) * h;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();
      ctx.shadowBlur = 0;
    }
  },
  
  updateDisk(sys) {
    const readEl = $('#disk-read-modern');
    const writeEl = $('#disk-write-modern');
    if (readEl) readEl.textContent = sys.diskRead ? `${sys.diskRead.toFixed(1)} MB/s` : '0';
    if (writeEl) writeEl.textContent = sys.diskWrite ? `${sys.diskWrite.toFixed(1)} MB/s` : '0';
    
    const container = $('#disk-usage-modern');
    if (!container) return;
    
    const disks = sys.disks || [];
    container.innerHTML = disks.map(disk => {
      const pct = Math.round((disk.used / disk.total) * 100);
      const color = pct > 90 ? '#ff4757' : pct > 70 ? '#f0b429' : '#2ed573';
      
      return `
        <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 3px;">
          <span style="color: var(--text-3); font-size: 0.5rem; min-width: 20px; font-family: var(--font-mono);">${disk.mount || '/'}</span>
          <div style="flex: 1; height: 6px; background: oklch(0.15 0.02 270); border-radius: 3px; overflow: hidden;">
            <div style="height: 100%; background: ${color}; transition: width 0.3s; width: ${pct}%;"></div>
          </div>
          <span style="color: ${color}; font-size: 0.5rem; font-family: var(--font-mono); font-weight: 700; min-width: 28px; text-align: right;">${pct}%</span>
        </div>
      `;
    }).join('');
  },
  
  updateProcesses(processes) {
    // Processes hidden in compact mode — no-op
  }
};

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  ModernMonitor.init();
});

