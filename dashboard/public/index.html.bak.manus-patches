// ═══ WORKSPACE PANEL ═══
function switchWorkspaceTab(tab) {
  document.querySelectorAll('.workspace-tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.workspace-tab[data-tab="${tab}"]`)?.classList.add('active');
  
  ['preview', 'terminal', 'files'].forEach(p => {
    const el = document.getElementById('workspace-' + p);
    if (el) el.style.display = (p === tab) ? 'flex' : 'none';
  });
  
  const iframe = document.getElementById('workspace-iframe');
  if (tab === 'preview' && iframe && iframe.src && iframe.src !== 'about:blank') {
    iframe.style.display = 'block';
    document.getElementById('workspace-preview').style.display = 'none';
  }
}

// Load URL in workspace iframe
window.loadWorkspaceUrl = function(url, title) {
  const iframe = document.getElementById('workspace-iframe');
  const preview = document.getElementById('workspace-preview');
  const urlBar = document.getElementById('workspace-url-bar');
  const urlText = document.getElementById('workspace-url-text');
  
  if (iframe && url) {
    iframe.src = url;
    iframe.style.display = 'block';
    if (preview) preview.style.display = 'none';
    if (urlBar) urlBar.style.display = 'block';
    if (urlText) urlText.textContent = title || url;
    
    // Switch to preview tab
    switchWorkspaceTab('preview');
  }
};

// Add terminal output to workspace
window.addWorkspaceTerminal = function(text, isError) {
  const terminal = document.getElementById('workspace-terminal');
  if (!terminal) return;
  
  // Clear placeholder
  if (terminal.children.length === 1 && terminal.firstChild.style?.opacity) {
    terminal.innerHTML = '';
  }
  
  const line = document.createElement('div');
  line.style.cssText = 'padding: 1px 0; word-break: break-all;';
  
  // Syntax coloring for terminal output
  let colored = text
    .replace(/\x1b\[[0-9;]*m/g, '') // strip ANSI
    .replace(/^(❯ .*)$/, '<span style="color:#00e5ff;font-weight:600;">$1</span>')
    .replace(/(error|Error|ERROR|FATAL|fatal|FAIL|fail)/g, '<span style="color:#ff3d71;font-weight:600;">$1</span>')
    .replace(/(success|Success|OK|ok|PASS|pass|done|Done|DONE|completed|active|running)/gi, '<span style="color:#0dff92;">$1</span>')
    .replace(/(warning|Warning|WARN|warn|deprecated)/gi, '<span style="color:#ffaa00;">$1</span>')
    .replace(/(\d+\.\d+\.\d+\.\d+)/g, '<span style="color:#a78bfa;">$1</span>')
    .replace(/(\/[\w\-\.\/]+)/g, '<span style="color:#a78bfa;">$1</span>')
    .replace(/(\d+(?:\.\d+)?%)/g, '<span style="color:#00e5ff;">$1</span>')
    .replace(/(https?:\/\/[^\s<]+)/g, '<span style="color:#00e5ff;text-decoration:underline;">$1</span>');
  
  if (isError) {
    line.style.cssText += 'color: #ff3d71; background: rgba(255,61,113,0.05); padding: 2px 6px; border-left: 2px solid #ff3d71; margin: 2px 0;';
  }
  
  line.innerHTML = colored;
  terminal.appendChild(line);
  terminal.scrollTop = terminal.scrollHeight;
  
  // Keep max 500 lines
  while (terminal.children.length > 500) terminal.removeChild(terminal.firstChild);
};

// Show file in workspace
window.addWorkspaceFile = function(path, action) {
  const files = document.getElementById('workspace-files');
  if (!files) return;
  
  // Clear placeholder
  if (files.children.length === 1 && files.firstChild.style?.opacity === '0.5') {
    files.innerHTML = '';
  }
  
  const entry = document.createElement('div');
  entry.style.cssText = 'display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid var(--glass-border); font-size: 0.72rem;';
  const icon = action === 'edit' ? '✏️' : action === 'read' ? '📖' : action === 'write' ? '💾' : '📄';
  const color = action === 'edit' ? 'var(--amber)' : action === 'write' ? 'var(--green)' : 'var(--text-2)';
  entry.innerHTML = `<span>${icon}</span><span style="color: ${color}; font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${path.split('/').pop()}</span><span style="color: var(--text-ghost); margin-left: auto; font-size: 0.6rem;">${new Date().toLocaleTimeString('en-US', {hour:'numeric',minute:'2-digit'})}</span>`;
  files.insertBefore(entry, files.firstChild);
  
  // Keep max 50
  while (files.children.length > 50) files.removeChild(files.lastChild);
};

