function renderMissions(data) {
  const container = $('#missions-container');
  if (!container) return;
  
  const updatedEl = $('#missions-updated');
  if (updatedEl && data.updated) {
    const d = new Date(data.updated);
    updatedEl.textContent = 'Updated ' + d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
  }
  
  if (!data.missions || data.missions.length === 0) {
    container.innerHTML = '<div style="color:var(--text-3);text-align:center;padding:20px;font-size:0.7rem;">No active missions</div>';
    return;
  }
  
  // Sort: active first, then by progress desc
  const sorted = [...data.missions].sort((a,b) => {
    const order = {active:0, paused:1, planned:2, done:3};
    return (order[a.status]||9) - (order[b.status]||9) || b.progress - a.progress;
  });
  
  container.innerHTML = sorted.map(m => {
    const statusIcon = {active:'🟢', done:'✅', paused:'⏸️', planned:'📋'}[m.status] || '⚪';
    const barColor = {active:'var(--green)', done:'var(--cyan)', paused:'var(--amber)', planned:'var(--text-3)'}[m.status] || 'var(--text-3)';
    
    const tasksHtml = (m.tasks || []).map(t => {
      const icon = {done:'✅', active:'⚡', planned:'⬜'}[t.status] || '⬜';
      return `<div class="mission-task"><span class="task-icon">${icon}</span> ${t.name}</div>`;
    }).join('');
    
    return `
      <div class="mission-item status-${m.status}" onclick="this.classList.toggle('expanded')">
        <div class="mission-header">
          <span class="mission-name">${statusIcon} ${m.name}</span>
          <span class="mission-eta">${m.progress}% · ${m.eta}</span>
        </div>
        <div class="mission-progress">
          <div class="mission-progress-fill" style="width:${m.progress}%;background:${barColor};"></div>
        </div>
        <div class="mission-desc">${m.desc}</div>
        <div class="mission-tasks">${tasksHtml}</div>
      </div>
    `;
  }).join('');
}

