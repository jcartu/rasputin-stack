function renderAgents(agents) {
  const container = $('#agents-container');
  if (agents.length === 0) {
    container.innerHTML = '<div style="color: var(--text-3); text-align: center; padding: 20px; font-size: 0.7rem;">No active sub-agents</div>';
    return;
  }
  
  // Group by model, separate active vs completed
  const active = agents.filter(a => a.status === 'active' || a.status === 'running');
  const completed = agents.filter(a => a.status !== 'active' && a.status !== 'running');
  
  // Group completed by model
  const modelGroups = {};
  completed.forEach(a => {
    const model = (a.model || 'unknown').replace(/^.*\//, ''); // strip provider prefix
    if (!modelGroups[model]) modelGroups[model] = { count: 0, totalTokens: 0, totalRuntime: 0, lastTask: '' };
    modelGroups[model].count++;
    modelGroups[model].totalTokens += (a.tokenCount || 0);
    modelGroups[model].totalRuntime += (a.runtime || 0);
    if (a.task && a.task !== 'Processing...') modelGroups[model].lastTask = a.task.slice(0, 80);
  });
  
  const modelColors = {
    'claude-opus-4-6': '#c084fc', 'claude-sonnet-4-5': '#818cf8',
    'gemini-3-flash-preview': '#34d399', 'grok-4-1-fast-non-reasoning': '#f97316'
  };
  
  let html = '';
  
  // Active agents - show individually with pulse
  active.forEach(agent => {
    const shortModel = (agent.model || '').replace(/^.*\//, '');
    const color = modelColors[shortModel] || '#00d4ff';
    html += `
      <div class="agent-item active" style="border-left: 2px solid ${color};">
        <div class="agent-header">
          <div class="agent-status-dot" style="background:${color};box-shadow:0 0 8px ${color};animation:blink 1.5s ease-in-out infinite;"></div>
          <span class="agent-label">${agent.label}</span>
          <span class="agent-model" style="color:${color};">${shortModel}</span>
        </div>
        <div class="agent-task">${(agent.task || '').slice(0, 100)}</div>
        <div class="agent-meta"><span>⏱ ${Math.floor((agent.runtime||0) / 60)}m</span><span style="color:${color};">🪙 ${(agent.tokenCount||0).toLocaleString()}</span></div>
      </div>`;
  });
  
  // Completed - grouped by model
  const groupKeys = Object.keys(modelGroups).sort((a, b) => modelGroups[b].count - modelGroups[a].count);
  groupKeys.forEach(model => {
    const g = modelGroups[model];
    const color = modelColors[model] || '#64748b';
    const avgRuntime = Math.round(g.totalRuntime / g.count / 60);
    html += `
      <div style="padding: 6px 8px; border-bottom: 1px solid oklch(0.15 0.02 270 / 0.15); display: flex; align-items: center; gap: 8px;">
        <div style="width: 6px; height: 6px; border-radius: 50%; background: ${color}; opacity: 0.5; flex-shrink: 0;"></div>
        <div style="flex: 1; min-width: 0;">
          <div style="display: flex; align-items: center; gap: 6px;">
            <span style="font-size: 0.65rem; font-weight: 700; color: ${color}; font-family: var(--font-mono);">${model}</span>
            <span style="font-size: 0.55rem; color: var(--text-3); margin-left: auto;">×${g.count}</span>
          </div>
          <div style="display: flex; gap: 8px; font-size: 0.5rem; color: var(--text-3); margin-top: 2px;">
            <span>~${avgRuntime}m avg</span>
            <span style="color: ${color}80;">🪙 ${g.totalTokens.toLocaleString()}</span>
          </div>
        </div>
      </div>`;
  });
  
  // Summary footer
  html += `<div style="padding: 6px 8px; text-align: center; font-size: 0.5rem; color: var(--text-ghost); font-family: var(--font-mono);">${active.length} active · ${completed.length} completed · ${agents.length} total</div>`;
  
  container.innerHTML = html;
}

// ─── CHAT ENGINE v2 — Full Telegram Replacement ───
function initChat() {
  const messages = $('#chat-messages');
  const textarea = $('#chat-textarea');
  const sendBtn = $('#chat-send-btn');
  const attachBtn = $('#chat-attach-btn');
  const voiceBtn = $('#chat-voice-btn');
  const fileInput = $('#chat-file-input');
  const scrollBtn = $('#chat-scroll-btn');
  const unreadBadge = $('#chat-unread-badge');
  const dropOverlay = $('#chat-drop-overlay');
  const replyBar = $('#chat-reply-bar');
  const replyText = $('#chat-reply-text');
  const replyClose = $('#chat-reply-close');
  const searchBar = $('#chat-search-bar');
  const searchInput = $('#chat-search-input');
  const searchCount = $('#chat-search-count');
  const searchClose = $('#chat-search-close');
  const searchToggle = $('#chat-search-toggle');
  const clearBtn = $('#chat-clear-btn');
  const lightbox = $('#chat-lightbox');
  const lbImg = $('#chat-lb-img');
  const lbClose = $('#chat-lb-close');
  const connStatus = $('#chat-conn-status');

  let isRecording = false;
  let mediaRecorder = null;
  let audioChunks = [];
  let msgIdCounter = 0;
  let unreadCount = 0;
  let replyToId = null;
  let replyToText = '';
  let isAtBottom = true;
  let lastDateStr = '';
  let searchMatches = [];
  let searchIdx = -1;

  // ─── Markdown setup ───
  function setupMarked() {
    if (typeof marked === 'undefined') return;
    const renderer = new marked.Renderer();
    
    // Custom code block with copy button + language label
    renderer.code = function(code, lang) {
      // Handle marked v12+ where code is an object {text, lang}
      if (typeof code === 'object' && code !== null) {
        lang = code.lang || '';
        code = code.text || '';
      }
      const langLabel = lang || 'code';
      const highlighted = (typeof hljs !== 'undefined' && lang && hljs.getLanguage(lang))
        ? hljs.highlight(code, { language: lang }).value
        : (typeof hljs !== 'undefined' ? hljs.highlightAuto(code).value : escapeHtml(code));
      const id = 'code-' + (++msgIdCounter);
      return `<div class="chat-code-block"><div class="chat-code-header"><span>${escapeHtml(langLabel)}</span><button class="chat-code-copy" data-code-id="${id}" onclick="window._chatCopyCode(this)">Copy</button></div><pre><code id="${id}" class="hljs">${highlighted}</code></pre></div>`;
    };
    
    // Links open in new tab
    renderer.link = function(href, title, text) {
      // marked v12+ passes object
      if (typeof href === 'object' && href !== null) {
        text = href.text || '';
        title = href.title || '';
        href = href.href || '';
      }
      const t = title ? ` title="${escapeHtml(title)}"` : '';
      return `<a href="${escapeHtml(href)}" target="_blank" rel="noopener"${t}>${text}</a>`;
    };

    // Images with lightbox
    renderer.image = function(href, title, text) {
      if (typeof href === 'object' && href !== null) {
        text = href.text || href.title || '';
        title = href.title || '';
        href = href.href || '';
      }
      return `<img class="chat-media-img" src="${escapeHtml(href)}" alt="${escapeHtml(text || '')}" onclick="window._chatLightbox(this.src)" loading="lazy">`;
    };

    marked.setOptions({
      renderer,
      gfm: true,
      breaks: true,
      smartypants: false,
      headerIds: false,
      mangle: false
    });
  }
  setupMarked();

  function escapeHtml(s) {
    if (!s) return '';
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderMarkdown(text) {
    if (!text) return '';
    // Clean noise
    text = text.replace(/\[message_id:\s*\d+\]\s*/g, '').replace(/\[media attached:.*?\]\n?/gs, '').trim();
    if (!text) return '';
    
    // Check for SVG content
    const svgMatch = text.match(/<svg[\s\S]*?<\/svg>/i);
    if (svgMatch) {
      const before = text.slice(0, text.indexOf(svgMatch[0]));
      const after = text.slice(text.indexOf(svgMatch[0]) + svgMatch[0].length);
      let html = '';
      if (before.trim()) html += renderMarkdownText(before);
      html += `<div class="chat-svg-render">${svgMatch[0]}</div>`;
      if (after.trim()) html += renderMarkdownText(after);
      return html;
    }

    // Check for HTML content (has tags beyond basic markdown)
    const hasHtml = /<(?:div|span|table|iframe|canvas|form|section|article|header|footer|nav|main|aside|details|summary|figure|figcaption|video|audio|source|picture|object|embed|img[^>]*>)[^>]*>/i.test(text);
    if (hasHtml) {
      // Render in sandboxed container
      return `<div class="chat-html-render">${text}</div>`;
    }

    return renderMarkdownText(text);
  }

  function renderMarkdownText(text) {
    if (typeof marked !== 'undefined') {
      try { return marked.parse(text); } catch(e) { console.warn('Marked parse error:', e); }
    }
    // Fallback: basic rendering
    let html = escapeHtml(text);
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
    html = html.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank">$1</a>');
    html = html.replace(/\n/g, '<br>');
    return html;
  }

  // ─── Copy code ───
  window._chatCopyCode = function(btn) {
    const id = btn.getAttribute('data-code-id');
    const codeEl = document.getElementById(id);
    if (!codeEl) return;
    navigator.clipboard.writeText(codeEl.textContent).then(() => {
      btn.textContent = '✓ Copied';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
    });
  };

  // ─── Lightbox ───
  window._chatLightbox = function(src) {
    lbImg.src = src;
    lightbox.classList.add('active');
  };
  if (lbClose) lbClose.onclick = () => lightbox.classList.remove('active');
  if (lightbox) lightbox.onclick = (e) => { if (e.target === lightbox) lightbox.classList.remove('active'); };

  // ─── Date separator ───
  function maybeAddDateSep(ts) {
    const d = new Date(ts);
    const dateStr = d.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' });
    if (dateStr !== lastDateStr) {
      lastDateStr = dateStr;
      const sep = document.createElement('div');
      sep.className = 'chat-date-sep';
      sep.innerHTML = `<span>${dateStr}</span>`;
      messages.appendChild(sep);
    }
  }

  // ─── Chat History Persistence (localStorage) ───
  const CHAT_STORAGE_KEY = 'nexus_chat_history';
  const CHAT_MAX_STORED = 200;

  function saveChatHistory(role, text, ts, media) {
    try {
      const history = JSON.parse(localStorage.getItem(CHAT_STORAGE_KEY) || '[]');
      history.push({ id: 'h-' + Date.now() + '-' + Math.random().toString(36).slice(2,6), role, text: (text || '').slice(0, 5000), ts: ts || Date.now(), media: media || null });
      // Prune oldest
      while (history.length > CHAT_MAX_STORED) history.shift();
      localStorage.setItem(CHAT_STORAGE_KEY, JSON.stringify(history));
    } catch(e) { console.warn('Chat history save error:', e); }
  }

  function loadChatHistory() {
    try {
      const history = JSON.parse(localStorage.getItem(CHAT_STORAGE_KEY) || '[]');
      if (history.length === 0) return;
      console.log(`[Chat] Loading ${history.length} messages from localStorage`);
      history.forEach(m => {
        addMessage(m.role, m.text, m.ts, m.media, { skipSave: true });
      });
      scrollToBottom(false);
    } catch(e) { console.warn('Chat history load error:', e); }
  }

  function clearChatHistory() {
    try { localStorage.removeItem(CHAT_STORAGE_KEY); } catch(e) {}
  }

  // ─── Scroll management ───
  function scrollToBottom(smooth) {
    requestAnimationFrame(() => {
      messages.scrollTo({ top: messages.scrollHeight, behavior: smooth ? 'smooth' : 'auto' });
    });
  }

  function checkScroll() {
    const threshold = 80;
    isAtBottom = (messages.scrollHeight - messages.scrollTop - messages.clientHeight) < threshold;
    if (scrollBtn) {
      scrollBtn.style.display = isAtBottom ? 'none' : 'flex';
    }
    if (isAtBottom) {
      unreadCount = 0;
      if (unreadBadge) unreadBadge.style.display = 'none';
    }
  }
  messages.addEventListener('scroll', () => requestAnimationFrame(checkScroll));
  if (scrollBtn) scrollBtn.onclick = () => { scrollToBottom(true); unreadCount = 0; if(unreadBadge) unreadBadge.style.display = 'none'; };

  // ─── Build message ───
  let lastMsgRole = null;
  function addMessage(role, content, ts, media, opts = {}) {
    const id = 'msg-' + (++msgIdCounter);
    const timestamp = ts || Date.now();
    
    // Clean content
    content = (content || '').replace(/\[message_id:\s*\d+\]\s*/g, '').replace(/\[media attached:.*?\]\n?/gs, '').trim();
    if (!content && !media) return null;

    maybeAddDateSep(timestamp);

    // Check for message grouping (consecutive same-role messages)
    const isGrouped = (lastMsgRole === role);
    lastMsgRole = role;

    // Wrapper
    const wrap = document.createElement('div');
    wrap.className = `chat-msg-wrap ${role}${isGrouped ? ' grouped' : ''}`;
    wrap.id = id;
    wrap.dataset.ts = timestamp;
    wrap.dataset.role = role;
    wrap.dataset.text = (content || '').slice(0, 200);

    // Avatar (AI only, hidden for user)
    const avatar = document.createElement('div');
    avatar.className = 'chat-avatar';
    avatar.textContent = '🔮';
    wrap.appendChild(avatar);

    // Bubble container (wraps sender + bubble for AI)
    const bubbleWrap = document.createElement('div');
    bubbleWrap.style.cssText = 'flex: 1; min-width: 0;';

    // Sender label (AI messages only, not grouped)
    if (role === 'ai' && !isGrouped) {
      const sender = document.createElement('div');
      sender.className = 'chat-sender';
      sender.textContent = 'Rasputin 2';
      bubbleWrap.appendChild(sender);
    }

    // Bubble
    const bubble = document.createElement('div');
    bubble.className = `chat-bubble ${role}`;

    // Reply quote
    if (opts.replyTo) {
      const quote = document.createElement('div');
      quote.className = 'chat-reply-quote';
      quote.innerHTML = `<div class="reply-author">${role === 'user' ? 'Rasputin 2' : 'You'}</div>${escapeHtml(opts.replyToText || '').slice(0, 100)}`;
      quote.onclick = () => {
        const target = document.getElementById(opts.replyTo);
        if (target) { target.scrollIntoView({ behavior: 'smooth', block: 'center' }); target.style.background = 'oklch(0.68 0.30 290 / 0.1)'; setTimeout(() => target.style.background = '', 1500); }
      };
      bubble.appendChild(quote);
    }

    // Media
    if (media) {
      const mediaEl = renderMedia(media);
      if (mediaEl) bubble.appendChild(mediaEl);
    }

    // Content
    if (content) {
      const contentDiv = document.createElement('div');
      contentDiv.className = 'chat-content';
      contentDiv.innerHTML = renderMarkdown(content);
      bubble.appendChild(contentDiv);
      
      // Highlight code blocks
      if (typeof hljs !== 'undefined') {
        bubble.querySelectorAll('pre code:not(.hljs)').forEach(block => {
          hljs.highlightElement(block);
        });
      }
      
      // Add copy buttons to code blocks that don't have them
      bubble.querySelectorAll('pre').forEach(pre => {
        if (!pre.parentElement.classList.contains('chat-code-block') && !pre.querySelector('.chat-code-header')) {
          const code = pre.querySelector('code');
          if (code) {
            const header = document.createElement('div');
            header.className = 'chat-code-header';
            const lang = (code.className.match(/language-(\w+)/) || ['','code'])[1];
            const copyId = 'code-' + (++msgIdCounter);
            code.id = copyId;
            header.innerHTML = `<span>${escapeHtml(lang)}</span><button class="chat-code-copy" data-code-id="${copyId}" onclick="window._chatCopyCode(this)">Copy</button>`;
            pre.insertBefore(header, pre.firstChild);
          }
        }
      });
      
      // Collapsible long messages (>600 chars or >15 lines)
      const lineCount = (content.match(/\n/g) || []).length + 1;
      if (role === 'ai' && (content.length > 600 || lineCount > 15)) {
        contentDiv.classList.add('chat-content-collapsed');
        const toggle = document.createElement('button');
        toggle.className = 'chat-collapse-toggle';
        toggle.textContent = 'Show more ▾';
        toggle.onclick = () => {
          const collapsed = contentDiv.classList.toggle('chat-content-collapsed');
          toggle.textContent = collapsed ? 'Show more ▾' : 'Show less ▴';
        };
        bubble.appendChild(toggle);
      }
    }

    // Meta (time + status)
    const meta = document.createElement('div');
    meta.className = 'chat-meta';
    const timeStr = new Date(timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    meta.innerHTML = `<span class="chat-time">${timeStr}</span>`;
    if (role === 'user') {
      meta.innerHTML += `<span class="chat-status delivered">✓✓</span>`;
    }
    bubble.appendChild(meta);

    // Hover actions
    const actions = document.createElement('div');
    actions.className = 'chat-msg-actions';
    actions.innerHTML = `
      <button title="Reply" onclick="window._chatReply('${id}')">↩</button>
      <button title="Copy" onclick="window._chatCopyMsg('${id}')">📋</button>
    `;
    bubble.appendChild(actions);

    bubbleWrap.appendChild(bubble);
    wrap.appendChild(bubbleWrap);
    messages.appendChild(wrap);

    // Scroll or show unread
    if (isAtBottom) {
      scrollToBottom(true);
    } else {
      unreadCount++;
      if (unreadBadge) {
        unreadBadge.textContent = unreadCount;
        unreadBadge.style.display = 'flex';
      }
    }

    // Prune old messages (keep 500 max)
    while (messages.children.length > 500) messages.removeChild(messages.firstChild);

    // Persist to localStorage (unless loading from history)
    if (!opts.skipSave) {
      saveChatHistory(role, content, timestamp, media);
    }

    return id;
  }

  // ─── Media rendering ───
  function renderMedia(media) {
    if (!media) return null;
    const container = document.createElement('div');
    
    if (media.type === 'image' || (media.mime && media.mime.startsWith('image/'))) {
      const img = document.createElement('img');
      img.className = 'chat-media-img';
      img.src = media.url || media.data;
      img.alt = media.name || 'image';
      img.loading = 'lazy';
      img.onclick = () => window._chatLightbox(img.src);
      container.appendChild(img);
    } else if (media.type === 'video' || (media.mime && media.mime.startsWith('video/'))) {
      const video = document.createElement('video');
      video.controls = true;
      video.preload = 'metadata';
      video.src = media.url || media.data;
      video.style.maxWidth = '100%';
      video.style.borderRadius = '8px';
      container.appendChild(video);
    } else if (media.type === 'audio' || (media.mime && media.mime.startsWith('audio/'))) {
      const audio = document.createElement('audio');
      audio.controls = true;
      audio.src = media.url || media.data;
      audio.style.width = '100%';
      container.appendChild(audio);
    } else {
      // File card
      const card = document.createElement('div');
      card.className = 'chat-file-card';
      const ext = (media.name || '').split('.').pop().toLowerCase();
      const icons = { pdf: '📕', doc: '📘', docx: '📘', xls: '📗', xlsx: '📗', zip: '📦', rar: '📦', txt: '📄', md: '📝', json: '📋', csv: '📊', py: '🐍', js: '🟡', ts: '🔷', html: '🌐', css: '🎨' };
      const icon = icons[ext] || '📎';
      const size = media.size || '';
      card.innerHTML = `
        <div class="chat-file-icon">${icon}</div>
        <div class="chat-file-info">
          <div class="chat-file-name">${escapeHtml(media.name || 'file')}</div>
          <div class="chat-file-size">${size}</div>
        </div>
      `;
      if (media.url || media.data) {
        card.onclick = () => {
          const a = document.createElement('a');
          a.href = media.url || media.data;
          a.download = media.name || 'file';
          a.click();
        };
      }
      container.appendChild(card);
    }
    return container;
  }

  // ─── Reply system ───
  window._chatReply = function(id) {
    const msg = document.getElementById(id);
    if (!msg) return;
    replyToId = id;
    replyToText = msg.dataset.text || '';
    if (replyText) replyText.textContent = replyToText.slice(0, 80) + (replyToText.length > 80 ? '...' : '');
    if (replyBar) replyBar.classList.add('active');
    if (textarea) textarea.focus();
  };
  if (replyClose) replyClose.onclick = () => { replyToId = null; replyToText = ''; if(replyBar) replyBar.classList.remove('active'); };

  // ─── Copy message ───
  window._chatCopyMsg = function(id) {
    const msg = document.getElementById(id);
    if (!msg) return;
    const text = msg.querySelector('.chat-content')?.textContent || msg.dataset.text || '';
    navigator.clipboard.writeText(text);
  };

  // ─── Typing indicator ───
  let typingEl = null;
  function showTyping() {
    if (typingEl) return;
    typingEl = document.createElement('div');
    typingEl.className = 'chat-typing-indicator';
    typingEl.innerHTML = `
      <div class="chat-avatar" style="background: linear-gradient(135deg, oklch(0.68 0.30 290 / 0.3), oklch(0.55 0.22 260 / 0.3)); border: 1px solid oklch(0.68 0.30 290 / 0.3);">🔮</div>
      <div class="chat-typing-dots"><span></span><span></span><span></span></div>
    `;
    messages.appendChild(typingEl);
    if (isAtBottom) scrollToBottom(true);
  }
  function hideTyping() {
    if (typingEl) { typingEl.remove(); typingEl = null; }
  }

  // ─── Streaming ───
  let streamingWrap = null;
  let streamingBubble = null;
  let streamingContent = null;
  let streamTarget = '';
  let streamRevealed = 0;
  let streamTimer = null;
  let streamStartTs = 0;
  let streamTokens = 0;

  window.startChatStream = function(ts) {
    hideTyping();
    if (streamTimer) { clearInterval(streamTimer); streamTimer = null; }
    // Kill any existing cursors from previous streams
    messages.querySelectorAll('.chat-cursor').forEach(c => c.remove());
    // If there's a previous streaming wrap without completion, finalize it
    if (streamingWrap && streamingContent) {
      streamingContent.querySelectorAll('.chat-cursor').forEach(c => c.remove());
    }
    streamTarget = '';
    streamRevealed = 0;
    streamStartTs = Date.now();
    streamTokens = 0;

    maybeAddDateSep(ts || Date.now());

    // Check grouping
    const isGrouped = (lastMsgRole === 'ai');
    lastMsgRole = 'ai';

    streamingWrap = document.createElement('div');
    streamingWrap.className = `chat-msg-wrap ai${isGrouped ? ' grouped' : ''}`;
    const avatar = document.createElement('div');
    avatar.className = 'chat-avatar';
    avatar.textContent = '🔮';
    streamingWrap.appendChild(avatar);

    const sBubbleWrap = document.createElement('div');
    sBubbleWrap.style.cssText = 'flex: 1; min-width: 0;';

    // Sender label (not grouped)
    if (!isGrouped) {
      const sender = document.createElement('div');
      sender.className = 'chat-sender';
      sender.textContent = 'Rasputin 2';
      sBubbleWrap.appendChild(sender);
    }

    streamingBubble = document.createElement('div');
    streamingBubble.className = 'chat-bubble ai';

    streamingContent = document.createElement('div');
    streamingContent.className = 'chat-content';
    streamingContent.innerHTML = '<span class="chat-cursor"></span>';
    streamingBubble.appendChild(streamingContent);

    sBubbleWrap.appendChild(streamingBubble);
    streamingWrap.appendChild(sBubbleWrap);
    messages.appendChild(streamingWrap);
    if (isAtBottom) scrollToBottom(false);
  };

  window.updateChatStream = function(text) {
    if (!streamingBubble || !streamingContent) return;
    streamTarget = text || '';
    streamTokens++;

    if (!streamTimer) {
      streamTimer = setInterval(() => {
        if (streamRevealed >= streamTarget.length) return;
        // Fast reveal — 8-15 chars per tick
        const chunk = Math.min(8 + Math.floor(Math.random() * 7), streamTarget.length - streamRevealed);
        streamRevealed += chunk;
        const visible = streamTarget.slice(0, streamRevealed);
        
        // Render markdown on every update
        let rendered = renderMarkdown(visible);
        streamingContent.innerHTML = rendered + '<span class="chat-cursor"></span>';

        // Highlight code blocks
        if (typeof hljs !== 'undefined') {
          streamingContent.querySelectorAll('pre code:not(.hljs)').forEach(block => hljs.highlightElement(block));
        }

        if (isAtBottom) scrollToBottom(false);
      }, 16); // 60fps
    }
  };

  window.endChatStream = function() {
    if (streamTimer) { clearInterval(streamTimer); streamTimer = null; }
    if (streamingBubble && streamingContent) {
      // Final render with full markdown
      let rendered = renderMarkdown(streamTarget || '');
      streamingContent.innerHTML = rendered;

      // Highlight code blocks
      if (typeof hljs !== 'undefined') {
        streamingContent.querySelectorAll('pre code:not(.hljs)').forEach(block => hljs.highlightElement(block));
      }

      // Add copy buttons to code blocks
      streamingContent.querySelectorAll('pre').forEach(pre => {
        if (!pre.querySelector('.chat-code-header')) {
          const code = pre.querySelector('code');
          if (code) {
            const header = document.createElement('div');
            header.className = 'chat-code-header';
            const lang = (code.className.match(/language-(\w+)/) || ['','code'])[1];
            const copyId = 'code-' + (++msgIdCounter);
            code.id = copyId;
            header.innerHTML = `<span>${escapeHtml(lang)}</span><button class="chat-code-copy" data-code-id="${copyId}" onclick="window._chatCopyCode(this)">Copy</button>`;
            pre.insertBefore(header, pre.firstChild);
          }
        }
      });

      // Stream stats
      const elapsed = ((Date.now() - streamStartTs) / 1000).toFixed(1);
      const tokSec = streamTokens > 0 && elapsed > 0 ? (streamTokens / elapsed).toFixed(0) : '—';
      
      // Meta
      const meta = document.createElement('div');
      meta.className = 'chat-meta';
      meta.innerHTML = `<span class="chat-stream-stats">⚡ ${elapsed}s</span><span class="chat-time">${new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</span>`;
      streamingBubble.appendChild(meta);

      // Actions
      const id = 'msg-' + (++msgIdCounter);
      if (streamingWrap) {
        streamingWrap.id = id;
        streamingWrap.dataset.text = (streamTarget || '').slice(0, 200);
        streamingWrap.dataset.role = 'ai';
      }
      const actions = document.createElement('div');
      actions.className = 'chat-msg-actions';
      actions.innerHTML = `
        <button title="Reply" onclick="window._chatReply('${id}')">↩</button>
        <button title="Copy" onclick="window._chatCopyMsg('${id}')">📋</button>
      `;
      streamingBubble.appendChild(actions);

      if (isAtBottom) scrollToBottom(true);
    }
    // Kill ALL remaining cursors in chat (prevent stuck animations)
    messages.querySelectorAll('.chat-cursor').forEach(c => c.remove());
    
    // Persist streamed AI message to localStorage + server
    if (streamTarget) {
      saveChatHistory('ai', streamTarget, Date.now(), null);
      // Log AI response to server's chat_history.jsonl
      try {
        if (state.ws && state.ws.readyState === WebSocket.OPEN) {
          state.ws.send(JSON.stringify({ type: 'chat_log_ai', text: streamTarget.slice(0, 4096) }));
        }
      } catch(_) {}
    }
    
    streamingWrap = null;
    streamingBubble = null;
    streamingContent = null;
    streamTarget = '';
    streamRevealed = 0;
  };

  // Periodic cursor cleanup (every 5s, catches any stragglers)
  setInterval(() => {
    if (!streamingContent) { // Only clean when NOT actively streaming
      messages.querySelectorAll('.chat-cursor').forEach(c => c.remove());
    }
  }, 5000);

  // ─── Send message ───
  function sendMessage() {
    const text = textarea.value.trim();
    if (!text) return;

    const opts = {};
    if (replyToId) {
      opts.replyTo = replyToId;
      opts.replyToText = replyToText;
      replyToId = null;
      replyToText = '';
      if (replyBar) replyBar.classList.remove('active');
    }

    addMessage('user', text, Date.now(), null, opts);
    textarea.value = '';
    autoGrow();

    // Send via WebSocket
    if (state.ws && state.ws.readyState === WebSocket.OPEN) {
      state.ws.send(JSON.stringify({ type: 'chat_message', text }));
    }
    showTyping();
  }

  // ─── Input handlers ───
  // ─── Slash commands ───
  const SLASH_COMMANDS = [
    { cmd: '/clear', icon: '🗑️', desc: 'Clear chat history', action: () => { if(confirm('Clear chat?')){ messagesArea.innerHTML=''; localStorage.removeItem('nexus_chat_history'); } } },
    { cmd: '/search', icon: '🔍', desc: 'Search messages', action: () => { const so = $('#chat-search-overlay'); if(so) so.style.display='flex'; } },
    { cmd: '/compact', icon: '📦', desc: 'Send /compact to Rasputin', action: () => { textarea.value='/compact'; sendMessage(); } },
    { cmd: '/voice', icon: '🎙️', desc: 'Toggle voice recording', action: () => { const vb = $('#chat-voice-btn'); if(vb) vb.click(); } },
    { cmd: '/status', icon: '📊', desc: 'Send /status to Rasputin', action: () => { textarea.value='/status'; sendMessage(); } },
    { cmd: '/reset', icon: '🔄', desc: 'Send /reset to Rasputin', action: () => { textarea.value='/reset'; sendMessage(); } },
  ];
  let slashActive = -1;
  const slashMenu = $('#slash-menu');

  function showSlashMenu(filter) {
    if (!slashMenu) return;
    const filtered = SLASH_COMMANDS.filter(c => c.cmd.includes(filter.toLowerCase()));
    if (filtered.length === 0) { hideSlashMenu(); return; }
    slashMenu.innerHTML = filtered.map((c, i) =>
      `<div class="slash-item${i===0?' active':''}" data-idx="${i}"><span class="slash-item-icon">${c.icon}</span><div class="slash-item-info"><div class="slash-item-name">${c.cmd}</div><div class="slash-item-desc">${c.desc}</div></div></div>`
    ).join('');
    slashMenu.classList.add('open');
    slashActive = 0;
    slashMenu.querySelectorAll('.slash-item').forEach((el, i) => {
      el.onclick = () => { filtered[i].action(); hideSlashMenu(); textarea.value = ''; autoGrow(); };
    });
  }
  function hideSlashMenu() { if (slashMenu) { slashMenu.classList.remove('open'); slashActive = -1; } }

  if (sendBtn) sendBtn.addEventListener('click', sendMessage);
  if (textarea) {
    textarea.addEventListener('keydown', (e) => {
      // Slash menu navigation
      if (slashMenu && slashMenu.classList.contains('open')) {
        const items = slashMenu.querySelectorAll('.slash-item');
        if (e.key === 'ArrowDown') { e.preventDefault(); slashActive = Math.min(slashActive + 1, items.length - 1); items.forEach((el,i) => el.classList.toggle('active', i === slashActive)); return; }
        if (e.key === 'ArrowUp') { e.preventDefault(); slashActive = Math.max(slashActive - 1, 0); items.forEach((el,i) => el.classList.toggle('active', i === slashActive)); return; }
        if (e.key === 'Enter') { e.preventDefault(); const active = items[slashActive]; if (active) active.click(); return; }
        if (e.key === 'Escape') { hideSlashMenu(); return; }
      }
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
    textarea.addEventListener('input', () => {
      autoGrow();
      // Slash command detection
      const val = textarea.value;
      if (val.startsWith('/') && val.length > 0 && val.indexOf(' ') === -1) {
        showSlashMenu(val);
      } else {
        hideSlashMenu();
      }
    });
    
    // Paste images
    textarea.addEventListener('paste', (e) => {
      const items = Array.from(e.clipboardData?.items || []);
      const imageItem = items.find(i => i.type.startsWith('image/'));
      if (imageItem) {
        e.preventDefault();
        const file = imageItem.getAsFile();
        if (file) uploadFile(file);
      }
    });
  }

  function autoGrow() {
    if (!textarea) return;
    textarea.style.height = 'auto';
    textarea.style.height = Math.min(textarea.scrollHeight, 200) + 'px';
  }

  // ─── File handling ───
  function uploadFile(file) {
    const reader = new FileReader();
    reader.onload = () => {
      const mediaType = file.type.startsWith('image/') ? 'image' : 
                        file.type.startsWith('video/') ? 'video' :
                        file.type.startsWith('audio/') ? 'audio' : 'file';
      const sizeStr = file.size > 1e6 ? (file.size/1e6).toFixed(1)+'MB' : (file.size/1e3).toFixed(0)+'KB';
      addMessage('user', '', Date.now(), { 
        type: mediaType, url: reader.result, name: file.name, 
        size: sizeStr, mime: file.type 
      });
      if (state.ws && state.ws.readyState === WebSocket.OPEN) {
        state.ws.send(JSON.stringify({ type: 'chat_file', name: file.name, mime: file.type, data: reader.result }));
      }
    };
    reader.readAsDataURL(file);
  }

  if (attachBtn) attachBtn.addEventListener('click', () => fileInput?.click());
  if (fileInput) {
    fileInput.addEventListener('change', (e) => {
      Array.from(e.target.files).forEach(uploadFile);
      fileInput.value = '';
    });
  }

  // ─── Drag & Drop ───
  const chatCard = $('#chat-card');
  if (chatCard) {
    let dragCounter = 0;
    chatCard.addEventListener('dragenter', (e) => {
      e.preventDefault();
      dragCounter++;
      if (dropOverlay) dropOverlay.classList.add('active');
    });
    chatCard.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dragCounter--;
      if (dragCounter <= 0) { dragCounter = 0; if (dropOverlay) dropOverlay.classList.remove('active'); }
    });
    chatCard.addEventListener('dragover', (e) => e.preventDefault());
    chatCard.addEventListener('drop', (e) => {
      e.preventDefault();
      dragCounter = 0;
      if (dropOverlay) dropOverlay.classList.remove('active');
      Array.from(e.dataTransfer.files).forEach(uploadFile);
    });
  }

  // ─── Voice recording ───
  if (voiceBtn) {
    voiceBtn.addEventListener('click', async () => {
      if (!isRecording) {
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];
          mediaRecorder.ondataavailable = (e) => audioChunks.push(e.data);
          mediaRecorder.onstop = () => {
            const blob = new Blob(audioChunks, { type: 'audio/webm' });
            const url = URL.createObjectURL(blob);
            addMessage('user', '', Date.now(), { type: 'audio', url });
            stream.getTracks().forEach(t => t.stop());
            const reader = new FileReader();
            reader.onload = () => {
              if (state.ws && state.ws.readyState === WebSocket.OPEN) {
                state.ws.send(JSON.stringify({ type: 'chat_voice', data: reader.result }));
              }
            };
            reader.readAsDataURL(blob);
          };
          mediaRecorder.start();
          isRecording = true;
          voiceBtn.classList.add('recording');
          voiceBtn.textContent = '⏹️';
        } catch(e) { console.error('Mic denied:', e); }
      } else {
        mediaRecorder.stop();
        isRecording = false;
        voiceBtn.classList.remove('recording');
        voiceBtn.textContent = '🎙️';
      }
    });
  }

  // ─── Search ───
  if (searchToggle) {
    searchToggle.onclick = () => {
      searchBar.classList.toggle('active');
      if (searchBar.classList.contains('active')) searchInput.focus();
      else { searchInput.value = ''; clearSearch(); }
    };
  }
  if (searchClose) searchClose.onclick = () => {
    searchBar.classList.remove('active');
    searchInput.value = '';
    clearSearch();
  };
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.trim().toLowerCase();
      clearSearch();
      if (!q) { searchCount.textContent = ''; return; }
      searchMatches = [];
      messages.querySelectorAll('.chat-msg-wrap').forEach(wrap => {
        const text = (wrap.dataset.text || '').toLowerCase();
        const content = wrap.querySelector('.chat-content');
        if (text.includes(q) || (content && content.textContent.toLowerCase().includes(q))) {
          searchMatches.push(wrap);
          wrap.style.outline = '1px solid oklch(0.68 0.30 290 / 0.4)';
        }
      });
      searchCount.textContent = searchMatches.length + ' found';
      if (searchMatches.length > 0) {
        searchIdx = searchMatches.length - 1;
        searchMatches[searchIdx].scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && searchMatches.length > 0) {
        searchIdx = (searchIdx + (e.shiftKey ? -1 : 1) + searchMatches.length) % searchMatches.length;
        searchMatches[searchIdx].scrollIntoView({ behavior: 'smooth', block: 'center' });
        searchCount.textContent = `${searchIdx + 1}/${searchMatches.length}`;
      }
      if (e.key === 'Escape') { searchBar.classList.remove('active'); searchInput.value = ''; clearSearch(); }
    });
  }
  function clearSearch() {
    searchMatches.forEach(m => m.style.outline = '');
    searchMatches = [];
    searchIdx = -1;
  }

  // ─── Clear chat ───
  if (clearBtn) {
    clearBtn.onclick = () => {
      if (confirm('Clear all messages?')) {
        messages.innerHTML = '';
        lastDateStr = '';
        unreadCount = 0;
        clearChatHistory();
        toast('🗑️ Chat history cleared', 'info');
      }
    };
  }

  // ─── Connection status ───
  function updateConnectionStatus(connected) {
    if (!connStatus) return;
    if (connected) {
      connStatus.textContent = 'Online — Direct WebSocket';
      connStatus.style.color = 'var(--green)';
    } else {
      connStatus.textContent = 'Disconnected';
      connStatus.style.color = 'var(--red)';
    }
  }

  // Check WS state periodically
  setInterval(() => {
    updateConnectionStatus(state.ws && state.ws.readyState === WebSocket.OPEN);
  }, 3000);

  // ─── Expose for message routing ───
  window.addChatMessage = function(role, text, ts, media) {
    hideTyping();
    addMessage(role, text, ts, media);
  };
  // Internal access for history loading (with opts like skipSave)
  window._chatAddMessageInternal = function(role, text, ts, media, opts) {
