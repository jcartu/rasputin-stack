    .catch(() => toast('❌ Memory search failed', 'error'));
}

function fuzzyMatch(query, text) {
  const q = query.toLowerCase();
  const t = text.toLowerCase();
  if (!q) return { match: true, score: 0, highlighted: text };
  if (t.includes(q)) return { match: true, score: 100 - t.indexOf(q), highlighted: text.replace(new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi'), '<mark>$1</mark>') };
  let qi = 0, score = 0;
  for (let i = 0; i < t.length && qi < q.length; i++) {
    if (t[i] === q[qi]) { qi++; score += (i === 0 || t[i-1] === ' ') ? 10 : 1; }
  }
  return qi === q.length ? { match: true, score, highlighted: text } : { match: false, score: 0, highlighted: text };
}

function openCommandPalette() {
  const overlay = $('#cmd-overlay');
  overlay.classList.add('visible');
  const input = $('#cmd-input');
  input.value = '';
  input.focus();
  cmdSelectedIdx = 0;
  renderCommandResults('');
}

function closeCommandPalette() {
  $('#cmd-overlay').classList.remove('visible');
}

function renderCommandResults(query) {
  const container = $('#cmd-results');
  container.innerHTML = '';

  let items;
  if (!query) {
    // Show recent, then all
    const recent = getCmdRecent();
    const recentCmds = recent.map(id => commands.find(c => c.id === id)).filter(Boolean);
    if (recentCmds.length) {
      const label = document.createElement('div');
      label.className = 'cmd-section-label';
      label.textContent = 'Recent';
      container.appendChild(label);
      recentCmds.forEach(cmd => container.appendChild(makeCmdItem(cmd, false)));
      const label2 = document.createElement('div');
      label2.className = 'cmd-section-label';
      label2.textContent = 'All Commands';
      container.appendChild(label2);
    }
    items = commands;
  } else {
    items = commands
      .map(cmd => ({ cmd, ...fuzzyMatch(query, cmd.name + ' ' + cmd.desc) }))
      .filter(r => r.match)
      .sort((a, b) => b.score - a.score)
      .map(r => ({ ...r.cmd, _highlighted: fuzzyMatch(query, r.cmd.name).highlighted }));
  }

  if (items.length === 0) {
    container.innerHTML = '<div class="cmd-empty">No matching commands</div>';
    return;
  }

  items.forEach(cmd => container.appendChild(makeCmdItem(cmd, !!query)));

  // Select first actionable item
  const allItems = container.querySelectorAll('.cmd-item');
  cmdSelectedIdx = 0;
  if (allItems[0]) allItems[0].classList.add('selected');
}

function makeCmdItem(cmd, useHighlight) {
  const el = document.createElement('div');
  el.className = 'cmd-item';
  el.dataset.cmdId = cmd.id;
  const catClass = cmd.cat || 'nav';
  el.innerHTML = `
    <div class="cmd-icon ${catClass}">${cmd.icon}</div>
    <div class="cmd-text">
      <div class="cmd-name">${useHighlight && cmd._highlighted ? cmd._highlighted : cmd.name}</div>
      <div class="cmd-desc">${cmd.desc}</div>
    </div>
    ${cmd.key ? `<kbd class="cmd-key">${cmd.key}</kbd>` : ''}
  `;
  el.addEventListener('click', () => executeCmd(cmd));
  el.addEventListener('mouseenter', () => {
    const all = el.parentElement.querySelectorAll('.cmd-item');
    all.forEach((item, i) => { item.classList.remove('selected'); if (item === el) cmdSelectedIdx = i; });
    el.classList.add('selected');
  });
  return el;
}

function executeCmd(cmd) {
  addCmdRecent(cmd.id);
  closeCommandPalette();
  cmd.action();
}

$('#cmd-input').addEventListener('input', (e) => {
  cmdSelectedIdx = 0;
  renderCommandResults(e.target.value.trim());
});

$('#cmd-input').addEventListener('keydown', (e) => {
  const items = $('#cmd-results').querySelectorAll('.cmd-item');
  if (e.key === 'Escape') {
    e.preventDefault();
    closeCommandPalette();
  } else if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (items.length) {
      items[cmdSelectedIdx]?.classList.remove('selected');
      cmdSelectedIdx = (cmdSelectedIdx + 1) % items.length;
      items[cmdSelectedIdx]?.classList.add('selected');
      items[cmdSelectedIdx]?.scrollIntoView({ block: 'nearest' });
    }
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (items.length) {
      items[cmdSelectedIdx]?.classList.remove('selected');
      cmdSelectedIdx = (cmdSelectedIdx - 1 + items.length) % items.length;
      items[cmdSelectedIdx]?.classList.add('selected');
      items[cmdSelectedIdx]?.scrollIntoView({ block: 'nearest' });
    }
  } else if (e.key === 'Enter') {
    e.preventDefault();
    const selected = items[cmdSelectedIdx];
    if (selected) selected.click();
  }
});

// ─── Voice Chat ───
const voiceState = {
  recognition: null,
  isRecording: false,
};

function initVoiceChat() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    toast('⚠️ Speech recognition not supported', 'error');
    $('#mic-btn').disabled = true;
    return;
  }

  voiceState.recognition = new SpeechRecognition();
  voiceState.recognition.continuous = false;
  voiceState.recognition.interimResults = false;
  voiceState.recognition.lang = 'en-US';

  voiceState.recognition.onstart = () => {
    voiceState.isRecording = true;
    $('#mic-btn').classList.add('recording');
    $('#voice-status').textContent = '🎤 Listening...';
    $('#voice-status').classList.add('listening');
  };

  voiceState.recognition.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    var _ci = $('#chat-textarea') || $('#chat-input'); if(_ci) _ci.value = transcript;
    sendMessage(transcript);
  };

  voiceState.recognition.onerror = (event) => {
    console.error('Speech recognition error:', event.error);
    stopRecording();
    if (event.error !== 'no-speech') {
      toast('❌ Speech error: ' + event.error, 'error');
    }
  };

  voiceState.recognition.onend = () => {
