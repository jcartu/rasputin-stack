/* ═══ SMOOTH COUNTER ANIMATION — Numbers tick up/down ═══ */
const _counterState = {};
function animateCounter(el, newVal, suffix = '%', duration = 400) {
  if (!el) return;
  const key = el.id || el.dataset.counterId || (el.dataset.counterId = 'c' + Math.random().toString(36).slice(2,8));
  const state = _counterState[key] || (_counterState[key] = { current: 0, raf: null });
  if (state.current === newVal) return;
  if (state.raf) cancelAnimationFrame(state.raf);
  const from = state.current;
  const start = performance.now();
  const step = (now) => {
    const t = Math.min((now - start) / duration, 1);
    const eased = 1 - Math.pow(1 - t, 3); // ease-out cubic
    const val = Math.round(from + (newVal - from) * eased);
    el.textContent = val + suffix;
    if (t < 1) { state.raf = requestAnimationFrame(step); }
    else { state.current = newVal; state.raf = null; }
  };
  state.raf = requestAnimationFrame(step);
}

