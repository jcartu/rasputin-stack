<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Latency Analytics • ALFIE Nexus</title>
  <link rel="stylesheet" href="shared-styles.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    body {
      background: #0a0e15;
      color: #c5d1eb;
      font-family: 'SF Mono', 'Monaco', 'Cascadia Code', monospace;
      margin: 0;
      padding: 0;
      overflow-x: hidden;
    }

    .dashboard {
      max-width: 1800px;
      margin: 0 auto;
      padding: 20px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 1px solid #1e2836;
    }

    .header h1 {
      margin: 0;
      font-size: 32px;
      font-weight: 600;
      background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .status-badge {
      padding: 8px 16px;
      background: rgba(0, 212, 255, 0.1);
      border: 1px solid rgba(0, 212, 255, 0.3);
      border-radius: 8px;
      font-size: 14px;
      color: #00d4ff;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .stat-card {
      background: linear-gradient(135deg, rgba(30, 40, 54, 0.8) 0%, rgba(20, 28, 40, 0.9) 100%);
      border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 12px;
      padding: 20px;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #00d4ff 0%, #0099ff 100%);
    }

    .stat-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #7a8ba0;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 36px;
      font-weight: 700;
      color: #00d4ff;
      margin-bottom: 4px;
    }

    .stat-unit {
      font-size: 18px;
      color: #7a8ba0;
      margin-left: 4px;
    }

    .stat-sub {
      font-size: 13px;
      color: #5a6a80;
      margin-top: 8px;
    }

    .chart-section {
      background: rgba(30, 40, 54, 0.6);
      border: 1px solid rgba(0, 212, 255, 0.15);
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .chart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .chart-title {
      font-size: 18px;
      font-weight: 600;
      color: #c5d1eb;
    }

    .chart-subtitle {
      font-size: 13px;
      color: #7a8ba0;
      margin-top: 4px;
    }

    .percentile-markers {
      display: flex;
      gap: 20px;
      margin-top: 15px;
    }

    .marker {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
    }

    .marker-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }

    .marker-dot.p50 { background: #00d4ff; }
    .marker-dot.p95 { background: #ffa500; }
    .marker-dot.p99 { background: #ff4444; }

    .gpu-correlation {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-top: 30px;
    }

    .correlation-card {
      background: rgba(20, 28, 40, 0.8);
      border: 1px solid rgba(0, 212, 255, 0.15);
      border-radius: 12px;
      padding: 20px;
    }

    .alert-box {
      background: rgba(255, 68, 68, 0.1);
      border: 1px solid rgba(255, 68, 68, 0.3);
      border-radius: 8px;
      padding: 15px;
      margin-top: 20px;
      display: none;
    }

    .alert-box.active {
      display: block;
    }

    .alert-title {
      font-size: 14px;
      font-weight: 600;
      color: #ff4444;
      margin-bottom: 8px;
    }

    .alert-body {
      font-size: 13px;
      color: #c5d1eb;
    }

    canvas {
      max-height: 300px;
    }

    .trend-indicator {
      display: inline-block;
      margin-left: 8px;
      font-size: 14px;
    }

    .trend-indicator.up { color: #ff4444; }
    .trend-indicator.down { color: #00ff88; }
  </style>
</head>
<body>
  <div id="nav-placeholder"></div>

  <div class="dashboard">
    <div class="header">
      <div>
        <h1>⚡ Latency Analytics</h1>
        <div class="stat-sub">Production observability • P50/P95/P99 • GPU correlation</div>
      </div>
      <div class="status-badge" id="status">● LIVE</div>
    </div>

    <!-- Key Metrics Grid -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">P50 Latency (Median)</div>
        <div class="stat-value" id="p50">—<span class="stat-unit">ms</span></div>
        <div class="stat-sub">50% of requests faster than this</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">P95 Latency</div>
        <div class="stat-value" id="p95">—<span class="stat-unit">ms</span></div>
        <div class="stat-sub">95% of requests faster than this</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">P99 Latency (Tail)</div>
        <div class="stat-value" id="p99">—<span class="stat-unit">ms</span></div>
        <div class="stat-sub">99% of requests faster than this</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Time to First Token</div>
        <div class="stat-value" id="ttft">—<span class="stat-unit">ms</span></div>
        <div class="stat-sub">P95 streaming start latency</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Total Requests</div>
        <div class="stat-value" id="totalRequests">—</div>
        <div class="stat-sub" id="sampleCount">Last 1000 samples</div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Avg Latency</div>
        <div class="stat-value" id="avgLatency">—<span class="stat-unit">ms</span></div>
        <div class="stat-sub">Mean response time (avg lies!)</div>
      </div>
    </div>

    <!-- Latency Distribution Histogram -->
    <div class="chart-section">
      <div class="chart-header">
        <div>
          <div class="chart-title">Latency Distribution</div>
          <div class="chart-subtitle">Histogram showing response time distribution (last 1000 requests)</div>
        </div>
      </div>
      <canvas id="histogramChart"></canvas>
      <div class="percentile-markers">
        <div class="marker">
          <div class="marker-dot p50"></div>
          <span>P50: <strong id="p50-marker">—</strong> ms</span>
        </div>
        <div class="marker">
          <div class="marker-dot p95"></div>
          <span>P95: <strong id="p95-marker">—</strong> ms</span>
        </div>
        <div class="marker">
          <div class="marker-dot p99"></div>
          <span>P99: <strong id="p99-marker">—</strong> ms</span>
        </div>
      </div>
    </div>

    <!-- Time to First Token Breakdown -->
    <div class="chart-section">
      <div class="chart-header">
        <div>
          <div class="chart-title">TTFT (Time to First Token)</div>
          <div class="chart-subtitle">Critical for streaming UX — measures perceived responsiveness</div>
        </div>
      </div>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">TTFT P50</div>
          <div class="stat-value" id="ttft-p50">—<span class="stat-unit">ms</span></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">TTFT P95</div>
          <div class="stat-value" id="ttft-p95">—<span class="stat-unit">ms</span></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">TTFT P99</div>
          <div class="stat-value" id="ttft-p99">—<span class="stat-unit">ms</span></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">TTFT Avg</div>
          <div class="stat-value" id="ttft-avg">—<span class="stat-unit">ms</span></div>
        </div>
      </div>
    </div>

    <!-- GPU Correlation (UNIQUE TO ALFIE!) -->
    <div class="chart-section">
      <div class="chart-header">
        <div>
          <div class="chart-title">🎮 GPU Correlation</div>
          <div class="chart-subtitle">Unique to ALFIE: Correlate latency spikes with GPU utilization</div>
        </div>
      </div>
      <div class="gpu-correlation">
        <div class="correlation-card">
          <div class="chart-title" style="font-size: 16px; margin-bottom: 15px;">GPU Utilization</div>
          <canvas id="gpuChart"></canvas>
        </div>
        <div class="correlation-card">
          <div class="chart-title" style="font-size: 16px; margin-bottom: 15px;">Latency vs GPU</div>
          <canvas id="correlationChart"></canvas>
        </div>
      </div>
      <div class="alert-box" id="gpuAlert">
        <div class="alert-title">⚠️ GPU Bottleneck Detected</div>
        <div class="alert-body">High GPU utilization (>90%) correlates with P95 latency spike. Consider scaling or optimizing GPU workload.</div>
      </div>
    </div>

    <!-- Latency Trend (Last 20 samples) -->
    <div class="chart-section">
      <div class="chart-header">
        <div>
          <div class="chart-title">Latency Trend</div>
          <div class="chart-subtitle">Rolling window showing recent request latencies</div>
        </div>
      </div>
      <canvas id="trendChart"></canvas>
    </div>

  </div>

  <script src="shared-nav.js"></script>
  <script>
    let ws = null;
    let histogramChart = null;
    let trendChart = null;
    let gpuChart = null;
    let correlationChart = null;
    let latencyHistory = [];
    let gpuHistory = [];
    const MAX_HISTORY = 20;

    // Connect to WebSocket
    function connectWebSocket() {
      const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
      const wsUrl = `${protocol}//${window.location.host}`;
      
      ws = new WebSocket(wsUrl);
      
      ws.onopen = () => {
        console.log('WebSocket connected');
        document.getElementById('status').textContent = '● LIVE';
        document.getElementById('status').style.background = 'rgba(0, 255, 136, 0.1)';
        document.getElementById('status').style.borderColor = 'rgba(0, 255, 136, 0.3)';
        document.getElementById('status').style.color = '#00ff88';
      };
      
      ws.onmessage = (event) => {
        try {
          const msg = JSON.parse(event.data);
          if (msg.type === 'telemetry' && msg.data.latency) {
            updateLatencyStats(msg.data.latency, msg.data.gpu);
          }
        } catch (e) {
          console.error('Failed to parse WebSocket message:', e);
        }
      };
      
      ws.onclose = () => {
        console.log('WebSocket disconnected, reconnecting...');
        document.getElementById('status').textContent = '○ RECONNECTING';
        document.getElementById('status').style.background = 'rgba(255, 165, 0, 0.1)';
        document.getElementById('status').style.borderColor = 'rgba(255, 165, 0, 0.3)';
        document.getElementById('status').style.color = '#ffa500';
        setTimeout(connectWebSocket, 3000);
      };
    }

    // Update latency statistics
    function updateLatencyStats(latency, gpu) {
      // Update key metrics
      document.getElementById('p50').innerHTML = `${latency.latency.p50}<span class="stat-unit">ms</span>`;
      document.getElementById('p95').innerHTML = `${latency.latency.p95}<span class="stat-unit">ms</span>`;
      document.getElementById('p99').innerHTML = `${latency.latency.p99}<span class="stat-unit">ms</span>`;
      document.getElementById('avgLatency').innerHTML = `${latency.latency.avg}<span class="stat-unit">ms</span>`;
      document.getElementById('totalRequests').textContent = latency.totalRequests.toLocaleString();
      document.getElementById('sampleCount').textContent = `Last ${latency.sampleCount} samples`;

      // Update TTFT metrics
      document.getElementById('ttft').innerHTML = `${latency.ttft.p95}<span class="stat-unit">ms</span>`;
      document.getElementById('ttft-p50').innerHTML = `${latency.ttft.p50}<span class="stat-unit">ms</span>`;
      document.getElementById('ttft-p95').innerHTML = `${latency.ttft.p95}<span class="stat-unit">ms</span>`;
      document.getElementById('ttft-p99').innerHTML = `${latency.ttft.p99}<span class="stat-unit">ms</span>`;
      document.getElementById('ttft-avg').innerHTML = `${latency.ttft.avg}<span class="stat-unit">ms</span>`;

      // Update markers
      document.getElementById('p50-marker').textContent = latency.latency.p50;
      document.getElementById('p95-marker').textContent = latency.latency.p95;
      document.getElementById('p99-marker').textContent = latency.latency.p99;

      // Update histogram
      updateHistogram(latency.histogram, latency.latency);

      // Track history for trend
      latencyHistory.push(latency.latency.p95);
      if (latencyHistory.length > MAX_HISTORY) latencyHistory.shift();

      if (gpu && gpu.gpus && gpu.gpus.length > 0) {
        const avgGpuUtil = gpu.gpus.reduce((sum, g) => sum + (g.utilization || 0), 0) / gpu.gpus.length;
        gpuHistory.push(avgGpuUtil);
        if (gpuHistory.length > MAX_HISTORY) gpuHistory.shift();

        // Update GPU charts
        updateGpuCharts(gpu);

        // Check for GPU bottleneck
        if (avgGpuUtil > 90 && latency.latency.p95 > latency.latency.avg * 1.5) {
          document.getElementById('gpuAlert').classList.add('active');
        } else {
          document.getElementById('gpuAlert').classList.remove('active');
        }
      }

      // Update trend chart
      updateTrendChart();
    }

    // Initialize histogram chart
    function updateHistogram(histogram, latency) {
      const ctx = document.getElementById('histogramChart').getContext('2d');
      
      if (histogramChart) {
        histogramChart.destroy();
      }

      const labels = histogram.map(h => `${h.min}-${h.max}`);
      const data = histogram.map(h => h.count);

      histogramChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Request Count',
            data: data,
            backgroundColor: 'rgba(0, 212, 255, 0.6)',
            borderColor: 'rgba(0, 212, 255, 1)',
            borderWidth: 1,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              display: false,
            },
            tooltip: {
              backgroundColor: 'rgba(10, 14, 21, 0.95)',
              titleColor: '#00d4ff',
              bodyColor: '#c5d1eb',
              borderColor: 'rgba(0, 212, 255, 0.3)',
              borderWidth: 1,
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(122, 139, 160, 0.1)',
              },
              ticks: {
                color: '#7a8ba0',
              },
            },
            x: {
              grid: {
                display: false,
              },
              ticks: {
                color: '#7a8ba0',
                maxRotation: 45,
                minRotation: 45,
              },
            },
          },
        },
      });
    }

    // Update trend chart
    function updateTrendChart() {
      const ctx = document.getElementById('trendChart').getContext('2d');
      
      if (trendChart) {
        trendChart.destroy();
      }

      const labels = latencyHistory.map((_, i) => `-${latencyHistory.length - i}`);

      trendChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'P95 Latency (ms)',
            data: latencyHistory,
            borderColor: '#00d4ff',
            backgroundColor: 'rgba(0, 212, 255, 0.1)',
            borderWidth: 2,
            tension: 0.4,
            fill: true,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              display: false,
            },
            tooltip: {
              backgroundColor: 'rgba(10, 14, 21, 0.95)',
              titleColor: '#00d4ff',
              bodyColor: '#c5d1eb',
              borderColor: 'rgba(0, 212, 255, 0.3)',
              borderWidth: 1,
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(122, 139, 160, 0.1)',
              },
              ticks: {
                color: '#7a8ba0',
              },
            },
            x: {
              grid: {
                display: false,
              },
              ticks: {
                color: '#7a8ba0',
              },
            },
          },
        },
      });
    }

    // Update GPU correlation charts
    function updateGpuCharts(gpu) {
      // GPU Utilization Chart
      const gpuCtx = document.getElementById('gpuChart').getContext('2d');
      
      if (gpuChart) {
        gpuChart.destroy();
      }

      const gpuLabels = gpuHistory.map((_, i) => `-${gpuHistory.length - i}`);

      gpuChart = new Chart(gpuCtx, {
        type: 'line',
        data: {
          labels: gpuLabels,
          datasets: [{
            label: 'GPU Utilization (%)',
            data: gpuHistory,
            borderColor: '#ff9500',
            backgroundColor: 'rgba(255, 149, 0, 0.1)',
            borderWidth: 2,
            tension: 0.4,
            fill: true,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              display: false,
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              max: 100,
              grid: {
                color: 'rgba(122, 139, 160, 0.1)',
              },
              ticks: {
                color: '#7a8ba0',
              },
            },
            x: {
              grid: {
                display: false,
              },
              ticks: {
                color: '#7a8ba0',
              },
            },
          },
        },
      });

      // Correlation Scatter Plot
      const corrCtx = document.getElementById('correlationChart').getContext('2d');
      
      if (correlationChart) {
        correlationChart.destroy();
      }

      const scatterData = gpuHistory.map((gpu, i) => ({
        x: gpu,
        y: latencyHistory[i] || 0,
      }));

      correlationChart = new Chart(corrCtx, {
        type: 'scatter',
        data: {
          datasets: [{
            label: 'Latency vs GPU',
            data: scatterData,
            backgroundColor: 'rgba(0, 212, 255, 0.6)',
            borderColor: 'rgba(0, 212, 255, 1)',
            borderWidth: 1,
            pointRadius: 5,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              display: false,
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              title: {
                display: true,
                text: 'P95 Latency (ms)',
                color: '#7a8ba0',
              },
              grid: {
                color: 'rgba(122, 139, 160, 0.1)',
              },
              ticks: {
                color: '#7a8ba0',
              },
            },
            x: {
              beginAtZero: true,
              max: 100,
              title: {
                display: true,
                text: 'GPU Utilization (%)',
                color: '#7a8ba0',
              },
              grid: {
                color: 'rgba(122, 139, 160, 0.1)',
              },
              ticks: {
                color: '#7a8ba0',
              },
            },
          },
        },
      });
    }

    // Initialize on load
    window.addEventListener('load', () => {
      connectWebSocket();
    });
  </script>
</body>
</html>
