<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ALFIE Nexus — Knowledge Base</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<style>
:root {
  --bg-base: oklch(0.13 0.02 270);
  --bg-surface: oklch(0.17 0.02 270);
  --bg-elevated: oklch(0.21 0.02 270);
  --bg-hover: oklch(0.25 0.02 270);
  --border: oklch(0.30 0.02 270);
  --text-primary: oklch(0.93 0.01 270);
  --text-secondary: oklch(0.65 0.02 270);
  --text-muted: oklch(0.50 0.02 270);
  --accent: oklch(0.70 0.18 280);
  --accent-dim: oklch(0.45 0.12 280);
  --green: oklch(0.72 0.18 155);
  --amber: oklch(0.75 0.15 75);
  --red: oklch(0.65 0.20 25);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'Space Grotesk', sans-serif;
  background: var(--bg-base);
  color: var(--text-primary);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Top Bar */
.topbar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 20px;
  background: oklch(0.08 0.015 265/0.35);
  backdrop-filter: blur(10px) saturate(150%);
  border-bottom: 1px solid oklch(0.38 0.04 270/0.15);
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 100;
}
.topbar-logo {
  font-size: 16px;
  font-weight: 700;
  background: linear-gradient(135deg,oklch(0.68 0.30 290),oklch(0.78 0.22 195));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  white-space: nowrap;
  text-decoration: none;
}
.topbar-logo:hover { opacity: 0.85; }
.topbar-divider { width: 1px; height: 20px; background: oklch(0.38 0.04 270/0.2); }
.nav-link {
  color: oklch(0.70 0.18 280);
  font-size: 12px;
  text-decoration: none;
  padding: 5px 12px;
  border: 1px solid oklch(0.30 0.02 280);
  border-radius: 6px;
  white-space: nowrap;
  transition: all .2s;
}
.nav-link:hover { border-color: oklch(0.70 0.18 280); background: oklch(0.70 0.18 280/0.1); }
.nav-link.active { background: oklch(0.70 0.18 280/0.15); border-color: oklch(0.70 0.18 280); color: oklch(0.78 0.22 195); }
.topbar-spacer { flex: 1; }
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-left: auto;
  font-size: 13px;
  color: var(--text-secondary);
}
.breadcrumb span { cursor: pointer; }
.breadcrumb span:hover { color: var(--accent); }
.breadcrumb .bc-sep { color: var(--text-muted); cursor: default; }

/* Search */
.search-wrap {
  position: relative;
  margin-left: 16px;
}
.search-wrap input {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 12px 6px 32px;
  color: var(--text-primary);
  font-family: inherit;
  font-size: 13px;
  width: 220px;
  outline: none;
  transition: border-color 0.2s;
}
.search-wrap input:focus { border-color: var(--accent); }
.search-wrap::before {
  content: '🔍';
  position: absolute;
  left: 10px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 12px;
}

/* Layout */
.main {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* Sidebar */
.sidebar {
  width: 280px;
  min-width: 280px;
  background: var(--bg-surface);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  padding: 8px 0;
}
.sidebar::-webkit-scrollbar { width: 6px; }
.sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

.tree-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  cursor: pointer;
  font-size: 13px;
  color: var(--text-secondary);
  transition: background 0.15s, color 0.15s;
  user-select: none;
}
.tree-item:hover { background: var(--bg-hover); color: var(--text-primary); }
.tree-item.active { background: var(--accent-dim); color: var(--text-primary); }
.tree-item .icon { font-size: 14px; width: 18px; text-align: center; flex-shrink: 0; }
.tree-item .name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tree-item .arrow {
  font-size: 10px;
  width: 14px;
  text-align: center;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.tree-item .arrow.open { transform: rotate(90deg); }
.tree-children { display: none; }
.tree-children.open { display: block; }
.tree-item.hidden { display: none; }

/* Viewer */
.viewer {
  flex: 1;
  overflow-y: auto;
  padding: 32px 48px;
}
.viewer::-webkit-scrollbar { width: 8px; }
.viewer::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

.viewer-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--text-muted);
  gap: 12px;
}
.viewer-empty .big-icon { font-size: 48px; opacity: 0.5; }
.viewer-empty p { font-size: 14px; }

/* File Meta */
.file-meta {
  display: flex;
  gap: 16px;
  padding: 10px 16px;
  background: var(--bg-elevated);
  border-radius: 10px;
  margin-bottom: 24px;
  font-size: 12px;
  color: var(--text-secondary);
  flex-wrap: wrap;
}
.file-meta .tag {
  display: flex;
  align-items: center;
  gap: 4px;
}

/* Markdown Content */
.md-content {
  line-height: 1.7;
  font-size: 15px;
}
.md-content h1 { font-size: 28px; font-weight: 700; margin: 32px 0 16px; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 8px; }
.md-content h2 { font-size: 22px; font-weight: 600; margin: 28px 0 12px; }
.md-content h3 { font-size: 18px; font-weight: 600; margin: 24px 0 10px; }
.md-content h4 { font-size: 16px; font-weight: 600; margin: 20px 0 8px; }
.md-content p { margin: 10px 0; }
.md-content ul, .md-content ol { margin: 10px 0; padding-left: 24px; }
.md-content li { margin: 4px 0; }
.md-content a { color: var(--accent); text-decoration: none; }
.md-content a:hover { text-decoration: underline; }
.md-content blockquote {
  border-left: 3px solid var(--accent);
  padding: 8px 16px;
  margin: 12px 0;
  background: var(--bg-elevated);
  border-radius: 0 8px 8px 0;
  color: var(--text-secondary);
}
.md-content code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  background: var(--bg-elevated);
  padding: 2px 6px;
  border-radius: 4px;
}
.md-content pre {
  margin: 16px 0;
  border-radius: 10px;
  overflow-x: auto;
}
.md-content pre code {
  display: block;
  padding: 16px;
  background: oklch(0.14 0.02 270);
  border: 1px solid var(--border);
  border-radius: 10px;
  line-height: 1.5;
}
.md-content table {
  border-collapse: collapse;
  margin: 16px 0;
  width: 100%;
}
.md-content th, .md-content td {
  border: 1px solid var(--border);
  padding: 8px 12px;
  text-align: left;
  font-size: 13px;
}
.md-content th { background: var(--bg-elevated); font-weight: 600; }
.md-content hr { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
.md-content img { max-width: 100%; border-radius: 8px; }

/* Raw text */
.raw-content {
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
  background: var(--bg-elevated);
  padding: 20px;
  border-radius: 10px;
  border: 1px solid var(--border);
}
</style>
</head>
<body>

<div class="topbar">
  <a href="/" class="topbar-logo">🧠 ALFIE NEXUS</a>
  <div class="topbar-divider"></div>
  <a href="/" class="nav-link">📊 Dashboard</a>
  <a href="/browser.html" class="nav-link">🌐 Browser</a>
  <a href="/execute.html" class="nav-link">⚡ Execute</a>
  <a href="/research.html" class="nav-link">🔬 Research</a>
  <a href="/playground.html" class="nav-link">🎯 Playground</a>
  <a href="/replay.html" class="nav-link">🔄 Replay</a>
  <a href="/agents.html" class="nav-link">🤖 Agents</a>
  <a href="/knowledge.html" class="nav-link active">📚 Knowledge</a>
  <a href="/templates.html" class="nav-link">📝 Templates</a>
  <div class="topbar-spacer"></div>
  <div class="search-wrap">
    <input type="text" id="search" placeholder="Filter files..." autocomplete="off">
  </div>
</div>

<div class="main">
  <div class="sidebar" id="sidebar"></div>
  <div class="viewer" id="viewer">
    <div class="viewer-empty">
      <div class="big-icon">📂</div>
      <p>Select a file to view its contents</p>
    </div>
  </div>
</div>

<script>
marked.setOptions({
  highlight: (code, lang) => {
    if (lang && hljs.getLanguage(lang)) {
      return hljs.highlight(code, { language: lang }).value;
    }
    return hljs.highlightAuto(code).value;
  },
  breaks: true,
});

let treeData = [];
let activeFilePath = null;

async function loadTree() {
  const res = await fetch('/api/knowledge');
  const data = await res.json();
  treeData = data.tree || [];
  renderTree();
}

function renderTree() {
  const sidebar = document.getElementById('sidebar');
  sidebar.innerHTML = '';
  const q = document.getElementById('search').value.toLowerCase();
  for (const dir of treeData) {
    sidebar.appendChild(buildTreeNode(dir, [dir.name], q));
  }
}

function buildTreeNode(node, pathParts, query, depth = 0) {
  const frag = document.createDocumentFragment();

  if (node.type === 'dir') {
    const item = document.createElement('div');
    item.className = 'tree-item';
    item.style.paddingLeft = (12 + depth * 16) + 'px';
    item.innerHTML = `<span class="arrow">▶</span><span class="icon">📁</span><span class="name">${esc(node.name)}</span>`;

    const childContainer = document.createElement('div');
    childContainer.className = 'tree-children';

    let hasVisibleChild = false;
    if (node.children) {
      for (const child of node.children) {
        const childPath = [...pathParts, child.name];
        const el = buildTreeNode(child, childPath, query, depth + 1);
        childContainer.appendChild(el);
        if (el.querySelector && !el.classList?.contains('hidden')) hasVisibleChild = true;
        // Check if fragment has visible items
        if (el.nodeType === 11) {
          for (const c of el.children) {
            if (!c.classList.contains('hidden')) hasVisibleChild = true;
          }
        }
      }
    }

    // If searching and no visible children, hide dir
    if (query && !hasVisibleChild) {
      item.classList.add('hidden');
    }
    if (query && hasVisibleChild) {
      childContainer.classList.add('open');
      item.querySelector('.arrow').classList.add('open');
    }

    item.addEventListener('click', (e) => {
      e.stopPropagation();
      childContainer.classList.toggle('open');
      item.querySelector('.arrow').classList.toggle('open');
    });

    frag.appendChild(item);
    frag.appendChild(childContainer);
  } else {
    const item = document.createElement('div');
    item.className = 'tree-item';
    item.style.paddingLeft = (12 + depth * 16) + 'px';
    const icon = getFileIcon(node.name);
    item.innerHTML = `<span class="icon">${icon}</span><span class="name">${esc(node.name)}</span>`;
    item.dataset.path = pathParts.join('/');

    if (query && !node.name.toLowerCase().includes(query)) {
      item.classList.add('hidden');
    }

    item.addEventListener('click', (e) => {
      e.stopPropagation();
      document.querySelectorAll('.tree-item.active').forEach(el => el.classList.remove('active'));
      item.classList.add('active');
      loadFile(pathParts.join('/'));
    });

    frag.appendChild(item);
  }

  return frag;
}

function getFileIcon(name) {
  const ext = name.split('.').pop().toLowerCase();
  const map = { md: '📝', json: '📋', yaml: '⚙️', yml: '⚙️', py: '🐍', sh: '🔧', js: '🟨', ts: '🔷', txt: '📄', log: '📊', toml: '⚙️' };
  return map[ext] || '📄';
}

async function loadFile(filePath) {
  activeFilePath = filePath;
  updateBreadcrumb(filePath);
  const viewer = document.getElementById('viewer');
  viewer.innerHTML = '<div class="viewer-empty"><p>Loading...</p></div>';

  try {
    const res = await fetch('/api/knowledge/' + encodeURIComponent(filePath));
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    const meta = `
      <div class="file-meta">
        <div class="tag">📄 ${esc(data.name)}</div>
        <div class="tag">📏 ${humanSize(data.size)}</div>
        <div class="tag">🕐 ${new Date(data.modified).toLocaleString()}</div>
        <div class="tag">📝 ${data.wordCount.toLocaleString()} words</div>
      </div>`;

    if (data.ext === '.md') {
      viewer.innerHTML = meta + '<div class="md-content">' + marked.parse(data.content) + '</div>';
    } else {
      viewer.innerHTML = meta + '<div class="raw-content">' + esc(data.content) + '</div>';
    }

    // Re-highlight code blocks
    viewer.querySelectorAll('pre code').forEach(block => {
      hljs.highlightElement(block);
    });
  } catch (e) {
    viewer.innerHTML = `<div class="viewer-empty"><div class="big-icon">⚠️</div><p>${esc(e.message)}</p></div>`;
  }
}

function updateBreadcrumb(filePath) {
  const bc = document.getElementById('breadcrumb');
  const parts = filePath.split('/');
  bc.innerHTML = '';
  parts.forEach((p, i) => {
    if (i > 0) {
      const sep = document.createElement('span');
      sep.className = 'bc-sep';
      sep.textContent = '›';
      bc.appendChild(sep);
    }
    const span = document.createElement('span');
    span.textContent = p;
    bc.appendChild(span);
  });
}

function humanSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / 1048576).toFixed(1) + ' MB';
}

function esc(s) {
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

// Search
document.getElementById('search').addEventListener('input', () => renderTree());

// Init
loadTree();
</script>
</body>
</html>
