<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>🤖 ALFIE Agent Orchestration</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  color-scheme:dark;
  --void:oklch(0.06 0.01 270);
  --base:oklch(0.08 0.015 265);
  --surface:oklch(0.11 0.02 270);
  --elevated:oklch(0.15 0.025 270);
  --raised:oklch(0.19 0.025 265);
  --text-1:oklch(0.98 0.005 270);
  --text-2:oklch(0.72 0.012 270);
  --text-3:oklch(0.48 0.018 270);
  --purple:oklch(0.68 0.30 290);
  --cyan:oklch(0.78 0.22 195);
  --green:oklch(0.75 0.24 145);
  --amber:oklch(0.85 0.20 85);
  --red:oklch(0.65 0.29 25);
  --blue:oklch(0.72 0.20 240);
}
body{background:var(--void);color:var(--text-1);font-family:'Space Grotesk',sans-serif;min-height:100vh;overflow-x:hidden}
a{color:var(--cyan);text-decoration:none}
a:hover{text-decoration:underline}

/* Header */
.header{padding:10px 20px;display:flex;align-items:center;gap:12px;background:oklch(0.08 0.015 265/0.35);backdrop-filter:blur(10px) saturate(150%);border-bottom:1px solid oklch(0.38 0.04 270/0.15);position:sticky;top:0;z-index:100}
.header-logo{font-size:16px;font-weight:700;background:linear-gradient(135deg,oklch(0.68 0.30 290),oklch(0.78 0.22 195));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;white-space:nowrap;text-decoration:none}
.header-logo:hover{opacity:0.85}
.header-divider{width:1px;height:20px;background:oklch(0.38 0.04 270/0.2)}
.nav-link{color:oklch(0.70 0.18 280);font-size:12px;text-decoration:none;padding:5px 12px;border:1px solid oklch(0.30 0.02 280);border-radius:6px;white-space:nowrap;transition:all .2s}
.nav-link:hover{border-color:oklch(0.70 0.18 280);background:oklch(0.70 0.18 280/0.1);text-decoration:none}
.nav-link.active{background:oklch(0.70 0.18 280/0.15);border-color:oklch(0.70 0.18 280);color:oklch(0.78 0.22 195)}

/* Stats bar */
.stats-bar{display:flex;gap:24px;padding:16px 32px;border-bottom:1px solid oklch(0.12 0.015 270);flex-wrap:wrap}
.stat{display:flex;flex-direction:column;gap:2px}
.stat-label{font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-3)}
.stat-value{font-size:1.3rem;font-weight:700;font-family:'JetBrains Mono',monospace}
.stat-value.active{color:var(--green)}
.stat-value.total{color:var(--cyan)}
.stat-value.idle{color:var(--text-3)}

/* Spawn panel */
.spawn-panel{margin:20px 32px;padding:20px;background:var(--surface);border:1px solid oklch(0.18 0.03 290);border-radius:12px}
.spawn-panel h3{font-size:0.85rem;color:var(--purple);margin-bottom:12px;font-weight:600}
.spawn-form{display:flex;gap:10px;flex-wrap:wrap}
.spawn-form input,.spawn-form select{background:var(--base);border:1px solid var(--raised);color:var(--text-1);padding:10px 14px;border-radius:8px;font-family:'Space Grotesk',sans-serif;font-size:0.85rem;outline:none}
.spawn-form input:focus,.spawn-form select:focus{border-color:var(--purple)}
.spawn-form input[name="task"]{flex:1;min-width:250px}
.spawn-form input[name="label"]{width:160px}
.spawn-form select{width:180px}
.spawn-btn{background:oklch(0.68 0.30 290 / 0.2);border:1px solid var(--purple);color:var(--purple);padding:10px 20px;border-radius:8px;cursor:pointer;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:0.85rem;transition:all 0.2s}
.spawn-btn:hover{background:oklch(0.68 0.30 290 / 0.35)}
.spawn-btn:disabled{opacity:0.4;cursor:not-allowed}
.spawn-status{font-size:0.75rem;color:var(--green);padding:8px 0;display:none}

/* Agent grid */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:16px;padding:20px 32px}

/* Agent card */
.card{background:var(--surface);border:1px solid oklch(0.16 0.02 270);border-radius:12px;padding:16px;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden}
.card:hover{border-color:oklch(0.25 0.03 270);transform:translateY(-1px)}
.card.active{border-color:oklch(0.35 0.15 145 / 0.4)}
.card.expanded{grid-column:1/-1;max-width:900px}

.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.card-label{font-size:0.95rem;font-weight:600;display:flex;align-items:center;gap:8px}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot.active{background:var(--green);box-shadow:0 0 8px oklch(0.75 0.24 145 / 0.6)}
.dot.idle{background:var(--text-3)}
.card-status{font-size:0.65rem;text-transform:uppercase;letter-spacing:0.06em;padding:3px 8px;border-radius:4px;font-weight:600}
.card-status.active{background:oklch(0.75 0.24 145 / 0.15);color:var(--green)}
.card-status.idle{background:oklch(0.3 0.01 270 / 0.3);color:var(--text-3)}

.card-meta{display:flex;gap:16px;margin-bottom:10px;flex-wrap:wrap}
.card-meta span{font-size:0.7rem;color:var(--text-3);font-family:'JetBrains Mono',monospace}
.card-meta span b{color:var(--text-2)}

.card-preview{font-size:0.78rem;color:var(--text-2);line-height:1.5;max-height:3em;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;word-break:break-word}

.card-transcript{margin-top:14px;padding-top:14px;border-top:1px solid oklch(0.15 0.02 270);display:none;max-height:400px;overflow-y:auto}
.card.expanded .card-transcript{display:block}
.transcript-line{font-size:0.72rem;font-family:'JetBrains Mono',monospace;padding:4px 0;line-height:1.5;color:var(--text-2);border-bottom:1px solid oklch(0.10 0.01 270)}
.transcript-line .role{font-weight:600;margin-right:6px}
.transcript-line .role.assistant{color:var(--cyan)}
.transcript-line .role.user{color:var(--amber)}
.transcript-line .role.tool{color:var(--purple)}
.transcript-ts{color:var(--text-3);font-size:0.6rem;margin-right:8px}

/* Loading */
.loading{text-align:center;padding:60px;color:var(--text-3);font-size:0.85rem}
.refresh-indicator{font-size:0.7rem;color:var(--text-3);padding:0 32px 8px}

/* Scrollbar */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:oklch(0.25 0.02 270);border-radius:3px}
</style>
</head>
<body>

<div class="header">
  <a href="/" class="header-logo">🧠 ALFIE NEXUS</a>
  <div class="header-divider"></div>
  <a href="/" class="nav-link">📊 Dashboard</a>
  <a href="/browser.html" class="nav-link">🌐 Browser</a>
  <a href="/execute.html" class="nav-link">⚡ Execute</a>
  <a href="/research.html" class="nav-link">🔬 Research</a>
  <a href="/playground.html" class="nav-link">🎯 Playground</a>
  <a href="/replay.html" class="nav-link">🔄 Replay</a>
  <a href="/agents.html" class="nav-link active">🤖 Agents</a>
  <a href="/knowledge.html" class="nav-link">📚 Knowledge</a>
  <a href="/templates.html" class="nav-link">📝 Templates</a>
</div>

<div class="stats-bar" id="stats-bar">
  <div class="stat"><span class="stat-label">Active</span><span class="stat-value active" id="stat-active">—</span></div>
  <div class="stat"><span class="stat-label">Total Sessions</span><span class="stat-value total" id="stat-total">—</span></div>
  <div class="stat"><span class="stat-label">Idle</span><span class="stat-value idle" id="stat-idle">—</span></div>
  <div class="stat"><span class="stat-label">Last Refresh</span><span class="stat-value" id="stat-refresh" style="font-size:0.85rem;color:var(--text-2)">—</span></div>
</div>

<div class="spawn-panel">
  <h3>⚡ Spawn New Agent</h3>
  <form class="spawn-form" id="spawn-form">
    <input name="task" placeholder="Task description..." required>
    <input name="label" placeholder="Label" required>
    <select name="model">
      <option value="">Default Model</option>
      <option value="anthropic/claude-opus-4-6">Claude Opus 4.6</option>
      <option value="anthropic/claude-sonnet-4">Claude Sonnet 4</option>
      <option value="anthropic/claude-haiku-3.5">Claude Haiku 3.5</option>
    </select>
    <button type="submit" class="spawn-btn" id="spawn-btn">🚀 Spawn</button>
  </form>
  <div class="spawn-status" id="spawn-status"></div>
</div>

<div class="grid" id="grid">
  <div class="loading">Loading agents...</div>
</div>

<script>
const grid = document.getElementById('grid');
const form = document.getElementById('spawn-form');
let expandedId = null;
let transcriptCache = {};

function formatRuntime(sec) {
  if (sec < 60) return sec + 's';
  if (sec < 3600) return Math.floor(sec/60) + 'm ' + (sec%60) + 's';
  const h = Math.floor(sec/3600);
  const m = Math.floor((sec%3600)/60);
  return h + 'h ' + m + 'm';
}

function formatTime(ts) {
  const d = new Date(ts);
  return d.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
}

function escapeHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

async function fetchAgents() {
  try {
    const res = await fetch('/api/agents/active');
    const data = await res.json();
    renderStats(data.stats);
    renderGrid(data.agents);
    document.getElementById('stat-refresh').textContent = formatTime(Date.now());
  } catch(e) {
    console.error('Fetch failed:', e);
  }
}

function renderStats(stats) {
  document.getElementById('stat-active').textContent = stats.active;
  document.getElementById('stat-total').textContent = stats.total;
  document.getElementById('stat-idle').textContent = stats.total - stats.active;
}

function renderGrid(agents) {
  if (!agents.length) {
    grid.innerHTML = '<div class="loading">No sessions found</div>';
    return;
  }
  
  grid.innerHTML = agents.map(a => {
    const isExpanded = expandedId === a.sessionId;
    return `
    <div class="card ${a.status} ${isExpanded ? 'expanded' : ''}" data-id="${a.sessionId}" onclick="toggleCard('${a.sessionId}')">
      <div class="card-header">
        <span class="card-label"><span class="dot ${a.status}"></span>${escapeHtml(a.label)}</span>
        <span class="card-status ${a.status}">${a.status}</span>
      </div>
      <div class="card-meta">
        <span>⏱ <b>${formatRuntime(a.runtime)}</b></span>
        <span>💬 <b>${a.messageCount}</b> msgs</span>
        <span>🕐 <b>${formatTime(a.lastActivity)}</b></span>
        <span>🧠 <b>${escapeHtml((a.model||'').split('/').pop())}</b></span>
      </div>
      <div class="card-preview">${escapeHtml(a.lastMessage)}</div>
      <div class="card-transcript" id="transcript-${a.sessionId}">
        ${isExpanded && transcriptCache[a.sessionId] ? transcriptCache[a.sessionId] : '<div style="color:var(--text-3);font-size:0.72rem">Loading transcript...</div>'}
      </div>
    </div>`;
  }).join('');
  
  // If we have an expanded card, load its transcript
  if (expandedId) loadTranscript(expandedId);
}

async function toggleCard(id) {
  if (expandedId === id) {
    expandedId = null;
  } else {
    expandedId = id;
    loadTranscript(id);
  }
  fetchAgents();
}

async function loadTranscript(sessionId) {
  // Use existing /api/agents endpoint data + read last 20 lines via a simple approach
  // We'll fetch the full session data from the active endpoint
  try {
    const res = await fetch('/api/agents/active');
    const data = await res.json();
    const agent = data.agents.find(a => a.sessionId === sessionId);
    if (!agent) return;
    
    // Show what we have - the lastMessage as a simple transcript
    const el = document.getElementById('transcript-' + sessionId);
    if (el) {
      const html = `
        <div class="transcript-line">
          <span class="transcript-ts">${formatTime(agent.lastActivity)}</span>
          <span class="role assistant">assistant</span>
          ${escapeHtml(agent.lastMessage)}
        </div>
        <div style="color:var(--text-3);font-size:0.65rem;padding:8px 0">Session: ${sessionId}<br>Messages: ${agent.messageCount} total</div>
      `;
      transcriptCache[sessionId] = html;
      el.innerHTML = html;
    }
  } catch(e) {
    console.error('Transcript load failed:', e);
  }
}

// Spawn form
form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('spawn-btn');
  const status = document.getElementById('spawn-status');
  const fd = new FormData(form);
  const payload = { task: fd.get('task'), label: fd.get('label'), model: fd.get('model') || undefined };
  
  btn.disabled = true;
  btn.textContent = '⏳ Spawning...';
  
  try {
    const res = await fetch('/api/agents/spawn', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload) });
    const data = await res.json();
    if (data.ok) {
      status.style.display = 'block';
      status.style.color = 'var(--green)';
      status.textContent = `✅ Agent "${payload.label}" spawn requested`;
      form.reset();
      setTimeout(() => fetchAgents(), 2000);
    } else {
      throw new Error(data.error || 'Spawn failed');
    }
  } catch(err) {
    status.style.display = 'block';
    status.style.color = 'var(--red)';
    status.textContent = '❌ ' + err.message;
  } finally {
    btn.disabled = false;
    btn.textContent = '🚀 Spawn';
    setTimeout(() => status.style.display = 'none', 5000);
  }
});

// Initial load + auto-refresh
fetchAgents();
setInterval(fetchAgents, 10000);
</script>
</body>
</html>
