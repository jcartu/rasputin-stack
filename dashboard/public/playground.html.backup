<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>🧪 ALFIE Prompt Playground</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{color-scheme:dark;--bg:#0a0a0f;--surface:#12121a;--elevated:#1a1a26;--border:#2a2a3a;--text:#e8e8f0;--text2:#8888a0;--purple:#8b6cf6;--cyan:#22d3ee;--green:#34d399;--amber:#fbbf24;--red:#f87171}
body{font-family:'Space Grotesk',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
.header{display:flex;align-items:center;gap:12px;padding:10px 20px;background:oklch(0.08 0.015 265/0.35);backdrop-filter:blur(10px) saturate(150%);border-bottom:1px solid oklch(0.38 0.04 270/0.15);position:sticky;top:0;z-index:100}
.header-logo{font-size:16px;font-weight:700;background:linear-gradient(135deg,oklch(0.68 0.30 290),oklch(0.78 0.22 195));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;white-space:nowrap;text-decoration:none}
.header-logo:hover{opacity:0.85}
.header-divider{width:1px;height:20px;background:oklch(0.38 0.04 270/0.2)}
.nav-link{color:oklch(0.70 0.18 280);font-size:12px;text-decoration:none;padding:5px 12px;border:1px solid oklch(0.30 0.02 280);border-radius:6px;white-space:nowrap;transition:all .2s}
.nav-link:hover{border-color:oklch(0.70 0.18 280);background:oklch(0.70 0.18 280/0.1)}
.nav-link.active{background:oklch(0.70 0.18 280/0.15);border-color:oklch(0.70 0.18 280);color:oklch(0.78 0.22 195)}
.main{display:grid;grid-template-rows:auto 1fr;height:calc(100vh - 65px)}
.controls{padding:20px 24px;display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;border-bottom:1px solid var(--border);background:var(--surface)}
.field{display:flex;flex-direction:column;gap:4px}
.field label{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--text2);font-weight:600}
textarea{width:100%;min-height:80px;background:var(--elevated);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;resize:vertical}
textarea:focus{outline:none;border-color:var(--purple)}
.model-picker{display:flex;flex-wrap:wrap;gap:6px;max-width:600px}
.model-chip{padding:5px 12px;border-radius:16px;font-size:12px;font-family:'JetBrains Mono',monospace;cursor:pointer;border:1px solid var(--border);background:var(--elevated);color:var(--text2);transition:.15s}
.model-chip.selected{background:var(--purple);color:#fff;border-color:var(--purple)}
.model-chip:hover{border-color:var(--purple)}
.slider-row{display:flex;gap:16px;align-items:center}
.slider-row input[type=range]{width:100px;accent-color:var(--purple)}
.slider-row span{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text2);min-width:36px}
button.run{padding:8px 28px;border-radius:8px;border:none;background:linear-gradient(135deg,var(--purple),#6d4de8);color:#fff;font-weight:700;font-size:14px;cursor:pointer;transition:.2s;font-family:inherit}
button.run:hover{transform:translateY(-1px);box-shadow:0 4px 20px rgba(139,108,246,.4)}
button.run:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
.results{display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:16px;padding:20px 24px;overflow-y:auto}
.result-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;display:flex;flex-direction:column;overflow:hidden}
.result-header{padding:12px 16px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border);background:var(--elevated)}
.result-header .model-name{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;color:var(--cyan)}
.result-header .meta{margin-left:auto;display:flex;gap:12px;font-size:11px;color:var(--text2)}
.result-header .meta .time{color:var(--green)}
.result-header .meta .tokens{color:var(--amber)}
.result-header .meta .error{color:var(--red)}
.result-body{padding:16px;font-family:'JetBrains Mono',monospace;font-size:12.5px;line-height:1.7;white-space:pre-wrap;word-break:break-word;overflow-y:auto;max-height:500px;color:var(--text)}
.result-body.loading{color:var(--text2);font-style:italic}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--purple);border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.empty{display:flex;align-items:center;justify-content:center;height:100%;color:var(--text2);font-size:14px;flex-direction:column;gap:8px}
.prompt-field{flex:1 1 100%}
</style>
</head>
<body>
<div class="header">
  <a href="/" class="header-logo">🧠 ALFIE NEXUS</a>
  <div class="header-divider"></div>
  <a href="/" class="nav-link">📊 Dashboard</a>
  <a href="/browser.html" class="nav-link">🌐 Browser</a>
  <a href="/execute.html" class="nav-link">⚡ Execute</a>
  <a href="/research.html" class="nav-link">🔬 Research</a>
  <a href="/playground.html" class="nav-link active">🎯 Playground</a>
  <a href="/replay.html" class="nav-link">🔄 Replay</a>
  <a href="/agents.html" class="nav-link">🤖 Agents</a>
  <a href="/knowledge.html" class="nav-link">📚 Knowledge</a>
  <a href="/templates.html" class="nav-link">📝 Templates</a>
</div>
<div class="main">
  <div class="controls">
    <div class="field prompt-field">
      <label>Prompt</label>
      <textarea id="prompt" rows="3" placeholder="Enter your prompt here..."></textarea>
    </div>
    <div class="field">
      <label>Models</label>
      <div class="model-picker" id="modelPicker"><span style="color:var(--text2);font-size:12px">Loading models...</span></div>
    </div>
    <div class="field">
      <label>Settings</label>
      <div class="slider-row">
        <span>Temp</span><input type="range" id="temp" min="0" max="2" step="0.1" value="0.7"><span id="tempVal">0.7</span>
        <span style="margin-left:8px">Tokens</span><input type="range" id="maxTok" min="128" max="4096" step="128" value="1024"><span id="tokVal">1024</span>
      </div>
    </div>
    <button class="run" id="runBtn" onclick="runPlayground()">▶ Run</button>
  </div>
  <div class="results" id="results">
    <div class="empty">
      <div style="font-size:32px">🧪</div>
      <div>Select models and enter a prompt to compare responses</div>
    </div>
  </div>
</div>
<script>
const modelPicker=document.getElementById('modelPicker');
const resultsDiv=document.getElementById('results');
const tempSlider=document.getElementById('temp');
const tokSlider=document.getElementById('maxTok');
const tempVal=document.getElementById('tempVal');
const tokVal=document.getElementById('tokVal');
tempSlider.oninput=()=>tempVal.textContent=tempSlider.value;
tokSlider.oninput=()=>tokVal.textContent=tokSlider.value;

let allModels=[];
let selectedModels=new Set();

// Popular models to pre-select
const popular=['claude-sonnet-4-20250514','gpt-4o','gemini/gemini-2.5-flash','groq/llama-3.3-70b-versatile'];

async function loadModels(){
  try{
    const r=await fetch('/api/playground/models');
    const d=await r.json();
    allModels=d.models||[];
    modelPicker.innerHTML='';
    if(!allModels.length){modelPicker.innerHTML='<span style="color:var(--red);font-size:12px">No models found (LiteLLM down?)</span>';return}
    allModels.forEach(m=>{
      const chip=document.createElement('div');
      chip.className='model-chip';
      chip.textContent=m.id;
      chip.dataset.id=m.id;
      if(popular.includes(m.id)){chip.classList.add('selected');selectedModels.add(m.id)}
      chip.onclick=()=>{
        if(selectedModels.has(m.id)){selectedModels.delete(m.id);chip.classList.remove('selected')}
        else{selectedModels.add(m.id);chip.classList.add('selected')}
      };
      modelPicker.appendChild(chip);
    });
  }catch(e){modelPicker.innerHTML=`<span style="color:var(--red);font-size:12px">Error: ${e.message}</span>`}
}

async function runPlayground(){
  const prompt=document.getElementById('prompt').value.trim();
  if(!prompt){alert('Enter a prompt');return}
  if(!selectedModels.size){alert('Select at least one model');return}
  const models=[...selectedModels];
  const btn=document.getElementById('runBtn');
  btn.disabled=true;btn.textContent='⏳ Running...';
  
  // Show loading cards
  resultsDiv.innerHTML='';
  models.forEach(m=>{
    const card=document.createElement('div');card.className='result-card';card.id='card-'+CSS.escape(m);
    card.innerHTML=`<div class="result-header"><span class="model-name">${m}</span><div class="meta"><span class="time"><span class="spinner"></span></span></div></div><div class="result-body loading">Waiting for response...</div>`;
    resultsDiv.appendChild(card);
  });

  try{
    const r=await fetch('/api/playground',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt,models,temperature:parseFloat(tempSlider.value),maxTokens:parseInt(tokSlider.value)})});
    const d=await r.json();
    if(d.error){resultsDiv.innerHTML=`<div class="empty" style="color:var(--red)">${d.error}</div>`;return}
    d.results.forEach(res=>{
      const card=document.getElementById('card-'+CSS.escape(res.model));
      if(!card)return;
      const tokInfo=res.usage?.total_tokens?`${res.usage.total_tokens} tok`:'';
      const timeColor=res.elapsed<3000?'var(--green)':res.elapsed<10000?'var(--amber)':'var(--red)';
      card.querySelector('.result-header .meta').innerHTML=
        (res.error?`<span class="error">❌ ${res.error}</span>`:'') +
        `<span class="time" style="color:${timeColor}">${(res.elapsed/1000).toFixed(1)}s</span>` +
        (tokInfo?`<span class="tokens">${tokInfo}</span>`:'');
      const body=card.querySelector('.result-body');
      body.classList.remove('loading');
      body.textContent=res.error&&!res.text?`Error: ${res.error}`:res.text;
    });
  }catch(e){resultsDiv.innerHTML=`<div class="empty" style="color:var(--red)">Request failed: ${e.message}</div>`}
  finally{btn.disabled=false;btn.textContent='▶ Run'}
}

loadModels();
</script>
</body>
</html>
