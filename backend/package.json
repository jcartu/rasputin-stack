{
  "name": "alfie-backend",
  "version": "1.0.0",
  "description": "Backend API server for ALFIE UI - real-time communication with OpenClaw gateway",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node --require ./src/observability/tracing.cjs src/index.js",
    "start:no-otel": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test tests/*.test.js",
    "test:backup": "node --test tests/backup.test.js",
    "db:init": "node src/db/migrate.js init",
    "db:migrate": "node src/db/migrate.js up",
    "db:rollback": "node src/db/migrate.js down",
    "db:status": "node src/db/migrate.js status",
    "db:create": "node src/db/migrate.js create"
  },
  "keywords": [
    "nexus",
    "openclaw",
    "websocket",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.41.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/instrumentation-express": "^0.35.0",
    "@opentelemetry/instrumentation-http": "^0.48.0",
    "@opentelemetry/resources": "^1.21.0",
    "@opentelemetry/sdk-metrics": "^1.21.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/sdk-trace-base": "^1.21.0",
    "@opentelemetry/sdk-trace-node": "^1.21.0",
    "@opentelemetry/semantic-conventions": "^1.21.0",
    "@prisma/client": "^7.3.0",
    "@sentry/node": "^7.100.0",
    "@sentry/profiling-node": "^7.100.0",
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lib0": "^0.2.117",
    "marked": "^17.0.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "on-finished": "^2.4.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pino": "^8.18.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.3.1",
    "prisma": "^7.3.0",
    "prom-client": "^15.1.0",
    "response-time": "^2.3.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
