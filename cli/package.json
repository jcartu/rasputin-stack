{
  "name": "@alfie/cli",
  "version": "1.0.0",
  "description": "ALFIE CLI - Command-line interface for ALFIE AI assistant",
  "author": "ALFIE Team",
  "license": "MIT",
  "keywords": [
    "nexus",
    "cli",
    "ai",
    "assistant",
    "memory",
    "search",
    "consensus"
  ],
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "nexus": "./src/index.js"
  },
  "files": [
    "src",
    "completions",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "lint": "eslint src/",
    "test": "node --test src/**/*.test.js",
    "postinstall": "node src/lib/setup.js || true"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "cli-table3": "^0.6.3",
    "node-fetch": "^3.3.2",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "readline": "^1.3.0",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alfie-ai/alfie-cli"
  },
  "bugs": {
    "url": "https://github.com/alfie-ai/alfie-cli/issues"
  },
  "homepage": "https://github.com/alfie-ai/alfie-cli#readme"
